function agent_diagnostics_request(clientName: string, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (!is_admin_user(current) && !is_owner_user(current)) {
    return raw_json_error(403, 'permission denied');
  }
  const normalizedClientName = normalize_user_name(clientName);
  const targetUser = find_user_by_identity(normalizedClientName);
  if (targetUser != null && !can_manage_user(current, targetUser)) {
    return raw_json_error(403, 'permission denied');
  }
  let targetOwnerUserId = null;
  if (targetUser != null) {
    targetOwnerUserId = targetUser.ownerUserId;
  }
  let targetClientUserId = null;
  if (targetUser != null) {
    targetClientUserId = targetUser.id;
  }
  const agent = ensure_agent(normalizedClientName, targetClientUserId, targetOwnerUserId);
  const updated = db.update(Agent, { clientName: normalizedClientName }, {
    diagnosticRequestId: uuid.v4(),
    diagnosticRequestedAt: now_iso(),
    diagnosticRequestedByUserId: current.id,
    diagnosticStatus: 'requested',
    updatedAt: now_iso()
  });
  if (updated == null) {
    return raw_json_error(404, 'client not found');
  }
  return {
    ok: true,
    clientName: normalizedClientName,
    diagnostics: agent_diagnostics_payload(updated)
  };
}

function agent_diagnostics_request_all(token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (!is_admin_user(current) && !is_owner_user(current)) {
    return raw_json_error(403, 'permission denied');
  }

  const requestId = uuid.v4();
  const requestedAt = now_iso();
  const visibleAgents = visible_agent_rows_for(current);
  let requestedClientNames = [];
  for (const agent of visibleAgents) {
    const clientName = normalize_user_name(agent.clientName);
    if (clientName.length != 0) {
      requestedClientNames = requestedClientNames.concat([clientName]);
    }
  }
  if (requestedClientNames.length == 0) {
    return {
      ok: true,
      requestId,
      requestedAt,
      requestedByUserId: current.id,
      requestedClientCount: 0,
      requestedClientNames: []
    };
  }

  if (is_owner_user(current)) {
    db.updateMany(Agent, { ownerUserId: current.id }, {
      diagnosticRequestId: requestId,
      diagnosticRequestedAt: requestedAt,
      diagnosticRequestedByUserId: current.id,
      diagnosticStatus: 'requested',
      updatedAt: requestedAt
    });
  } else {
    db.updateMany(Agent, { clientName: { gte: '' } }, {
      diagnosticRequestId: requestId,
      diagnosticRequestedAt: requestedAt,
      diagnosticRequestedByUserId: current.id,
      diagnosticStatus: 'requested',
      updatedAt: requestedAt
    });
  }

  return {
    ok: true,
    requestId,
    requestedAt,
    requestedByUserId: current.id,
    requestedClientCount: requestedClientNames.length,
    requestedClientNames
  };
}

function agent_diagnostics_upload(clientName: string? = null, requestId: string? = null, summary: string = '', payload: string = '', token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  let resolvedClientName = '';
  if (clientName == null || clientName.trim().length == 0) {
    if (current.username == null) {
      resolvedClientName = normalize_user_name(current.name);
    } else {
      resolvedClientName = normalize_user_name(current.username);
    }
  } else {
    resolvedClientName = normalize_user_name(clientName);
  }
  const targetUser = find_user_by_identity(resolvedClientName);
  if (targetUser != null && !can_manage_user(current, targetUser)) {
    return raw_json_error(403, 'permission denied');
  }
  let targetOwnerUserId = owner_namespace_for_user(current);
  let targetClientUserId = current.id;
  if (targetUser != null) {
    targetOwnerUserId = targetUser.ownerUserId;
    targetClientUserId = targetUser.id;
  }
  const agent = ensure_agent(resolvedClientName, targetClientUserId, targetOwnerUserId);
  let resolvedRequestId = '';
  if (requestId != null) {
    resolvedRequestId = string.from(requestId).trim();
  }
  if (resolvedRequestId.length == 0 && agent.diagnosticRequestId != null) {
    resolvedRequestId = string.from(agent.diagnosticRequestId).trim();
  }
  let resolvedRequestIdOrNull = null;
  if (resolvedRequestId.length != 0) {
    resolvedRequestIdOrNull = resolvedRequestId;
  }
  const updated = db.update(Agent, { clientName: resolvedClientName }, {
    diagnosticLastRequestId: resolvedRequestIdOrNull,
    diagnosticLastUploadedAt: now_iso(),
    diagnosticStatus: 'uploaded',
    diagnosticSummary: truncate_text(summary, 4000),
    diagnosticPayload: truncate_text(payload, 64000),
    updatedAt: now_iso()
  });
  if (updated == null) {
    return raw_json_error(404, 'client not found');
  }
  return {
    ok: true,
    clientName: resolvedClientName,
    diagnostics: agent_diagnostics_payload(updated)
  };
}

function agent_diagnostics_get(clientName: string, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  const normalizedClientName = normalize_user_name(clientName);
  const agent = db.selectOne(Agent, { clientName: normalizedClientName });
  if (agent == null) {
    return raw_json_error(404, 'client not found');
  }
  if (!can_read_agent(current, agent.ownerUserId, agent.clientUserId)) {
    return raw_json_error(403, 'permission denied');
  }
  return {
    clientName: normalizedClientName,
    diagnostics: agent_diagnostics_payload(agent, true)
  };
}

function jobs_create_all_enabled(token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (!is_admin_user(current) && !is_owner_user(current)) {
    return raw_json_error(403, 'permission denied');
  }

  let createdJobs = [];
  let queuedClientNames = [];
  let skippedOfflineClients = [];
  let skippedBusyTables = [];

  const visibleAgents = visible_agent_rows_for(current);
  for (const agent of visibleAgents) {
    let enabledTables = unique_string_values(enabled_sync_tables_for_agent(agent).concat(enabled_sync_policy_tables_for_agent(agent)));
    if (enabledTables.length == 0) {
      enabledTables = latest_completed_job_tables_for_client(agent.clientName);
    }
    if (enabledTables.length == 0) {
      continue;
    }
    if (agent.isOnline != true || agent.serverConnected != true || agent.sqlConnected != true) {
      skippedOfflineClients = skippedOfflineClients.concat([string.from(agent.clientName)]);
      continue;
    }
    const activeTables = active_job_tables_for_client(agent.clientName);
    let tablesToQueue = [];
    for (const table of enabledTables) {
      let busy = false;
      for (const activeTable of activeTables) {
        if (activeTable == table) {
          busy = true;
        }
      }
      if (busy) {
        skippedBusyTables = skippedBusyTables.concat([string.concat(agent.clientName, '::', table)]);
      } else {
        tablesToQueue = tablesToQueue.concat([table]);
      }
    }
    if (tablesToQueue.length == 0) {
      continue;
    }
    for (const sourceAgent of visibleAgents) {
      if (sourceAgent.clientName == agent.clientName) {
        continue;
      }
      if (sourceAgent.ownerUserId != agent.ownerUserId) {
        continue;
      }
      if (sourceAgent.isOnline != true || sourceAgent.serverConnected != true || sourceAgent.sqlConnected != true) {
        continue;
      }
      const clientJobs = create_sync_jobs_for_agent(agent, tablesToQueue, string.from(sourceAgent.clientName));
      if (clientJobs.length > 0) {
        createdJobs = createdJobs.concat(clientJobs);
        queuedClientNames = queuedClientNames.concat([string.from(agent.clientName)]);
      }
    }
  }

  return {
    ok: true,
    jobs: createdJobs.map((job) => public_job_payload(job)),
    queuedJobCount: createdJobs.length,
    queuedClientCount: unique_string_values(queuedClientNames).length,
    skippedOfflineClients: unique_string_values(skippedOfflineClients),
    skippedBusyTables: unique_string_values(skippedBusyTables)
  };
}

function sync_job_reset_batch(limit: int = 200): map<json> {
  const rows = db.selectMany(SyncJob, {
    where: { id: { gte: '' } },
    orderBy: { field: 'id', dir: 'asc' },
    fields: ['id'],
    limit
  });
  if (rows == null || rows.length == 0) {
    return { deletedCount: 0, hasMore: false };
  }
  let ids = [];
  for (const row of rows) {
    ids = ids.concat([string.from(row.id)]);
  }
  return {
    deletedCount: db.deleteMany(SyncJob, { id: { in: ids } }),
    hasMore: rows.length >= limit
  };
}

function reset_all_agent_saved_state(): int {
  return db.updateMany(Agent, { clientName: { gte: '' } }, {
    selectedTable: null,
    tables: [],
    diagnosticRequestId: null,
    diagnosticRequestedAt: null,
    diagnosticRequestedByUserId: null,
    diagnosticLastRequestId: null,
    diagnosticLastUploadedAt: null,
    diagnosticStatus: 'idle',
    diagnosticSummary: '',
    diagnosticPayload: '',
    updatedAt: now_iso()
  });
}

function server_saved_data_reset(resetAgents: bool = true, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (!is_admin_user(current)) {
    return raw_json_error(403, 'permission denied');
  }

  const syncJobBatch = sync_job_reset_batch();
  let agentResetCount = 0;
  if (resetAgents) {
    agentResetCount = reset_all_agent_saved_state();
  }
  const jobDeletedCount = syncJobBatch.deletedCount;
  const hasMore = syncJobBatch.hasMore == true;

  return {
    ok: true,
    jobDeletedCount,
    agentResetCount,
    hasMore,
    totalDeletedCount: jobDeletedCount
  };
}

function jobs_create(clientName: string, tables: array<string>, direction: string = 'sync', sourceClientName: string = '', syncMode: string? = null, token: string? = null): map<json> {
  if (tables.length == 0) {
    return raw_json_error(400, 'tables are required.');
  }
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  let resolvedClientName = clientName;
  if (clientName.trim().length == 0) {
    if (current.username != null) {
      resolvedClientName = current.username;
    }
  }
  const clientUser = find_user_by_identity(resolvedClientName);
  if (clientUser != null && !can_manage_user(current, clientUser)) {
    return raw_json_error(403, 'permission denied');
  }
  let clientUserId = null;
  let ownerId = owner_namespace_for_user(current);
  if (clientUser != null) {
    clientUserId = clientUser.id;
    ownerId = owner_namespace_for_user(clientUser);
  }
  const expandedTables = expand_sync_job_tables_for_owner(ownerId, tables);
  if (expandedTables.length == 0) {
    return raw_json_error(400, 'tables are required.');
  }
  const activeTables = active_job_tables_for_client(resolvedClientName);
  let tablesToCreate = [];
  for (const table of expandedTables) {
    let busy = false;
    for (const activeTable of activeTables) {
      if (activeTable == table) {
        busy = true;
      }
    }
    if (!busy) {
      tablesToCreate = tablesToCreate.concat([table]);
    }
  }
  if (tablesToCreate.length == 0) {
    return raw_json_success({ jobs: [] }, 201);
  }
  let sourceAgent = null;
  let resolvedSourceClientName = sourceClientName.trim();
  if (resolvedSourceClientName.length != 0) {
    sourceAgent = db.selectOne(Agent, { clientName: resolvedSourceClientName });
    if (sourceAgent == null) {
      return raw_json_error(404, 'source client not found');
    }
  }
  let createdJobsRaw = [];
  for (const table of tablesToCreate) {
    const resolvedMode = normalize_sync_mode(syncMode, true);
    if (sourceAgent != null && resolvedSourceClientName != resolvedClientName) {
      createdJobsRaw = createdJobsRaw.concat([{
        id: uuid.v4(),
        clientName: resolvedClientName,
        sourceClientName: resolvedSourceClientName,
        subscriberClientName: resolvedClientName,
        table,
        direction: direction_for_sync_mode(resolvedMode),
        mergeRole: 'symmetricds',
        publisherServer: sourceAgent.server,
        publisherDatabase: sourceAgent.database,
        publicationName: '',
        publisherUseWindowsAuth: sourceAgent.replicationUseWindowsAuth == true,
        publisherUser: sourceAgent.replicationUser,
        publisherPassword: sourceAgent.replicationPassword,
        status: 'queued',
        progress: 0,
        rowCount: 0,
        snapshotBytes: 0,
        snapshotCreatedAt: null,
        snapshotId: null,
        createdAt: now_iso(),
        updatedAt: now_iso(),
        startedAt: null,
        completedAt: null,
        message: string.concat('Queued SymmetricDS sync for ', table, '.'),
        error: null,
        clientUserId,
        ownerUserId: ownerId
      }]);
      continue;
    }
    let publisherServer = '';
    let publisherDatabase = '';
    let publisherUseWindowsAuth = false;
    let publisherUser = '';
    let publisherPassword = '';
    if (sourceAgent != null) {
      publisherServer = sourceAgent.server;
      publisherDatabase = sourceAgent.database;
      publisherUseWindowsAuth = sourceAgent.replicationUseWindowsAuth == true;
      publisherUser = sourceAgent.replicationUser;
      publisherPassword = sourceAgent.replicationPassword;
    }
    createdJobsRaw = createdJobsRaw.concat([{
      id: uuid.v4(),
      clientName: resolvedClientName,
      sourceClientName: resolvedSourceClientName,
      subscriberClientName: resolvedClientName,
      table,
      direction: direction_for_sync_mode(resolvedMode),
      mergeRole: 'symmetricds',
      publisherServer,
      publisherDatabase,
      publicationName: '',
      publisherUseWindowsAuth,
      publisherUser,
      publisherPassword,
      status: 'queued',
      progress: 0,
      rowCount: 0,
      snapshotBytes: 0,
      snapshotCreatedAt: null,
      snapshotId: null,
      createdAt: now_iso(),
      updatedAt: now_iso(),
      startedAt: null,
      completedAt: null,
      message: string.concat('Queued SymmetricDS sync for ', table, '.'),
      error: null,
      clientUserId,
      ownerUserId: ownerId
    }]);
  }
  const createdJobs = db.insertMany(SyncJob, createdJobsRaw);
  return raw_json_success({ jobs: createdJobs.map((job) => public_job_payload(job)) }, 201);
}

function jobs_start(jobId: string, status: string = 'running', progress: int? = null, message: string = 'Started SymmetricDS sync.', token: string? = null): map<json> {
  const current = current_user_record(token);
  const job = find_job_by_id(jobId);
  if (job == null) {
    return raw_json_error(404, 'job not found');
  }
  if (!can_access_job(current, job)) {
    return deny_job_access('jobs_start', token, current, job);
  }

  let nextProgress = 5;
  if (progress != null) {
    nextProgress = progress;
  }
  const updated = db.update(SyncJob, { id: jobId }, {
    clientName: job.clientName,
    sourceClientName: job.sourceClientName,
    subscriberClientName: job.subscriberClientName,
    table: job.table,
    direction: job.direction,
    mergeRole: job.mergeRole,
    publisherServer: job.publisherServer,
    publisherDatabase: job.publisherDatabase,
    publicationName: job.publicationName,
    publisherUseWindowsAuth: job.publisherUseWindowsAuth,
    publisherUser: job.publisherUser,
    publisherPassword: job.publisherPassword,
    status,
    progress: nextProgress,
    rowCount: job.rowCount,
    snapshotBytes: job.snapshotBytes,
    snapshotCreatedAt: job.snapshotCreatedAt,
    snapshotId: job.snapshotId,
    createdAt: job.createdAt,
    message,
    startedAt: now_iso(),
    completedAt: null,
    error: null,
    clientUserId: job.clientUserId,
    ownerUserId: job.ownerUserId,
    updatedAt: now_iso()
  });
  let nextJob = job;
  if (updated != null) {
    nextJob = updated;
  }
  return { job: public_job_payload(nextJob) };
}

function jobs_progress(jobId: string, status: string = 'running', progress: int, message: string, rowCount: int, direction: string, token: string? = null): map<json> {
  const current = current_user_record(token);
  const job = find_job_by_id(jobId);
  if (job == null) {
