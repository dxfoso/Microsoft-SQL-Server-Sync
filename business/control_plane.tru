function visible_user_rows_for(current: map<json>): array<json> {
  if (is_admin_user(current)) {
    return list_user_rows();
  }
  let users = [];
  for (const user of list_user_rows()) {
    if (can_manage_user(current, user)) {
      users = users.concat([user]);
    }
  }
  return users;
}

function visible_agent_rows_for(current: map<json>): array<json> {
  if (is_admin_user(current)) {
    return list_agent_rows();
  }
  let agents = [];
  for (const agent of list_agent_rows()) {
    if (can_read_agent(current, agent.ownerUserId, agent.clientUserId)) {
      agents = agents.concat([agent]);
    }
  }
  return agents;
}

function visible_job_rows_for(current: map<json>): array<json> {
  if (is_admin_user(current)) {
    return list_job_rows();
  }
  let jobs = [];
  for (const job of list_job_rows()) {
    if (can_access_job(current, job)) {
      jobs = jobs.concat([job]);
    }
  }
  return jobs;
}

function visible_snapshot_rows_for(current: map<json>): array<json> {
  if (is_admin_user(current)) {
    return list_snapshot_rows();
  }
  let snapshots = [];
  for (const snapshot of list_snapshot_rows()) {
    if (can_read_agent(current, snapshot.ownerUserId, snapshot.clientUserId)) {
      snapshots = snapshots.concat([snapshot]);
    }
  }
  return snapshots;
}

function public_agent_payload(agent: map<json>): map<json> {
  let nextTables = [];
  if (agent.tables != null) {
    nextTables = apply_table_sync_policies(agent.ownerUserId, bounded_agent_tables(agent.tables, agent.selectedTable), string.from(agent.database));
  }
  return {
    clientName: agent.clientName,
    machineName: agent.machineName,
    server: agent.server,
    database: agent.database,
    isOnline: agent.isOnline,
    historyLimit: agent.historyLimit,
    autoSyncIntervalMinutes: agent.autoSyncIntervalMinutes,
    serverConnected: agent.serverConnected,
    sqlConnected: agent.sqlConnected,
    lastHeartbeat: agent.lastHeartbeat,
    selectedTable: agent.selectedTable,
    diagnostics: agent_diagnostics_payload(agent),
    tables: nextTables,
    clientUserId: agent.clientUserId,
    ownerUserId: agent.ownerUserId
  };
}

function diagnostic_request_pending(agent: map<json>): bool {
  if (agent.diagnosticRequestId == null) {
    return false;
  }
  const requestId = string.from(agent.diagnosticRequestId).trim();
  if (requestId.length == 0) {
    return false;
  }
  if (agent.diagnosticLastRequestId == null) {
    return true;
  }
  return string.from(agent.diagnosticLastRequestId).trim() != requestId;
}

function agent_diagnostics_payload(agent: map<json>, includePayload: bool = false): map<json> {
  let payload = null;
  if (includePayload && agent.diagnosticPayload != null) {
    payload = agent.diagnosticPayload;
  }
  return {
    pending: diagnostic_request_pending(agent),
    requestId: agent.diagnosticRequestId,
    requestedAt: agent.diagnosticRequestedAt,
    requestedByUserId: agent.diagnosticRequestedByUserId,
    uploadedAt: agent.diagnosticLastUploadedAt,
    lastRequestId: agent.diagnosticLastRequestId,
    status: agent.diagnosticStatus,
    summary: agent.diagnosticSummary,
    payload: payload
  };
}

function table_sync_policy_set(table: string, enabled: bool, syncMode: string? = null, clientName: string? = null, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (!is_client_user(current) && !is_owner_user(current) && !is_admin_user(current)) {
    return raw_json_error(403, 'permission denied');
  }
  const normalizedTable = table.trim();
  if (normalizedTable.length == 0) {
    return raw_json_error(400, 'table is required');
  }
  let ownerUserId = owner_namespace_for_user(current);
  let normalizedClientName = '';
  if (clientName != null) {
    normalizedClientName = string.from(clientName).trim();
  }
  if (normalizedClientName.length != 0) {
    const targetAgent = db.selectOne(Agent, { clientName: normalizedClientName });
    if (targetAgent == null) {
      return raw_json_error(404, 'client not found');
    }
    if (!can_read_agent(current, targetAgent.ownerUserId, targetAgent.clientUserId)) {
      return raw_json_error(403, 'permission denied');
    }
    if (targetAgent.ownerUserId != null && targetAgent.ownerUserId.trim().length != 0) {
      ownerUserId = targetAgent.ownerUserId;
    } else if (targetAgent.clientUserId != null && targetAgent.clientUserId.trim().length != 0) {
      ownerUserId = targetAgent.clientUserId;
    }
  }
  const policy = upsert_table_sync_policy(
    ownerUserId,
    normalizedTable,
    enabled,
    syncMode,
    current.username
  );
  if (enabled) {
    const relatedTables = related_table_sync_keys_for_policy(ownerUserId, normalizedTable);
    for (const relatedTable of relatedTables) {
      upsert_table_sync_policy(
        ownerUserId,
        string.from(relatedTable),
        true,
        syncMode,
        current.username
      );
    }
  }
  return { ok: true, policy: table_sync_policy_payload(policy) };
}

function table_dependency_policy_set(table: string, relatedTable: string, relationshipType: string = 'business', database: string = '', clientName: string? = null, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (!is_client_user(current) && !is_owner_user(current) && !is_admin_user(current)) {
    return raw_json_error(403, 'permission denied');
  }
  const normalizedTable = table.trim();
  const normalizedRelatedTable = relatedTable.trim();
  if (normalizedTable.length == 0 || normalizedRelatedTable.length == 0) {
    return raw_json_error(400, 'table and relatedTable are required');
  }
  let ownerUserId = owner_namespace_for_user(current);
  let normalizedClientName = '';
  if (clientName != null) {
    normalizedClientName = string.from(clientName).trim();
  }
  if (normalizedClientName.length != 0) {
    const targetAgent = db.selectOne(Agent, { clientName: normalizedClientName });
    if (targetAgent == null) {
      return raw_json_error(404, 'client not found');
    }
    if (!can_read_agent(current, targetAgent.ownerUserId, targetAgent.clientUserId)) {
      return raw_json_error(403, 'permission denied');
    }
    if (targetAgent.ownerUserId != null && targetAgent.ownerUserId.trim().length != 0) {
      ownerUserId = targetAgent.ownerUserId;
    } else if (targetAgent.clientUserId != null && targetAgent.clientUserId.trim().length != 0) {
      ownerUserId = targetAgent.clientUserId;
    }
  }
  const dependency = normalized_table_dependency_payload(
    database,
    normalizedTable,
    normalizedRelatedTable,
    relationshipType,
    current.username
  );
  if (dependency == null) {
    return raw_json_error(400, 'valid related tables are required');
  }
  const reverseDependency = normalized_table_dependency_payload(
    database,
    normalizedRelatedTable,
    normalizedTable,
    relationshipType,
    current.username
  );
  let relationshipRows = [dependency];
  if (reverseDependency != null) {
    relationshipRows = relationshipRows.concat([reverseDependency]);
  }
  let targetClientName = normalizedClientName;
  if (targetClientName.length == 0) {
    targetClientName = current.username;
  }
  const agent = ensure_agent(targetClientName, current.id, ownerUserId);
  db.update(Agent, { clientName: agent.clientName }, {
    tableRelationships: bounded_table_relationships(database, (agent.tableRelationships ?? []).concat(relationshipRows), current.username),
    updatedAt: now_iso()
  });
  return {
    ok: true,
    dependencies: table_dependency_payloads_for_database(ownerUserId, database)
  };
}

function public_job_payload(job: map<json>): map<json> {
  return {
    id: job.id,
    clientName: job.clientName,
    sourceClientName: job.sourceClientName,
    table: job.table,
    direction: job.direction,
    status: job.status,
    progress: job.progress,
    rowCount: job.rowCount,
    createdAt: job.createdAt,
    updatedAt: job.updatedAt,
    startedAt: job.startedAt,
    completedAt: job.completedAt,
    snapshotId: job.snapshotId,
    snapshotCreatedAt: job.snapshotCreatedAt,
    snapshotBytes: job.snapshotBytes,
    message: job.message,
    error: job.error
  };
}

function public_snapshot_payload(snapshot: map<json>): map<json> {
  return {
    id: snapshot.id,
    clientName: snapshot.clientName,
    clientUserId: snapshot.clientUserId,
    ownerUserId: snapshot.ownerUserId,
    table: snapshot.table,
    rowCount: snapshot.rowCount,
    checksum: snapshot.checksum,
    createdAt: snapshot.createdAt,
    snapshotBytes: snapshot.snapshotBytes,
    columns: snapshot.columns,
    previewRows: snapshot.previewRows,
    sourceJobId: snapshot.sourceJobId
  };
}

function public_snapshot_detail_payload(snapshot: map<json>): map<json> {
  return {
    id: snapshot.id,
    clientName: snapshot.clientName,
    clientUserId: snapshot.clientUserId,
    ownerUserId: snapshot.ownerUserId,
    table: snapshot.table,
    rowCount: snapshot.rowCount,
    checksum: snapshot.checksum,
    createdAt: snapshot.createdAt,
    snapshotBytes: snapshot.snapshotBytes,
    columns: snapshot.columns,
    rows: snapshot.rows,
    sourceJobId: snapshot.sourceJobId
  };
}

function snapshot_download_session_for(snapshot: map<json>): map<json> {
  let session = find_download_session_for_snapshot(snapshot.id);
  if (session != null) {
    return session;
  }

  const downloadChunks = row_download_chunks(snapshot.rows, row_download_page_size());
  const fallbackJobId = snapshot.sourceJobId ?? snapshot.id;
  session = db.insert(DownloadSession, {
    id: uuid.v4(),
    jobId: fallbackJobId,
    snapshotId: snapshot.id,
    table: snapshot.table,
    chunkSizeBytes: row_download_page_size(),
    chunkCount: downloadChunks.length,
    compressedBytes: snapshot.snapshotBytes,
    encoding: 'rows',
    createdAt: now_iso(),
    updatedAt: now_iso(),
    chunks: downloadChunks
  });
  return session;
}

