    isOnline: false,
    serverConnected: false,
    sqlConnected: false,
    clientVersion: '',
    lastHeartbeat: '',
    selectedTable: null,
    tables: [],
    tableRelationships: [],
    diagnosticRequestId: null,
    diagnosticRequestedAt: null,
    diagnosticRequestedByUserId: null,
    diagnosticLastRequestId: null,
    diagnosticLastUploadedAt: null,
    diagnosticStatus: 'idle',
    diagnosticSummary: '',
    diagnosticPayload: '',
    clientUpdateRequestId: null,
    clientUpdateRequestedAt: null,
    clientUpdateRequestedByUserId: null,
    clientUpdateTargetVersion: null,
    clientUpdateLastRequestId: null,
    clientUpdateLastAcknowledgedAt: null,
    clientUpdateStatus: 'idle',
    clientUpdateMessage: '',
    windowActionRequestId: null,
    windowActionRequestedAt: null,
    windowActionRequestedByUserId: null,
    windowActionName: '',
    windowActionLastRequestId: null,
    windowActionLastAcknowledgedAt: null,
    windowActionStatus: 'idle',
    windowActionMessage: '',
    updatedAt: now_iso()
  });
}

function server_saved_data_reset(resetAgents: bool = true, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (!is_admin_user(current)) {
    return raw_json_error(403, 'permission denied');
  }

  const jobDeletedCount = db.deleteMany(SyncJob, { id: { gte: '' } });
  let agentResetCount = 0;
  if (resetAgents) {
    agentResetCount = reset_all_agent_saved_state();
  }

  return {
    ok: true,
    jobDeletedCount,
    agentResetCount
  };
}

function jobs_upload_chunk_start(jobId: string, uploadId: string, clientName: string = '', table: string = '', rowCount: int = 0, snapshotCreatedAt: string = '', snapshotBytes: int = 0, compressedBytes: int = 0, chunkSizeBytes: int = kSnapshotTransferChunkSizeBytes(), chunkCount: int = 0, encoding: string = kSnapshotTransferEncoding(), token: string? = null): map<json> {
  const job = find_job_by_id(jobId);
  if (job == null) {
    return raw_json_error(404, 'job not found');
  }
  if (!can_access_job(current_user_record(token), job)) {
    return deny_job_access('jobs_upload_chunk_start', token, current_user_record(token), job);
  }
  if (chunkCount < 1 || chunkCount > max_chunk_count()) {
    return raw_json_error(400, 'invalid chunk count');
  }
  let resolvedChunkSize = chunkSizeBytes;
  if (resolvedChunkSize < 1) {
    resolvedChunkSize = kSnapshotTransferChunkSizeBytes();
  }
  let resolvedUploadId = uploadId.trim();
  if (resolvedUploadId.length == 0) {
    resolvedUploadId = uuid.v4();
  }
  let resolvedCreatedAt = snapshotCreatedAt.trim();
  if (resolvedCreatedAt.length == 0) {
    resolvedCreatedAt = now_iso();
  }
  let resolvedTable = job.table;
  if (table.trim().length != 0) {
    resolvedTable = table.trim();
  }
  let resolvedEncoding = encoding.trim();
  if (resolvedEncoding.length == 0) {
    resolvedEncoding = kSnapshotTransferEncoding();
  }
  db.delete(UploadSession, { jobId });
  const session = db.insert(UploadSession, {
    id: uuid.v4(),
    jobId,
    uploadId: resolvedUploadId,
    table: resolvedTable,
    rowCount,
    snapshotCreatedAt: resolvedCreatedAt,
    snapshotBytes,
    compressedBytes,
    chunkSizeBytes: resolvedChunkSize,
    chunkCount,
    encoding: resolvedEncoding,
    createdAt: now_iso(),
    updatedAt: now_iso(),
    chunks: []
  });
  const updated = db.update(SyncJob, { id: jobId }, {
    clientName: job.clientName,
    sourceClientName: job.sourceClientName,
    subscriberClientName: job.subscriberClientName,
    table: job.table,
    direction: job.direction,
    publisherServer: job.publisherServer,
    publisherDatabase: job.publisherDatabase,
    publisherUseWindowsAuth: job.publisherUseWindowsAuth,
    publisherUser: job.publisherUser,
    publisherPassword: job.publisherPassword,
    status: 'uploading',
    progress: 35,
    rowCount,
    snapshotBytes,
    snapshotCreatedAt: resolvedCreatedAt,
    snapshotId: null,
    createdAt: job.createdAt,
    startedAt: job.startedAt,
    completedAt: null,
    message: 'Ready to receive compressed snapshot chunks.',
    error: null,
    clientUserId: job.clientUserId,
    ownerUserId: job.ownerUserId,
    updatedAt: now_iso()
  });
  let nextJob = job;
  if (updated != null) {
    nextJob = updated;
  }
  return raw_json_success({
    job: public_job_payload(nextJob),
    uploadId: session.uploadId,
    chunkSizeBytes: session.chunkSizeBytes,
    chunkCount: session.chunkCount,
    compressedBytes: session.compressedBytes,
    receivedIndexes: []
  });
}

function jobs_multi_writer_upload(jobId: string, batchId: string, clientName: string, table: string, columns: array<string>? = null, keyColumns: array<string>? = null, rows: array<json>? = null, chunkId: string = '', finalChunk: bool = true, changeTrackingVersion: int? = null, token: string? = null, payloadBase64: string? = null, payloadRowCount: int? = null, payloadIsDelta: bool = true): map<json> {
  const current = current_user_record(token);
  const job = find_job_by_id(jobId);
  if (job == null) {
    return raw_json_error(404, 'job not found');
  }
  if (!can_access_job(current, job)) {
    return deny_job_access('jobs_multi_writer_upload', token, current, job);
  }
  if (string.from(job.direction).trim() != 'upload' || string.from(job.batchId).trim() != batchId.trim()) {
    return raw_json_error(409, 'job is not a multi-writer upload');
  }
  const batch = find_sync_batch(batchId);
  if (batch == null || string.from(batch.table).trim() != table.trim()) {
    return raw_json_error(404, 'sync batch not found');
  }
  if (multi_writer_batch_stale(batch)) {
    return raw_json_error(410, 'multi-writer batch expired; start a new sync');
  }
  const normalizedClientName = clientName.trim();
  if (!sync_batch_has_value(batch.expectedClients, normalizedClientName)) {
    return raw_json_error(403, 'client is not part of this sync batch');
  }
  const normalizedChunkId = chunkId.trim();
  if (normalizedChunkId.length == 0) {
    return raw_json_error(400, 'chunkId is required');
  }
  const incomingRows = rows ?? [];
  let incomingRowCount = incomingRows.length;
  if (payloadRowCount != null && payloadRowCount >= 0) {
    incomingRowCount = payloadRowCount;
  }
  if (incomingRowCount > 500) {
    return raw_json_error(413, 'multi-writer chunk is too large');
  }
  const encodedPayload = string.from(payloadBase64 ?? '').trim();
  const hasStoredPayload = encodedPayload.length > 0;
  let incomingBytes = json.stringify(incomingRows).length;
  if (hasStoredPayload) {
    incomingBytes = int.from((encodedPayload.length * 3) / 4);
  }
  if (incomingBytes > 750000) {
    return raw_json_error(413, 'multi-writer chunk exceeds the 750 KB payload limit; retry with smaller chunks');
  }
  const receivedBytes = int.from(batch.receivedBytes ?? 0);
  if (receivedBytes + incomingBytes > 128000000) {
    return raw_json_error(413, 'multi-writer batch exceeds the 128 MB staging limit; split the sync by table or reduce the changed set');
  }
  if (sync_batch_chunk_seen(batch.receivedChunks, normalizedClientName, normalizedChunkId)) {
    return raw_json_success({ job: public_job_payload(job), batchId, duplicate: true, ready: batch.status == 'ready' });
  }

  let resolvedKeyColumns = normalize_key_columns(keyColumns);
  if (batch.keyColumns.length > 0) {
    resolvedKeyColumns = batch.keyColumns.map((value) => string.from(value));
  }
  let resolvedColumns = columns ?? [];
  if (batch.columns.length > 0) {
    resolvedColumns = batch.columns.map((value) => string.from(value));
  }
  const nextOrdinal = batch.revision + 1;
  const receivedChunks = batch.receivedChunks.concat([{
    clientName: normalizedClientName,
    chunkId: normalizedChunkId,
    rowCount: incomingRowCount,
    receivedAt: now_iso()
  }]);
  let uploadedClients = batch.uploadedClients;
  if (finalChunk && !sync_batch_has_value(uploadedClients, normalizedClientName)) {
    uploadedClients = uploadedClients.concat([normalizedClientName]);
  }
  const ready = uploadedClients.length >= batch.expectedClients.length;
  let clientChangeTrackingVersions = batch.clientChangeTrackingVersions ?? [];
  if (finalChunk && changeTrackingVersion != null) {
    clientChangeTrackingVersions = sync_batch_version_values(
      clientChangeTrackingVersions,
      normalizedClientName,
      changeTrackingVersion
    );
  }
  let storageId = '';
  if (hasStoredPayload) {
    const storedPayload = storage.put({
      name: string.concat('multi-writer-', batch.id, '-', normalizedChunkId, '.json'),
      content_base64: encodedPayload,
      content_type: 'application/json'
    });
    storageId = string.from(storedPayload.id ?? '').trim();
    if (storageId.length == 0) {
      return raw_json_error(500, 'could not store multi-writer delta payload');
    }
  }
  let storedRows = incomingRows;
  if (hasStoredPayload) {
    storedRows = [];
  }
  const chunkRecord = db.insert(SnapshotRecord, {
    id: uuid.v4(),
    clientName: 'server-merge',
    subscriberClientName: normalizedClientName,
    table: batch.table,
    rowCount: incomingRowCount,
    checksum: string.concat(normalizedChunkId, '-', string.from(nextOrdinal)),
    snapshotBytes: incomingBytes,
    columns: resolvedColumns,
    rows: storedRows,
    previewRows: [],
    compressedBytes: 0,
    chunkCount: 1,
    encoding: 'json',
    storageId,
    isDelta: payloadIsDelta,
    sourceJobId: batch.id,
    clientUserId: normalizedClientName,
    ownerUserId: batch.ownerUserId,
    createdAt: now_iso()
  });
  if (chunkRecord == null) {
    return raw_json_error(500, 'could not store multi-writer delta chunk');
  }
  const updatedBatch = db.updateMany(SyncBatch, { id: batch.id, revision: batch.revision }, {
    table: batch.table,
    revision: batch.revision + 1,
    ownerUserId: batch.ownerUserId,
    expectedClients: batch.expectedClients,
    uploadedClients,
    receivedChunks,
    receivedBytes: receivedBytes + incomingBytes,
    clientChangeTrackingVersions,
    keyColumns: resolvedKeyColumns,
    columns: resolvedColumns,
    rows: [],
    status: ready ? 'ready' : 'uploading',
    createdAt: batch.createdAt,
    updatedAt: now_iso()
  });
  if (updatedBatch == 0) {
    db.delete(SnapshotRecord, { id: chunkRecord.id });
    if (storageId.length != 0) {
      storage.delete(storageId);
    }
    return raw_json_error(409, 'sync batch changed while uploading; retry this chunk');
  }
  const updatedResult = finalChunk
    ? jobs_complete(job.id, 'completed', 100, string.concat('Uploaded ', string.from(incomingRowCount), ' changed rows for ', table, '.'), incomingRowCount, null, null, null, token)
    : jobs_progress(job.id, 'uploading', 70, string.concat('Uploaded multi-writer chunk for ', table, '.'), incomingRowCount, token);
  const updatedJob = updatedResult.job ?? job;
  // Clients poll their waiting batch download until the barrier is ready.
  let nextJob = job;
  if (updatedJob != null) {
    nextJob = updatedJob;
  }
  return raw_json_success({
    job: public_job_payload(nextJob),
    batchId,
    acceptedRows: incomingRowCount,
    mergedRowCount: incomingRowCount,
    uploadedClients,
    expectedClientCount: batch.expectedClients.length,
    ready,
    clientChangeTrackingVersions
  });
}

function jobs_multi_writer_download(jobId: string, batchId: string, cursor: string? = null, token: string? = null): map<json> {
  const current = current_user_record(token);
  const job = find_job_by_id(jobId);
  if (job == null) {
    return raw_json_error(404, 'job not found');
  }
  if (!can_access_job(current, job)) {
    return deny_job_access('jobs_multi_writer_download', token, current, job);
  }
  const batch = find_sync_batch(batchId);
  if (batch == null || string.from(job.batchId).trim() != batchId.trim()) {
    return raw_json_error(404, 'sync batch not found');
  }
  if (multi_writer_batch_stale(batch)) {
    return raw_json_error(410, 'multi-writer batch expired; start a new sync');
  }
  if (batch.status != 'ready') {
    return raw_json_error(409, 'sync batch is still waiting for client uploads');
  }
  const storedChunkPage = db.page(SnapshotRecord, {
    where: { sourceJobId: batch.id },
    orderBy: [{ field: 'createdAt', dir: 'asc' }, { field: 'id', dir: 'asc' }],
    fields: ['id', 'sourceJobId', 'clientUserId', 'columns', 'rows', 'rowCount', 'snapshotBytes', 'storageId', 'isDelta', 'createdAt'],
    limit: 1,
    cursor
  });
  const storedChunks = storedChunkPage.rows;
  let chunkRows = [];
  let chunkPayloadBase64 = '';
  let chunkIsDelta = true;
  if (batch.receivedChunks.length == 0) {
    chunkIsDelta = false;
    for (const row of batch.rows) {
      chunkRows = chunkRows.concat([row]);
    }
  } else {
    for (const storedChunk of storedChunks) {
      const storedPayloadId = string.from(storedChunk.storageId ?? '').trim();
      if (storedChunk.isDelta != true) {
        chunkIsDelta = false;
      }
      if (storedPayloadId.length != 0) {
        const storedPayload = storage.get(storedPayloadId);
        chunkPayloadBase64 = string.from(storedPayload.content_base64 ?? '').trim();
      } else {
        const storedRows = storedChunk.rows ?? [];
        chunkRows = chunkRows.concat(storedRows);
      }
    }
  }
  let totalRowCount = batch.rows.length;
  for (const receivedChunk of batch.receivedChunks) {
    totalRowCount += int.from(receivedChunk.rowCount ?? 0);
  }
  const nextCursor = storedChunkPage.nextCursor;
  const done = nextCursor == null || string.from(nextCursor).trim().length == 0;
  const snapshot = {
    id: string.concat(batch.id, '-', string.from(job.clientName), '-', string.from(cursor ?? 'first')),
    clientName: 'server-merge',
    subscriberClientName: job.clientName,
    table: batch.table,
    rowCount: chunkRows.length,
    checksum: snapshot_checksum({ batchId, cursor, rows: chunkRows }),
    createdAt: batch.updatedAt,
    snapshotBytes: json.stringify(chunkRows).length,
    compressedBytes: 0,
    chunkCount: 0,
    encoding: 'json',
    sourceJobId: job.id,
    columns: batch.columns,
    keyColumns: batch.keyColumns,
    clientChangeTrackingVersions: batch.clientChangeTrackingVersions,
    rows: chunkRows,
    isDelta: chunkIsDelta,
    totalRowCount,
    done,
    nextCursor
  };
  if (chunkPayloadBase64.length != 0) {
    snapshot.rows = [];
    snapshot.snapshotBytes = int.from(storedChunks[0].snapshotBytes ?? 0);
  }
  return raw_json_success({ snapshot, cursor, nextCursor, totalRowCount, done, payloadBase64: chunkPayloadBase64, isDelta: chunkIsDelta });
}

function jobs_upload_chunk(jobId: string, uploadId: string, chunkIndex: int, chunkData: string, token: string? = null): map<json> {
  log.info('snapshot upload chunk checkpoint', {
    stage: 'auth_lookup_start',
    jobId,
    uploadId,
    chunkIndex,
    chunkDataChars: chunkData.length,
    tokenPresent: token != null && token.trim().length > 0
  });
  const current = current_user_record(token);
  log.info('snapshot upload chunk checkpoint', {
    stage: 'auth_lookup_complete',
    jobId,
    uploadId,
    chunkIndex,
    authenticated: current != null
  });
  const job = find_job_by_id(jobId);
  log.info('snapshot upload chunk checkpoint', {
    stage: 'job_lookup_complete',
    jobId,
    uploadId,
    chunkIndex,
    jobFound: job != null
  });
  if (job == null) {
    return raw_json_error(404, 'job not found');
  }
  if (!can_access_job(current, job)) {
    return deny_job_access('jobs_upload_chunk', token, current, job);
  }
  const session = find_upload_session_for_job(jobId, uploadId);
  log.info('snapshot upload chunk checkpoint', {
    stage: 'session_lookup_complete',
    jobId,
    uploadId,
    chunkIndex,
    sessionFound: session != null
  });
  if (session == null) {
    return raw_json_error(404, 'upload session not found');
  }
  if (chunkIndex < 0 || chunkIndex >= session.chunkCount) {
    return raw_json_error(400, 'chunk index is out of range');
  }
  if (chunkData.trim().length == 0) {
    return raw_json_error(400, 'chunkData is required');
  }

  let nextChunks = [];
  let replaced = false;
  for (const item of session.chunks) {
    if (item.index == chunkIndex) {
      nextChunks = nextChunks.concat([{
        index: chunkIndex,
        data: chunkData,
        bytes: chunkData.length
      }]);
      replaced = true;
    } else {
      nextChunks = nextChunks.concat([item]);
    }
  }
  if (!replaced) {
    nextChunks = nextChunks.concat([{
      index: chunkIndex,
      data: chunkData,
      bytes: chunkData.length
    }]);
  }

  const updatedSession = db.update(UploadSession, { id: session.id }, {
    chunks: nextChunks,
    updatedAt: now_iso()
  });
  log.info('snapshot upload chunk checkpoint', {
    stage: 'session_write_complete',
    jobId,
    uploadId,
    chunkIndex,
    receivedChunkCount: nextChunks.length,
    sessionWriteSucceeded: updatedSession != null
  });
  let nextSession = session;
  if (updatedSession != null) {
    nextSession = updatedSession;
  }
  const received = chunk_indexes(nextSession);
  let progress = 35;
  if (session.chunkCount > 0) {
    const receivedCount = int.from(received.length);
    const estimated = int.from((receivedCount * 50) / session.chunkCount);
    progress = 35 + estimated;
    if (progress < 35) {
      progress = 35;
    }
    if (progress > 85) {
      progress = 85;
    }
  }
  const updatedJob = db.update(SyncJob, { id: jobId }, {
    clientName: job.clientName,
    sourceClientName: job.sourceClientName,
    subscriberClientName: job.subscriberClientName,
    table: job.table,
    direction: job.direction,
    publisherServer: job.publisherServer,
    publisherDatabase: job.publisherDatabase,
    publisherUseWindowsAuth: job.publisherUseWindowsAuth,
    publisherUser: job.publisherUser,
    publisherPassword: job.publisherPassword,
    status: 'uploading',
    progress,
    rowCount: session.rowCount,
    snapshotBytes: session.snapshotBytes,
    snapshotCreatedAt: session.snapshotCreatedAt,
    snapshotId: null,
    createdAt: job.createdAt,
    startedAt: job.startedAt,
    completedAt: null,
    message: string.concat('Received snapshot chunk ', string.from(chunkIndex + 1), '/', string.from(session.chunkCount), '.'),
    error: null,
    clientUserId: job.clientUserId,
    ownerUserId: job.ownerUserId,
    updatedAt: now_iso()
  });
  log.info('snapshot upload chunk checkpoint', {
    stage: 'job_write_complete',
    jobId,
    uploadId,
    chunkIndex,
    progress,
    jobWriteSucceeded: updatedJob != null
  });
  let nextJob = job;
  if (updatedJob != null) {
    nextJob = updatedJob;
  }
  return raw_json_success({
    job: public_job_payload(nextJob),
    uploadId: nextSession.uploadId,
    chunkCount: nextSession.chunkCount,
    receivedIndexes: received
  });
}

function jobs_upload_chunk_complete(jobId: string, uploadId: string, token: string? = null): map<json> {
  const current = current_user_record(token);
  const job = find_job_by_id(jobId);
  if (job == null) {
    return raw_json_error(404, 'job not found');
  }
  if (!can_access_job(current, job)) {
    return deny_job_access('jobs_upload_chunk_complete', token, current, job);
  }
  const session = find_upload_session_by_upload_id(uploadId);
  if (session == null || session.jobId != jobId) {
    return raw_json_error(404, 'upload session not found');
  }
  const received = chunk_indexes(session);
  if (received.length != session.chunkCount) {
    return raw_json_success({
      error: 'upload is missing chunks',
      uploadId: session.uploadId,
      chunkCount: session.chunkCount,
      compressedBytes: session.compressedBytes,
      chunkSizeBytes: session.chunkSizeBytes,
      receivedIndexes: received,
      receivedCount: received.length
    }, 409);
  }

  const targetJob = find_waiting_download_job(job.clientName, job.subscriberClientName, job.table);
  if (targetJob == null) {
    return raw_json_error(409, 'target download job not found');
  }

  const snapshotId = uuid.v4();
  let snapshotCreatedAt = now_iso();
  if (session.snapshotCreatedAt != null) {
    snapshotCreatedAt = session.snapshotCreatedAt;
  }
  const snapshot = db.insert(SnapshotRecord, {
    id: snapshotId,
    clientName: job.clientName,
    subscriberClientName: job.subscriberClientName,
    table: session.table,
    rowCount: session.rowCount,
    checksum: snapshot_checksum({ id: uploadId, sourceJobId: jobId, table: session.table, rowCount: session.rowCount, snapshotBytes: session.snapshotBytes, compressedBytes: session.compressedBytes }),
    createdAt: snapshotCreatedAt,
    snapshotBytes: session.snapshotBytes,
    columns: [],
    rows: [],
    previewRows: [],
    compressedBytes: session.compressedBytes,
    chunkCount: session.chunkCount,
    encoding: session.encoding,
    storageId: '',
    isDelta: false,
    sourceJobId: jobId,
    clientUserId: job.clientUserId,
    ownerUserId: job.ownerUserId
  });

  const existingDownloadSession = find_active_download_session_for_job(targetJob.id, snapshotId);
  if (existingDownloadSession != null) {
    db.delete(DownloadSession, { id: existingDownloadSession.id });
  }
  db.insert(DownloadSession, {
    id: uuid.v4(),
    jobId: targetJob.id,
    snapshotId,
    table: session.table,
    chunkSizeBytes: session.chunkSizeBytes,
    chunkCount: session.chunkCount,
    compressedBytes: session.compressedBytes,
    encoding: session.encoding,
    createdAt: now_iso(),
    updatedAt: now_iso(),
    chunks: session.chunks
  });

  const queuedTarget = db.update(SyncJob, { id: targetJob.id }, {
    clientName: targetJob.clientName,
    sourceClientName: targetJob.sourceClientName,
    subscriberClientName: targetJob.subscriberClientName,
    table: targetJob.table,
    direction: targetJob.direction,
    publisherServer: targetJob.publisherServer,
    publisherDatabase: targetJob.publisherDatabase,
    publisherUseWindowsAuth: targetJob.publisherUseWindowsAuth,
    publisherUser: targetJob.publisherUser,
    publisherPassword: targetJob.publisherPassword,
    status: 'queued',
    progress: 5,
    rowCount: session.rowCount,
    snapshotBytes: session.snapshotBytes,
    snapshotCreatedAt,
    snapshotId,
    createdAt: targetJob.createdAt,
    startedAt: null,
    completedAt: null,
    message: string.concat('Snapshot is ready for download for ', targetJob.table, '.'),
    error: null,
    clientUserId: targetJob.clientUserId,
    ownerUserId: targetJob.ownerUserId,
    updatedAt: now_iso()
  });

  const completed = db.update(SyncJob, { id: jobId }, {
    clientName: job.clientName,
    sourceClientName: job.sourceClientName,
    subscriberClientName: job.subscriberClientName,
    table: job.table,
    direction: job.direction,
    publisherServer: job.publisherServer,
    publisherDatabase: job.publisherDatabase,
    publisherUseWindowsAuth: job.publisherUseWindowsAuth,
    publisherUser: job.publisherUser,
    publisherPassword: job.publisherPassword,
    status: 'completed',
    progress: 100,
    rowCount: session.rowCount,
    snapshotBytes: session.snapshotBytes,
    snapshotCreatedAt,
    snapshotId,
    createdAt: job.createdAt,
    startedAt: job.startedAt,
    completedAt: now_iso(),
    message: string.concat('Uploaded snapshot with ', string.from(session.rowCount), ' rows for ', targetJob.clientName, '.'),
    error: null,
    clientUserId: job.clientUserId,
    ownerUserId: job.ownerUserId,
    updatedAt: now_iso()
  });

  db.delete(UploadSession, { jobId });

  let nextJob = job;
  if (completed != null) {
    nextJob = completed;
  }
  let nextTargetJob = targetJob;
  if (queuedTarget != null) {
    nextTargetJob = queuedTarget;
  }
  return raw_json_success({
    job: public_job_payload(nextJob),
    targetJob: public_job_payload(nextTargetJob),
    snapshot: public_snapshot_payload(snapshot)
  });
}

function jobs_download_snapshot_manifest(jobId: string, token: string? = null): map<json> {
  const current = current_user_record(token);
  const job = find_job_by_id(jobId);
  if (job == null) {
    return raw_json_error(404, 'job not found');
  }
  if (!can_access_job(current, job)) {
    return deny_job_access('jobs_download_snapshot_manifest', token, current, job);
  }
  const snapshot = latest_download_snapshot_for_job(job);
  if (snapshot == null) {
    return raw_json_error(404, 'snapshot not found');
  }
  const session = find_active_download_session_for_job(jobId, snapshot.id);
  if (session == null) {
    return raw_json_error(404, 'download session not found');
  }
  let progress = job.progress;
  if (progress < 30) {
    progress = 30;
  }
  const updated = db.update(SyncJob, { id: jobId }, {
    clientName: job.clientName,
    sourceClientName: job.sourceClientName,
    subscriberClientName: job.subscriberClientName,
    table: job.table,
    direction: job.direction,
    publisherServer: job.publisherServer,
    publisherDatabase: job.publisherDatabase,
    publisherUseWindowsAuth: job.publisherUseWindowsAuth,
    publisherUser: job.publisherUser,
    publisherPassword: job.publisherPassword,
    status: 'downloading',
    progress,
    rowCount: snapshot.rowCount,
    snapshotBytes: snapshot.snapshotBytes,
    snapshotCreatedAt: snapshot.createdAt,
    snapshotId: snapshot.id,
    createdAt: job.createdAt,
    startedAt: job.startedAt,
    completedAt: null,
    message: string.concat('Prepared ', string.from(session.chunkCount), ' snapshot chunks for download.'),
    error: null,
    clientUserId: job.clientUserId,
    ownerUserId: job.ownerUserId,
    updatedAt: now_iso()
  });
  let nextJob = job;
  if (updated != null) {
    nextJob = updated;
  }
  return raw_json_success({
    job: public_job_payload(nextJob),
    snapshot: public_snapshot_payload(snapshot),
    manifest: download_session_payload(session)
  });
}

function jobs_download_snapshot_chunk(jobId: string, chunkIndex: int? = null, token: string? = null): map<json> {
  const current = current_user_record(token);
  const job = find_job_by_id(jobId);
  if (job == null) {
    return raw_json_error(404, 'job not found');
  }
  if (!can_access_job(current, job)) {
    return deny_job_access('jobs_download_snapshot_chunk', token, current, job);
  }
  if (chunkIndex == null) {
    return raw_json_error(400, 'chunkIndex is required');
  }
  const snapshot = latest_download_snapshot_for_job(job);
  if (snapshot == null) {
    return raw_json_error(404, 'snapshot not found');
  }
  const session = find_active_download_session_for_job(jobId, snapshot.id);
  if (session == null) {
    return raw_json_error(404, 'download session not found');
  }
  if (chunkIndex < 0 || chunkIndex >= session.chunkCount) {
    return raw_json_error(400, 'chunk index is out of range');
  }
  const chunkData = chunk_data_for_index(session, chunkIndex);
  if (chunkData.length == 0) {
    return raw_json_error(404, 'chunk not found');
  }
  let progress = 40;
  if (session.chunkCount > 0) {
    progress = 40 + int.from(((chunkIndex + 1) * 35) / session.chunkCount);
  }
  db.update(SyncJob, { id: jobId }, {
    clientName: job.clientName,
    sourceClientName: job.sourceClientName,
    subscriberClientName: job.subscriberClientName,
    table: job.table,
    direction: job.direction,
    publisherServer: job.publisherServer,
    publisherDatabase: job.publisherDatabase,
    publisherUseWindowsAuth: job.publisherUseWindowsAuth,
    publisherUser: job.publisherUser,
    publisherPassword: job.publisherPassword,
    status: 'downloading',
    progress,
    rowCount: snapshot.rowCount,
    snapshotBytes: snapshot.snapshotBytes,
    snapshotCreatedAt: snapshot.createdAt,
    snapshotId: snapshot.id,
    createdAt: job.createdAt,
    startedAt: job.startedAt,
    completedAt: null,
    message: string.concat('Served snapshot chunk ', string.from(chunkIndex + 1), '/', string.from(session.chunkCount), '.'),
    error: null,
    clientUserId: job.clientUserId,
    ownerUserId: job.ownerUserId,
    updatedAt: now_iso()
  });
  return raw_json_success({
    transferId: session.id,
    chunkIndex,
    chunkCount: session.chunkCount,
    chunkData
  });
}

function jobs_create(clientName: string, tables: array<string>, sourceClientName: string = '', token: string? = null): map<json> {
  if (tables.length == 0) {
    return raw_json_error(400, 'tables are required.');
  }
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  let resolvedClientName = clientName;
  if (clientName.trim().length == 0) {
    if (current.username != null) {
      resolvedClientName = current.username;
    }
  }
  const clientUser = find_user_by_identity(resolvedClientName);
  if (clientUser != null && !can_manage_user(current, clientUser)) {
    return raw_json_error(403, 'permission denied');
  }
  let clientUserId = null;
  let ownerId = owner_namespace_for_user(current);
  if (clientUser != null) {
    clientUserId = clientUser.id;
    ownerId = owner_namespace_for_user(clientUser);
  }
  const targetAgent = db.selectOne(Agent, { clientName: resolvedClientName });
  if (targetAgent == null) {
    return raw_json_error(404, 'client not found');
  }
  let resolvedSourceClientName = sourceClientName.trim();
  if (resolvedSourceClientName.length != 0) {
    const sourceAgent = db.selectOne(Agent, { clientName: resolvedSourceClientName });
    if (sourceAgent == null) {
      return raw_json_error(404, 'source client not found');
    }
  }
  const visibleAgents = visible_agent_rows_for(current);
  let createdJobs = [];
  for (const table of tables) {
    let nextSourceClientName = resolvedSourceClientName;
    if (nextSourceClientName.length == 0) {
      nextSourceClientName = preferred_source_client_name_for_agent_table(targetAgent, table, visibleAgents);
    }
    const nextJobs = create_sync_jobs_for_agent(targetAgent, [table], nextSourceClientName);
    if (nextJobs.length > 0) {
      createdJobs = createdJobs.concat(nextJobs);
    }
  }
  return raw_json_success({ jobs: createdJobs.map((job) => public_job_payload(job)) }, 201);
}

function jobs_start(jobId: string, status: string = 'running', progress: int? = null, message: string = 'Started sync.', token: string? = null): map<json> {
  const current = current_user_record(token);
  const job = find_job_by_id(jobId);
  if (job == null) {
    return raw_json_error(404, 'job not found');
  }
  if (!can_access_job(current, job)) {
    return deny_job_access('jobs_start', token, current, job);
  }

  let nextProgress = 5;
  if (progress != null) {
    nextProgress = progress;
  }
  const updated = db.update(SyncJob, { id: jobId }, {
    clientName: job.clientName,
    sourceClientName: job.sourceClientName,
    subscriberClientName: job.subscriberClientName,
    table: job.table,
    direction: job.direction,
    publisherServer: job.publisherServer,
    publisherDatabase: job.publisherDatabase,
    publisherUseWindowsAuth: job.publisherUseWindowsAuth,
    publisherUser: job.publisherUser,
    publisherPassword: job.publisherPassword,
    status,
    progress: nextProgress,
    rowCount: job.rowCount,
    snapshotBytes: job.snapshotBytes,
    snapshotCreatedAt: job.snapshotCreatedAt,
    snapshotId: job.snapshotId,
    createdAt: job.createdAt,
    message,
    startedAt: now_iso(),
    completedAt: null,
    error: null,
    clientUserId: job.clientUserId,
    ownerUserId: job.ownerUserId,
    updatedAt: now_iso()
  });
  let nextJob = job;
  if (updated != null) {
    nextJob = updated;
  }
  return { job: public_job_payload(nextJob) };
}

function jobs_progress(jobId: string, status: string = 'running', progress: int, message: string, rowCount: int, token: string? = null): map<json> {
  const current = current_user_record(token);
  const job = find_job_by_id(jobId);
  if (job == null) {
    return raw_json_error(404, 'job not found');
  }
  if (!can_access_job(current, job)) {
    return deny_job_access('jobs_progress', token, current, job);
  }

  const updated = db.update(SyncJob, { id: jobId }, {
    clientName: job.clientName,
    sourceClientName: job.sourceClientName,
    subscriberClientName: job.subscriberClientName,
    table: job.table,
    status,
    progress,
    message,
    rowCount,
    direction: job.direction,
    publisherServer: job.publisherServer,
    publisherDatabase: job.publisherDatabase,
    publisherUseWindowsAuth: job.publisherUseWindowsAuth,
    publisherUser: job.publisherUser,
    publisherPassword: job.publisherPassword,
    snapshotBytes: job.snapshotBytes,
    snapshotCreatedAt: job.snapshotCreatedAt,
    snapshotId: job.snapshotId,
    createdAt: job.createdAt,
    startedAt: job.startedAt,
    completedAt: null,
    error: null,
    clientUserId: job.clientUserId,
    ownerUserId: job.ownerUserId,
    updatedAt: now_iso()
  });
  let nextJob = job;
  if (updated != null) {
    nextJob = updated;
  }
  return { job: public_job_payload(nextJob) };
}

function jobs_complete(jobId: string, status: string = 'completed', progress: int = 100, message: string = 'Completed sync.', rowCount: int = 0, snapshotId: string? = null, snapshotCreatedAt: string? = null, snapshotBytes: int? = null, token: string? = null): map<json> {
  const job = find_job_by_id(jobId);
  if (job == null) {
    return raw_json_error(404, 'job not found');
  }
  if (!can_access_job(current_user_record(token), job)) {
    return raw_json_error(403, 'permission denied');
  }

  const completedAt = now_iso();
  let nextSnapshotId = job.snapshotId;
  if (snapshotId != null && snapshotId.trim().length != 0) {
    nextSnapshotId = snapshotId.trim();
  }
  let nextSnapshotCreatedAt = job.snapshotCreatedAt;
  if (snapshotCreatedAt != null && snapshotCreatedAt.trim().length != 0) {
    nextSnapshotCreatedAt = snapshotCreatedAt.trim();
  }
  let nextSnapshotBytes = job.snapshotBytes;
  if (snapshotBytes != null && snapshotBytes >= 0) {
    nextSnapshotBytes = snapshotBytes;
  }
  const updated = db.update(SyncJob, { id: jobId }, {
    clientName: job.clientName,
    sourceClientName: job.sourceClientName,
    subscriberClientName: job.subscriberClientName,
    table: job.table,
    direction: job.direction,
    publisherServer: job.publisherServer,
    publisherDatabase: job.publisherDatabase,
    publisherUseWindowsAuth: job.publisherUseWindowsAuth,
    publisherUser: job.publisherUser,
    publisherPassword: job.publisherPassword,
    status,
    progress,
    rowCount,
    snapshotBytes: nextSnapshotBytes,
    snapshotCreatedAt: nextSnapshotCreatedAt,
    snapshotId: nextSnapshotId,
    createdAt: job.createdAt,
    startedAt: job.startedAt,
    completedAt,
    message,
    error: null,
    clientUserId: job.clientUserId,
    ownerUserId: job.ownerUserId,
    updatedAt: completedAt
  });
  let nextJob = job;
  if (updated != null) {
    nextJob = updated;
  }
  return { job: public_job_payload(nextJob) };
}

function jobs_fail(jobId: string, message: string, progress: int? = null, token: string? = null): map<json> {
  const job = find_job_by_id(jobId);
  if (job == null) {
    return raw_json_error(404, 'job not found');
  }
  if (!can_access_job(current_user_record(token), job)) {
    return raw_json_error(403, 'permission denied');
  }
  let nextProgress = job.progress;
  if (progress != null) {
    nextProgress = progress;
  }
  db.delete(UploadSession, { jobId });
  db.delete(DownloadSession, { jobId });
  const completedAt = now_iso();
  const updated = db.update(SyncJob, { id: jobId }, {
    clientName: job.clientName,
    sourceClientName: job.sourceClientName,
    subscriberClientName: job.subscriberClientName,
    table: job.table,
    direction: job.direction,
    publisherServer: job.publisherServer,
    publisherDatabase: job.publisherDatabase,
    publisherUseWindowsAuth: job.publisherUseWindowsAuth,
    publisherUser: job.publisherUser,
    publisherPassword: job.publisherPassword,
    status: 'failed',
    progress: nextProgress,
    rowCount: job.rowCount,
    snapshotBytes: job.snapshotBytes,
    snapshotCreatedAt: job.snapshotCreatedAt,
    snapshotId: job.snapshotId,
    createdAt: job.createdAt,
    startedAt: job.startedAt,
    completedAt,
    error: message,
    message,
    clientUserId: job.clientUserId,
    ownerUserId: job.ownerUserId,
    updatedAt: completedAt
  });
  if (string.from(job.direction).trim() == 'upload') {
    const targetJob = find_waiting_download_job(string.from(job.clientName), string.from(job.subscriberClientName), string.from(job.table));
    if (targetJob != null) {
      db.delete(DownloadSession, { jobId: targetJob.id });
      db.update(SyncJob, { id: targetJob.id }, {
        clientName: targetJob.clientName,
        sourceClientName: targetJob.sourceClientName,
        subscriberClientName: targetJob.subscriberClientName,
        table: targetJob.table,
        direction: targetJob.direction,
        publisherServer: targetJob.publisherServer,
        publisherDatabase: targetJob.publisherDatabase,
        publisherUseWindowsAuth: targetJob.publisherUseWindowsAuth,
        publisherUser: targetJob.publisherUser,
        publisherPassword: targetJob.publisherPassword,
        status: 'failed',
        progress: 100,
        rowCount: targetJob.rowCount,
        snapshotBytes: targetJob.snapshotBytes,
        snapshotCreatedAt: targetJob.snapshotCreatedAt,
        snapshotId: targetJob.snapshotId,
        createdAt: targetJob.createdAt,
        startedAt: targetJob.startedAt,
        completedAt,
        error: string.concat('Source upload failed: ', message),
        message: string.concat('Source upload failed: ', message),
        clientUserId: targetJob.clientUserId,
        ownerUserId: targetJob.ownerUserId,
        updatedAt: completedAt
      });
    }
  }
  let nextJob = job;
  if (updated != null) {
    nextJob = updated;
  }
  return { job: public_job_payload(nextJob) };
}

function jobs_cancel_active(clientNames: array<string>? = null, message: string = 'Cancelled active sync jobs.', token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (!is_admin_user(current) && !is_owner_user(current)) {
    return raw_json_error(403, 'permission denied');
  }

  let targetNames = [];
  if (clientNames != null) {
    for (const clientName of clientNames) {
      const normalized = normalize_user_name(clientName);
      if (normalized.length != 0) {
        targetNames = targetNames.concat([normalized]);
      }
    }
  }
  targetNames = unique_string_values(targetNames);

  let cancelledJobs = [];
  let cancelledJobIds = [];
  let cancelledBatchIds = [];
  const completedAt = now_iso();
  for (const job of visible_job_rows_for(current)) {
    const status = string.from(job.status).trim();
    if (!is_active_job_status(status)) {
      continue;
    }
    const jobClientName = normalize_user_name(job.clientName);
    if (targetNames.length != 0 && !string_array_contains(targetNames, jobClientName)) {
      continue;
    }
    cancelledJobIds = cancelledJobIds.concat([job.id]);
    const batchId = string.from(job.batchId ?? '').trim();
    if (batchId.length != 0 && !string_array_contains(cancelledBatchIds, batchId)) {
      cancelledBatchIds = cancelledBatchIds.concat([batchId]);
    }
    cancelledJobs = cancelledJobs.concat([public_job_payload({
      id: job.id,
      clientName: job.clientName,
      sourceClientName: job.sourceClientName,
      subscriberClientName: job.subscriberClientName,
      table: job.table,
      direction: job.direction,
      publisherServer: job.publisherServer,
      publisherDatabase: job.publisherDatabase,
      publisherUseWindowsAuth: job.publisherUseWindowsAuth,
      status: 'cancelled',
      progress: 100,
      rowCount: job.rowCount,
      snapshotBytes: job.snapshotBytes,
      snapshotCreatedAt: job.snapshotCreatedAt,
      snapshotId: job.snapshotId,
      createdAt: job.createdAt,
      updatedAt: completedAt,
      startedAt: job.startedAt,
      completedAt,
      message,
      error: message,
      clientUserId: job.clientUserId,
      ownerUserId: job.ownerUserId
    })]);
  }

  if (cancelledJobIds.length != 0) {
    db.updateMany(SyncJob, { id: { in: cancelledJobIds } }, {
      status: 'cancelled',
      progress: 100,
      completedAt,
      message,
      error: message,
      updatedAt: completedAt
    });
  }
  if (cancelledBatchIds.length != 0) {
    // Staged rows are disposable relay data. Remove them with the cancelled
    // batches so failed large syncs cannot consume memory on later startups.
    for (const batchId of cancelledBatchIds) {
      cleanup_multi_writer_batch_storage(batchId);
    }
  }

  return {
    ok: true,
    cancelledJobCount: cancelledJobs.length,
    jobs: cancelledJobs
  };
}

function cleanup_multi_writer_batch_storage(batchId: string): int {
  const normalizedBatchId = batchId.trim();
  if (normalizedBatchId.length == 0) {
    return 0;
  }
  const chunks = db.selectMany(SnapshotRecord, {
    where: { sourceJobId: normalizedBatchId },
    orderBy: { field: 'createdAt', dir: 'asc' },
    fields: ['storageId'],
    limit: 1000
  });
  for (const chunk of chunks) {
    const storageId = string.from(chunk.storageId ?? '').trim();
    if (storageId.length != 0) {
      storage.delete(storageId);
    }
  }
  return db.deleteMany(SnapshotRecord, { sourceJobId: normalizedBatchId });
}

function jobs_cleanup_multi_writer_batch(batchId: string, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null || !is_admin_user(current)) {
    return raw_json_error(403, 'permission denied');
  }
  const normalizedBatchId = batchId.trim();
  if (normalizedBatchId.length == 0) {
    return raw_json_error(400, 'batchId is required');
  }
  const deletedCount = cleanup_multi_writer_batch_storage(normalizedBatchId);
  return raw_json_success({ ok: true, batchId: normalizedBatchId, deletedCount });
}
