function reset_all_agent_saved_state(): int {
  return db.updateMany(Agent, { clientName: { gte: '' } }, {
    selectedTable: null,
    tables: [],
    diagnosticRequestId: null,
    diagnosticRequestedAt: null,
    diagnosticRequestedByUserId: null,
    diagnosticLastRequestId: null,
    diagnosticLastUploadedAt: null,
    diagnosticStatus: 'idle',
    diagnosticSummary: '',
    diagnosticPayload: '',
    updatedAt: now_iso()
  });
}

function server_saved_data_reset(resetAgents: bool = true, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (!is_admin_user(current)) {
    return raw_json_error(403, 'permission denied');
  }

  const uploadSessionBatch = upload_session_reset_batch();
  const downloadSessionBatch = download_session_reset_batch();
  const snapshotBatch = snapshot_reset_batch();
  const syncJobBatch = sync_job_reset_batch();
  let agentResetCount = 0;
  if (resetAgents) {
    agentResetCount = reset_all_agent_saved_state();
  }
  const uploadSessionDeletedCount = uploadSessionBatch.deletedCount;
  const downloadSessionDeletedCount = downloadSessionBatch.deletedCount;
  const snapshotDeletedCount = snapshotBatch.deletedCount;
  const jobDeletedCount = syncJobBatch.deletedCount;
  const hasMore = uploadSessionBatch.hasMore == true || downloadSessionBatch.hasMore == true || snapshotBatch.hasMore == true || syncJobBatch.hasMore == true;

  return {
    ok: true,
    uploadSessionDeletedCount,
    downloadSessionDeletedCount,
    snapshotDeletedCount,
    jobDeletedCount,
    agentResetCount,
    hasMore,
    totalDeletedCount: uploadSessionDeletedCount + downloadSessionDeletedCount + snapshotDeletedCount + jobDeletedCount
  };
}

function jobs_create(clientName: string, tables: array<string>, direction: string = 'sync', sourceClientName: string = '', syncMode: string? = null, token: string? = null): map<json> {
  if (tables.length == 0) {
    return raw_json_error(400, 'tables are required.');
  }
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  let resolvedClientName = clientName;
  if (clientName.trim().length == 0) {
    if (current.username != null) {
      resolvedClientName = current.username;
    }
  }
  const clientUser = find_user_by_identity(resolvedClientName);
  if (clientUser != null && !can_manage_user(current, clientUser)) {
    return raw_json_error(403, 'permission denied');
  }
  let clientUserId = null;
  let ownerId = owner_namespace_for_user(current);
  if (clientUser != null) {
    clientUserId = clientUser.id;
    ownerId = owner_namespace_for_user(clientUser);
  }
  const expandedTables = expand_sync_job_tables_for_owner(ownerId, tables);
  if (expandedTables.length == 0) {
    return raw_json_error(400, 'tables are required.');
  }
  const activeTables = active_job_tables_for_client(resolvedClientName);
  let tablesToCreate = [];
  for (const table of expandedTables) {
    let busy = false;
    for (const activeTable of activeTables) {
      if (activeTable == table) {
        busy = true;
      }
    }
    if (!busy) {
      tablesToCreate = tablesToCreate.concat([table]);
    }
  }
  if (tablesToCreate.length == 0) {
    return raw_json_success({ jobs: [] }, 201);
  }
  const createdJobsRaw = tablesToCreate.map((table) => {
    const resolvedMode = normalize_sync_mode(syncMode, true);
    return {
      id: uuid.v4(),
      clientName: resolvedClientName,
      sourceClientName,
      table,
      direction: direction_for_sync_mode(resolvedMode),
      status: 'queued',
      progress: 0,
      rowCount: 0,
      createdAt: now_iso(),
      updatedAt: now_iso(),
      startedAt: null,
      completedAt: null,
      snapshotId: null,
      snapshotCreatedAt: null,
      snapshotBytes: 0,
      message: string.concat('Queued merge sync for ', table, '.'),
      error: null,
      clientUserId,
      ownerUserId: ownerId
    };
  });
  const createdJobs = db.insertMany(SyncJob, createdJobsRaw);
  return raw_json_success({ jobs: createdJobs.map((job) => public_job_payload(job)) }, 201);
}

function snapshots_latest(clientName: string, table: string, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  const clientUser = find_user_by_identity(clientName);
  if (clientUser != null && !can_manage_user(current, clientUser)) {
    return raw_json_error(403, 'permission denied');
  }
  const snapshot = latest_snapshot_for(clientName, table);
  if (snapshot == null) {
    return raw_json_error(404, 'snapshot not found');
  }
  return public_snapshot_detail_payload(snapshot);
}

