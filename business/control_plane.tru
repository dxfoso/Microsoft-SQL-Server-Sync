version 0.3

class User {
  field id: string min=1 max=64
  field username: string min=1 max=128
  field email: string min=0 max=254
  field name: string min=1 max=128
  field role: string min=1 max=32
  field ownerUserId: string? min=0 max=64
  field createdByUserId: string? min=0 max=64
  field password: string min=1 max=256
  field createdAt: datetime
}

class Session {
  field id: string min=1 max=64
  field token: string min=1 max=128
  field userId: string min=1 max=64
  field userUsername: string? min=0 max=128
  field userEmail: string? min=0 max=254
  field userName: string? min=0 max=128
  field userRole: string? min=0 max=32
  field userOwnerUserId: string? min=0 max=64
  field userCreatedByUserId: string? min=0 max=64
  field userCreatedAt: datetime?
  field app: string min=1 max=32
  field createdAt: datetime
  field revokedAt: datetime?
}

class Agent {
  field clientName: string min=1 max=128
  field machineName: string min=0 max=128
  field server: string min=0 max=256
  field database: string min=0 max=256
  field replicationUseWindowsAuth: bool
  field replicationUser: string min=0 max=256
  field replicationPassword: string min=0 max=256
  field isOnline: bool
  field historyLimit: int min=1 max=100
  field autoSyncIntervalMinutes: int min=1 max=1440
  field serverConnected: bool
  field sqlConnected: bool
  field clientVersion: string? min=0 max=32
  field lastHeartbeat: string min=0 max=64
  field selectedTable: string? min=0 max=256
  field tables: array<json>
  field tableRelationships: array<json>
  field diagnosticRequestId: string? min=0 max=64
  field diagnosticRequestedAt: datetime?
  field diagnosticRequestedByUserId: string? min=0 max=64
  field diagnosticLastRequestId: string? min=0 max=64
  field diagnosticLastUploadedAt: datetime?
  field diagnosticStatus: string min=0 max=32
  field diagnosticSummary: string min=0 max=4000
  field diagnosticPayload: string min=0 max=64000
  field clientUpdateRequestId: string? min=0 max=64
  field clientUpdateRequestedAt: datetime?
  field clientUpdateRequestedByUserId: string? min=0 max=64
  field clientUpdateTargetVersion: string? min=0 max=32
  field clientUpdateLastRequestId: string? min=0 max=64
  field clientUpdateLastAcknowledgedAt: datetime?
  field clientUpdateStatus: string min=0 max=32
  field clientUpdateMessage: string min=0 max=4000
  field windowActionRequestId: string? min=0 max=64
  field windowActionRequestedAt: datetime?
  field windowActionRequestedByUserId: string? min=0 max=64
  field windowActionName: string? min=0 max=32
  field windowActionLastRequestId: string? min=0 max=64
  field windowActionLastAcknowledgedAt: datetime?
  field windowActionStatus: string? min=0 max=32
  field windowActionMessage: string? min=0 max=4000
  field clientUserId: string? min=0 max=64
  field ownerUserId: string? min=0 max=64
  field updatedAt: datetime
}

class TableSyncPolicy {
  field ownerUserId: string min=0 max=64
  field database: string? min=0 max=256
  field table: string min=1 max=256
  field enabled: bool
  field syncMode: string min=1 max=32
  field updatedAt: datetime
  field updatedByClientName: string min=0 max=128
}

class SyncJob {
  field id: string min=1 max=64
  field clientName: string min=1 max=128
  field sourceClientName: string min=0 max=128
  field subscriberClientName: string min=0 max=128
  field table: string min=1 max=256
  field direction: string min=1 max=32
  field publisherServer: string min=0 max=256
  field publisherDatabase: string min=0 max=256
  field publisherUseWindowsAuth: bool
  field publisherUser: string min=0 max=256
  field publisherPassword: string min=0 max=256
  field status: string min=1 max=32
  field progress: int min=0 max=100
  field rowCount: int min=0 max=1000000000
  field snapshotBytes: int min=0 max=1000000000
  field snapshotCreatedAt: datetime?
  field snapshotId: string? min=0 max=128
  field createdAt: datetime
  field updatedAt: datetime
  field startedAt: datetime?
  field completedAt: datetime?
  field message: string min=0 max=4000
  field error: string? min=0 max=4000
  field clientUserId: string? min=0 max=64
  field ownerUserId: string? min=0 max=64
  field batchId: string? min=0 max=128
}

class SyncBatch {
  field id: string min=1 max=128
  field table: string min=1 max=256
  field revision: int min=0
  field ownerUserId: string? min=0 max=64
  field expectedClients: array<json>
  field uploadedClients: array<json>
  field receivedChunks: array<json>
  field receivedBytes: int min=0 max=2147483647
  field clientChangeTrackingVersions: array<json>
  field keyColumns: array<json>
  field columns: array<json>
  field rows: array<json>
  field status: string min=1 max=32
  field createdAt: datetime
  field updatedAt: datetime
}

class SnapshotRecord {
  field id: string min=1 max=64
  field clientName: string min=1 max=128
  field subscriberClientName: string min=0 max=128
  field table: string min=1 max=256
  field rowCount: int min=0 max=1000000000
  field checksum: string min=1 max=128
  field createdAt: datetime
  field snapshotBytes: int min=0 max=2147483647
  field columns: array<json>
  field rows: array<json>
  field previewRows: array<json>
  field compressedBytes: int min=0 max=2147483647
  field chunkCount: int min=0 max=10000
  field encoding: string min=1 max=16
  field storageId: string min=0 max=128
  field isDelta: bool
  field sourceJobId: string? min=0 max=64
  field clientUserId: string? min=0 max=64
  field ownerUserId: string? min=0 max=64
}

class UploadSession {
  field id: string min=1 max=64
  field jobId: string min=1 max=64
  field uploadId: string min=1 max=128
  field table: string min=1 max=256
  field rowCount: int min=0 max=1000000000
  field snapshotCreatedAt: datetime
  field snapshotBytes: int min=0 max=2147483647
  field compressedBytes: int min=0 max=2147483647
  field chunkSizeBytes: int min=1 max=1048576
  field chunkCount: int min=1 max=10000
  field encoding: string min=1 max=16
  field createdAt: datetime
  field updatedAt: datetime
  field chunks: array<json>
}

class DownloadSession {
  field id: string min=1 max=64
  field jobId: string min=1 max=64
  field snapshotId: string min=1 max=64
  field table: string min=1 max=256
  field chunkSizeBytes: int min=1 max=1048576
  field chunkCount: int min=1 max=10000
  field compressedBytes: int min=0 max=2147483647
  field encoding: string min=1 max=16
  field createdAt: datetime
  field updatedAt: datetime
  field chunks: array<json>
}

class PeriodicSyncState {
  field ownerUserId: string min=0 max=64
  field lastCheckedAt: datetime
  field manualPendingTables: array<json>?
  field updatedAt: datetime
}

index User_id on User(id)
index User_username on User(username)
index User_email on User(email)
index Session_token on Session(token)
index Session_createdAt on Session(createdAt)
index Session_userId_createdAt on Session(userId, createdAt)
index Agent_clientName on Agent(clientName)
index Agent_ownerUserId on Agent(ownerUserId)
index TableSyncPolicy_ownerUserId_table on TableSyncPolicy(ownerUserId, table)
index TableSyncPolicy_ownerUserId_database_table on TableSyncPolicy(ownerUserId, database, table)
index SyncJob_id on SyncJob(id)
index SyncJob_clientName_createdAt on SyncJob(clientName, createdAt)
index SyncJob_createdAt on SyncJob(createdAt)
index SyncJob_batchId on SyncJob(batchId)
index SyncBatch_id on SyncBatch(id)
index SyncBatch_ownerUserId_table on SyncBatch(ownerUserId, table)
index SnapshotRecord_id on SnapshotRecord(id)
index SnapshotRecord_clientName_table_createdAt on SnapshotRecord(clientName, table, createdAt)
index SnapshotRecord_createdAt on SnapshotRecord(createdAt)
index UploadSession_jobId on UploadSession(jobId)
index UploadSession_uploadId on UploadSession(uploadId)
index DownloadSession_jobId on DownloadSession(jobId)
index DownloadSession_snapshotId on DownloadSession(snapshotId)
index PeriodicSyncState_ownerUserId on PeriodicSyncState(ownerUserId)

function now_iso(): datetime {
  return date.now();
}

function raw_json_error(status: int, message: string): json {
  return response.raw({
    status: status,
    content_type: "application/json",
    body: json.stringify({ error: message })
  });
}

function raw_json_success(payload: map<json>, status: int = 200): json {
  return response.raw({
    status: status,
    content_type: "application/json",
    body: json.stringify(payload)
  });
}

function is_admin_user(user: map<json>): bool {
  return user.role == "admin";
}

function is_owner_user(user: map<json>): bool {
  return user.role == "owner";
}

function is_client_user(user: map<json>): bool {
  return user.role == "client";
}

function can_read_agent(current: map<json>? = null, ownerUserId: string? = null, createdByUserId: string? = null): bool {
  if (current == null) {
    return false;
  }
  if (is_admin_user(current)) {
    return true;
  }
  if (current.id == createdByUserId) {
    return true;
  }
  if (is_owner_user(current) && ownerUserId == current.id) {
    return true;
  }
  return false;
}

function can_manage_user(current: map<json>? = null, target: map<json>? = null): bool {
  if (current == null) {
    return false;
  }
  if (is_admin_user(current)) {
    return true;
  }
  if (target == null) {
    return false;
  }
  if (current.id == target.id) {
    return true;
  }
  if (is_owner_user(current) && target.ownerUserId == current.id) {
    return true;
  }
  return false;
}

function owner_namespace_for_user(user: map<json>): string {
  if (is_owner_user(user)) {
    return user.id;
  }
  if (user.ownerUserId != null && user.ownerUserId.trim().length != 0) {
    return user.ownerUserId;
  }
  return user.id;
}

function can_access_job(current: map<json>? = null, job: map<json>): bool {
  if (current == null) {
    return false;
  }
  if (is_admin_user(current)) {
    return true;
  }
  if (current.id == job.clientUserId) {
    return true;
  }
  if (is_owner_user(current) && job.ownerUserId == current.id) {
    return true;
  }
  return false;
}

function max_chunk_count(): int {
  return 10000;
}

function kSnapshotTransferChunkSizeBytes(): int {
  return 100 * 1024;
}

function kSnapshotTransferEncoding(): string {
  return 'gzip';
}

function is_active_job_status(status: string? = null): bool {
  const normalized = string.from(status ?? '').trim();
  return normalized == 'queued' || normalized == 'waiting' || normalized == 'running' || normalized == 'snapshotting' || normalized == 'uploading' || normalized == 'downloading' || normalized == 'applying';
}

function truncate_text(value: string, maxLength: int): string {
  if (value.length <= maxLength) {
    return value;
  }
  return value.slice(0, maxLength);
}

function sync_job_text(value: string? = null, maxLength: int = 256): string {
  return truncate_text(string.from(value ?? ''), maxLength);
}

function agent_online_timeout_minutes(agent: map<json>): int {
  return 15;
}

function safe_date_diff_minutes_since(rawTimestamp: string? = null): int? {
  const timestamp = string.from(rawTimestamp ?? '').trim();
  if (timestamp.length == 0 || timestamp == '--') {
    return null;
  }
  try {
    return date.diff(date.now(), timestamp, 'min');
  } catch (err) {
    return null;
  }
}

function heartbeat_persist_interval_minutes(): int {
  return 1;
}

function heartbeat_write_due(agent: map<json>): bool {
  const lastHeartbeat = string.from(agent.lastHeartbeat ?? '').trim();
  if (lastHeartbeat.length == 0) {
    return true;
  }
  const elapsedMinutes = safe_date_diff_minutes_since(lastHeartbeat);
  if (elapsedMinutes == null) {
    return true;
  }
  return elapsedMinutes >= heartbeat_persist_interval_minutes();
}

function lightweight_agent_heartbeat_state_changed(agent: map<json>, machineName: string, historyLimit: int, server: string, database: string, replicationUseWindowsAuth: bool, replicationUser: string, replicationPassword: string, serverConnected: bool, sqlConnected: bool, selectedTable: string? = null, clientVersion: string = ''): bool {
  const nextMachineName = machineName.trim().length == 0 ? string.from(agent.clientName ?? '').trim() : machineName;
  const nextSelectedTable = selectedTable == null ? '' : string.from(selectedTable).trim();
  const currentSelectedTable = agent.selectedTable == null ? '' : string.from(agent.selectedTable).trim();
  const currentClientVersion = string.from(agent.clientVersion ?? '').trim();
  if (string.from(agent.machineName ?? '').trim() != nextMachineName) {
    return true;
  }
  if (string.from(agent.server ?? '').trim() != server.trim()) {
    return true;
  }
  if (string.from(agent.database ?? '').trim() != database.trim()) {
    return true;
  }
  if ((agent.replicationUseWindowsAuth == true) != (replicationUseWindowsAuth == true)) {
    return true;
  }
  if (string.from(agent.replicationUser ?? '').trim() != replicationUser.trim()) {
    return true;
  }
  if (string.from(agent.replicationPassword ?? '').trim() != replicationPassword.trim()) {
    return true;
  }
  if (agent.isOnline != true) {
    return true;
  }
  if (int.from(agent.historyLimit ?? 0) != historyLimit) {
    return true;
  }
  if ((agent.serverConnected == true) != (serverConnected == true)) {
    return true;
  }
  if ((agent.sqlConnected == true) != (sqlConnected == true)) {
    return true;
  }
  if (currentSelectedTable != nextSelectedTable) {
    return true;
  }
  if (currentClientVersion != clientVersion.trim()) {
    return true;
  }
  return false;
}

function effective_agent_online(agent: map<json>): bool {
  if (agent.isOnline != true || agent.serverConnected != true || agent.sqlConnected != true) {
    return false;
  }
  const heartbeat = string.from(agent.lastHeartbeat ?? '').trim();
  if (heartbeat.length == 0) {
    return false;
  }
  const ageMinutes = safe_date_diff_minutes_since(heartbeat);
  return ageMinutes != null && ageMinutes <= agent_online_timeout_minutes(agent);
}

// Command delivery only needs a live heartbeat. Database readiness is
// required for sync scheduling, but must not block updates or diagnostics.
function agent_command_delivery_online(agent: map<json>): bool {
  if (agent.isOnline != true) {
    return false;
  }
  const heartbeat = string.from(agent.lastHeartbeat ?? '').trim();
  if (heartbeat.length == 0) {
    return false;
  }
  const ageMinutes = safe_date_diff_minutes_since(heartbeat);
  return ageMinutes != null && ageMinutes <= agent_online_timeout_minutes(agent);
}

function default_admin_username(): string {
  return 'dxfoso@gmail.com';
}

function default_admin_password(): string {
  return 'Admin@123';
}

function normalize_user_name(value: string): string {
  const trimmed = value.trim();
  if (trimmed.length == 0) {
    return string.concat('user-', uuid.v4().slice(0, 8));
  }
  return trimmed.toLowerCase();
}

function clamp_history_limit(value: int? = null): int {
  if (value == null || value < 1) {
    return 5;
  }
  if (value > 100) {
    return 100;
  }
  return value;
}

function clamp_auto_sync_interval(value: int? = null): int {
  if (value == null || value < 1) {
    return 15;
  }
  if (value > 1440) {
    return 1440;
  }
  return value;
}

function kSyncTableKeySeparator(): string {
  return '::';
}

function sync_table_reference(syncTable: string): map<json> {
  const trimmed = syncTable.trim();
  const parts = trimmed.split(kSyncTableKeySeparator());
  if (parts.length != 2) {
    return {
      database: '',
      table: trimmed,
      syncKey: trimmed
    };
  }
  const databaseName = string.from(parts[0]).trim();
  const localTable = string.from(parts[1]).trim();
  if (databaseName.length == 0 || localTable.length == 0) {
    return {
      database: '',
      table: trimmed,
      syncKey: trimmed
    };
  }
  return {
    database: databaseName,
    table: localTable,
    syncKey: string.concat(databaseName, kSyncTableKeySeparator(), localTable)
  };
}

function remote_source_server(agent: map<json>): string {
  const machineName = string.from(agent.machineName ?? '').trim();
  const server = string.from(agent.server ?? '').trim();
  if (server.length == 0 || machineName.length == 0) {
    return server;
  }
  const normalized = server.toLowerCase();
  if (normalized == '.' || normalized == 'localhost' || normalized == '127.0.0.1') {
    return machineName;
  }
  const parts = server.split('\\');
  if (parts.length >= 2) {
    const host = string.from(parts[0]).trim().toLowerCase();
    const instance = string.from(parts[1]).trim();
    if ((host == '.' || host == 'localhost' || host == '127.0.0.1') && instance.length != 0) {
      return string.concat(machineName, '\\', instance);
    }
  }
  return server;
}

function relay_publisher_database(agent: map<json>, table: string): string {
  const tableReference = sync_table_reference(table);
  if (tableReference.database != null && string.from(tableReference.database).trim().length != 0) {
    return string.from(tableReference.database).trim();
  }
  return string.from(agent.database ?? '').trim();
}

function table_sync_policy_database_name(policy: map<json>): string {
  return string.from(policy.database ?? '').trim();
}

function table_sync_policy_local_name(policy: map<json>): string {
  return string.from(policy.table).trim();
}

function table_sync_policy_sync_key(policy: map<json>): string {
  const databaseName = table_sync_policy_database_name(policy);
  const localTable = table_sync_policy_local_name(policy);
  if (databaseName.length == 0 || localTable.length == 0) {
    return localTable;
  }
  return string.concat(databaseName, kSyncTableKeySeparator(), localTable);
}

function table_sync_policy_scope(ownerUserId: string? = null): string {
  if (ownerUserId == null) {
    return '';
  }
  return ownerUserId.trim();
}

function list_table_sync_policies_for_scope(ownerUserId: string? = null): array<json> {
  const rows = db.selectMany(TableSyncPolicy, {
    where: { ownerUserId: table_sync_policy_scope(ownerUserId) },
    orderBy: { field: 'table', dir: 'asc' },
    fields: ['ownerUserId', 'database', 'table', 'enabled', 'updatedAt', 'updatedByClientName'],
    limit: 1000
  });
  if (rows == null) {
    return [];
  }
  return rows;
}

function table_sync_policies_for_database(ownerUserId: string? = null, database: string = ''): array<json> {
  const rows = list_table_sync_policies_for_scope(ownerUserId);
  const trimmedDatabase = database.trim();
  if (trimmedDatabase.length == 0) {
    return rows;
  }
  return rows.filter((row) => table_sync_policy_database_name(row) == trimmedDatabase);
}

function table_sync_policy_payload(policy: map<json>): map<json> {
  return {
    table: table_sync_policy_sync_key(policy),
    enabled: policy.enabled,
    updatedAt: policy.updatedAt,
    updatedByClientName: policy.updatedByClientName
  };
}

function table_sync_policy_payloads_for_database(ownerUserId: string? = null, database: string = ''): array<json> {
  return table_sync_policies_for_database(ownerUserId, database).map((policy) => table_sync_policy_payload(policy));
}

function table_dependency_sync_key(database: string, table: string): string {
  const databaseName = database.trim();
  const localTable = table.trim();
  if (databaseName.length == 0 || localTable.length == 0) {
    return localTable;
  }
  return string.concat(databaseName, kSyncTableKeySeparator(), localTable);
}

function normalized_table_dependency_payload(database: string = '', table: string, relatedTable: string, relationshipType: string = 'business', updatedByClientName: string = ''): map<json>? {
  const databaseName = database.trim();
  const tableRef = sync_table_reference(table);
  const relatedRef = sync_table_reference(relatedTable);
  let resolvedDatabase = databaseName;
  if (resolvedDatabase.length == 0 && string.from(tableRef.database).trim().length != 0) {
    resolvedDatabase = string.from(tableRef.database).trim();
  }
  if (resolvedDatabase.length == 0 && string.from(relatedRef.database).trim().length != 0) {
    resolvedDatabase = string.from(relatedRef.database).trim();
  }
  const tableName = string.from(tableRef.table).trim();
  const relatedTableName = string.from(relatedRef.table).trim();
  if (tableName.length == 0 || relatedTableName.length == 0 || tableName == relatedTableName) {
    return null;
  }
  const normalizedType = relationshipType.trim().length == 0 ? 'business' : relationshipType.trim();
  return {
    table: table_dependency_sync_key(resolvedDatabase, tableName),
    relatedTable: table_dependency_sync_key(resolvedDatabase, relatedTableName),
    relationshipType: normalizedType,
    updatedAt: now_iso(),
    updatedByClientName
  };
}

function bounded_table_relationships(database: string = '', relationships: array<json>? = null, updatedByClientName: string = ''): array<json> {
  if (relationships == null || relationships.length == 0) {
    return [];
  }
  let acceptedCount = 0;
  return relationships.map((relationship) => {
    const tableName = string.from(relationship.table ?? '').trim();
    const relatedTableName = string.from(relationship.relatedTable ?? '').trim();
    const relationshipType = string.from(relationship.relationshipType ?? 'business').trim();
    if (tableName.length == 0 || relatedTableName.length == 0 || tableName == relatedTableName) {
      return null;
    }
    return normalized_table_dependency_payload(
      database,
      tableName,
      relatedTableName,
      relationshipType.length == 0 ? 'business' : relationshipType,
      updatedByClientName
    );
  }).filter((relationship) => {
    if (relationship == null || acceptedCount >= 1000) {
      return false;
    }
    acceptedCount = acceptedCount + 1;
    return true;
  });
}

function table_dependency_payloads_for_database(ownerUserId: string? = null, database: string = ''): array<json> {
  const trimmedDatabase = database.trim();
  const relationshipGroups = list_agent_rows()
      .filter((agent) => agent.ownerUserId == ownerUserId || agent.clientUserId == ownerUserId)
      .map((agent) => table_relationships_for_database(agent.tableRelationships ?? [], trimmedDatabase, 1000));
  return relationshipGroups.reduce(
    (all, relationships) => table_relationships_for_database(all.concat(relationships), '', 1000),
    []
  );
}

function table_relationships_for_database(relationships: array<json>, database: string, maxCount: int): array<json> {
  let acceptedCount = 0;
  return relationships.filter((relationship) => {
    if (acceptedCount >= maxCount) {
      return false;
    }
    const tableRef = sync_table_reference(string.from(relationship.table));
    const relationshipDatabase = string.from(tableRef.database).trim();
    const matches = database.length == 0 || relationshipDatabase == database;
    if (matches) {
      acceptedCount = acceptedCount + 1;
    }
    return matches;
  });
}

function expand_related_table_sync_keys_once(dependencies: array<json>, databaseName: string, visited: array<string>, related: array<string>): map<json> {
  return dependencies.reduce((state, dependency) => {
    const nextVisited = state.visited ?? [];
    const nextRelated = state.related ?? [];
    const dependencyTable = string.from(sync_table_reference(string.from(dependency.table)).table).trim();
    const sourceSeen = nextVisited.filter((source) => string.from(source) == dependencyTable).length > 0;
    if (!sourceSeen) {
      return state;
    }
    const candidate = string.from(sync_table_reference(string.from(dependency.relatedTable)).table).trim();
    if (candidate.length == 0) {
      return state;
    }
    const seen = nextVisited.filter((value) => string.from(value) == candidate).length > 0;
    if (seen) {
      return state;
    }
    return {
      visited: nextVisited.concat([candidate]),
      related: nextRelated.concat([table_dependency_sync_key(databaseName, candidate)])
    };
  }, { visited, related });
}

function related_table_sync_keys_for_policy(ownerUserId: string? = null, syncTable: string): array<string> {
  const scope = table_sync_policy_scope(ownerUserId);
  const reference = sync_table_reference(syncTable);
  const databaseName = string.from(reference.database).trim();
  const rootLocalTable = string.from(reference.table).trim();
  if (rootLocalTable.length == 0) {
    return [];
  }
  const dependencies = table_dependency_payloads_for_database(scope, databaseName);
  let state = {
    visited: [rootLocalTable],
    related: []
  };
  let previousRelatedCount = -1;
  for (const dependency of dependencies) {
    if (state.related.length == previousRelatedCount) {
      return state.related;
    }
    previousRelatedCount = state.related.length;
    state = expand_related_table_sync_keys_once(dependencies, databaseName, state.visited, state.related);
  }
  return state.related;
}

function expand_sync_job_tables_for_owner(ownerUserId: string? = null, tables: array<string>): array<string> {
  const expandedGroups = tables.map((table) => {
    const normalizedTable = string.from(table).trim();
    if (normalizedTable.length == 0) {
      return [];
    }
    const relatedTables = related_table_sync_keys_for_policy(ownerUserId, normalizedTable);
    return [normalizedTable].concat(relatedTables.map((relatedTable) => string.from(relatedTable)));
  });
  return unique_string_values(expandedGroups.reduce((all, group) => all.concat(group), []));
}

function table_sync_policy_for_table(ownerUserId: string? = null, database: string = '', table: string): map<json>? {
  return table_sync_policy_for_table_with_policies(ownerUserId, database, table);
}

function table_sync_policy_for_table_with_policies(ownerUserId: string? = null, database: string = '', table: string, policies: array<json>? = null): map<json>? {
  const scope = table_sync_policy_scope(ownerUserId);
  const reference = sync_table_reference(table);
  let databaseName = database.trim();
  const referenceDatabase = string.from(reference.database).trim();
  if (referenceDatabase.length != 0) {
    databaseName = referenceDatabase;
  }
  const localTable = string.from(reference.table).trim();
  if (localTable.length == 0) {
    return null;
  }
  if (policies != null) {
    for (const policy of policies) {
      if (string.from(policy.ownerUserId ?? '').trim() != scope) {
        continue;
      }
      if (table_sync_policy_local_name(policy) != localTable) {
        continue;
      }
      if (databaseName.length != 0 && table_sync_policy_database_name(policy) != databaseName) {
        continue;
      }
      return policy;
    }
    return null;
  }
  if (databaseName.length != 0) {
    return db.selectOne(TableSyncPolicy, {
      ownerUserId: scope,
      database: databaseName,
      table: localTable
    });
  }
  return db.selectOne(TableSyncPolicy, {
    ownerUserId: scope,
    table: localTable
  });
}

function find_table_sync_policy(ownerUserId: string? = null, syncTable: string): map<json>? {
  const scope = table_sync_policy_scope(ownerUserId);
  const reference = sync_table_reference(syncTable);
  const databaseName = string.from(reference.database).trim();
  const localTable = string.from(reference.table).trim();
  if (databaseName.length != 0 && localTable.length != 0) {
    return db.selectOne(TableSyncPolicy, {
      ownerUserId: scope,
      database: databaseName,
      table: localTable
    });
  }
  if (localTable.length != 0) {
    return db.selectOne(TableSyncPolicy, {
      ownerUserId: scope,
      table: localTable
    });
  }
  return null;
}

function upsert_table_sync_policy(ownerUserId: string? = null, table: string, enabled: bool, updatedByClientName: string = ''): map<json> {
  const scope = table_sync_policy_scope(ownerUserId);
  const reference = sync_table_reference(table);
  const databaseName = string.from(reference.database).trim();
  const localTable = string.from(reference.table).trim();
  let storedDatabase = null;
  if (databaseName.length != 0) {
    storedDatabase = databaseName;
  }
  const existing = find_table_sync_policy(scope, table);
  if (existing != null) {
    if (existing.database != null && string.from(existing.database).trim().length != 0) {
      const updated = db.update(TableSyncPolicy, {
        ownerUserId: scope,
        database: string.from(existing.database).trim(),
        table: string.from(existing.table).trim()
      }, {
        database: storedDatabase,
        table: localTable,
        enabled,
        syncMode: 'sync',
        updatedAt: now_iso(),
        updatedByClientName
      });
      if (updated != null) {
        return updated;
      }
    } else {
      const updated = db.update(TableSyncPolicy, {
        ownerUserId: scope,
        table: string.from(existing.table).trim()
      }, {
        database: storedDatabase,
        table: localTable,
        enabled,
        syncMode: 'sync',
        updatedAt: now_iso(),
        updatedByClientName
      });
      if (updated != null) {
        return updated;
      }
    }
  }
  return db.insert(TableSyncPolicy, {
    ownerUserId: scope,
    database: storedDatabase,
    table: localTable,
    enabled,
    syncMode: 'sync',
    updatedAt: now_iso(),
    updatedByClientName
  });
}

function apply_table_sync_policies(ownerUserId: string? = null, tables: array<json>? = null, database: string = ''): array<json> {
  return apply_table_sync_policies_with_policies(ownerUserId, tables, database);
}

function apply_table_sync_policies_with_policies(ownerUserId: string? = null, tables: array<json>? = null, database: string = '', policies: array<json>? = null): array<json> {
  if (tables == null) {
    return [];
  }
  if (tables.length == 0) {
    return tables;
  }
  return tables.map((tableState) => {
    const policy = table_sync_policy_for_table_with_policies(ownerUserId, database, string.from(tableState.table), policies);
    if (policy == null) {
      return tableState;
    }
    return {
      table: tableState.table,
      enabled: policy.enabled,
      status: tableState.status,
      lastSync: tableState.lastSync,
      progress: tableState.progress,
      rowCount: tableState.rowCount,
      tableChecksum: tableState.tableChecksum,
      message: tableState.message,
      history: tableState.history
    };
  });
}

function agent_table_payload_limit(): int {
  return 150;
}

function heartbeat_table_payload_limit(): int {
  return 60;
}

function bounded_heartbeat_tables(tables: array<json>? = null, selectedTable: string? = null): array<json> {
  if (tables == null) {
    return [];
  }
  let selected = '';
  if (selectedTable != null) {
    selected = string.from(selectedTable).trim();
  }
  const maxNonSelected = selected.length == 0
    ? heartbeat_table_payload_limit()
    : heartbeat_table_payload_limit() - 1;
  let selectedState = null;
  let result = [];
  for (const tableState of tables) {
    if (result.length >= maxNonSelected) {
      break;
    }
    if (tableState.table == null) {
      continue;
    }
    const tableName = string.from(tableState.table).trim();
    if (tableName.length == 0) {
      continue;
    }
    const nextState = {
      table: tableName,
      enabled: tableState.enabled == true,
      status: string.from(tableState.status ?? ''),
      lastSync: string.from(tableState.lastSync ?? ''),
      progress: int.from(tableState.progress ?? 0),
      rowCount: int.from(tableState.rowCount ?? 0),
      tableChecksum: string.from(tableState.tableChecksum ?? ''),
      message: string.from(tableState.message ?? ''),
      history: []
    };
    if (selected.length != 0 && tableName == selected && selectedState == null) {
      selectedState = nextState;
      continue;
    }
    result = result.concat([nextState]);
  }
  if (selectedState != null) {
    return [selectedState].concat(result);
  }
  return result;
}

function json_payload_changed(previousPayload: json, nextPayload: json): bool {
  return json.stringify(previousPayload) != json.stringify(nextPayload);
}

function bounded_agent_tables(tables: array<json>? = null, selectedTable: string? = null): array<json> {
  if (tables == null) {
    return [];
  }
  let selected = '';
  if (selectedTable != null) {
    selected = string.from(selectedTable).trim();
  }
  let result = [];
  if (selected.length != 0) {
    for (const tableState of tables) {
      if (tableState.table == selected && result.length == 0) {
        result = result.concat([tableState]);
      }
    }
  }
  for (const tableState of tables) {
    if (result.length >= agent_table_payload_limit()) {
      break;
    }
    if (tableState.table == selected) {
      continue;
    }
    if (tableState.enabled == true) {
      let seen = false;
      for (const existing of result) {
        if (existing.table == tableState.table) {
          seen = true;
        }
      }
      if (!seen) {
        result = result.concat([tableState]);
      }
    }
  }
  for (const tableState of tables) {
    if (result.length < agent_table_payload_limit() && tableState.table != selected) {
      let seen = false;
      for (const existing of result) {
        if (existing.table == tableState.table) {
          seen = true;
        }
      }
      if (!seen) {
        result = result.concat([tableState]);
      }
    }
  }
  return result;
}

function seed_admin_user(): map<json> {
  const existing = db.selectOne(User, { username: default_admin_username() });
  if (existing != null) {
    return existing;
  }
  return db.insert(User, {
    id: uuid.v4(),
    username: default_admin_username(),
    email: default_admin_username(),
    name: default_admin_username(),
    role: 'admin',
