function jobs_create_all_enabled_legacy(token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (!is_admin_user(current) && !is_owner_user(current)) {
    return raw_json_error(403, 'permission denied');
  }

  let createdJobs = [];
  let queuedClientNames = [];
  let skippedOfflineClients = [];
  let skippedBusyTables = [];
  let skippedSourceResolutionTables = [];

  const visibleAgents = visible_agent_rows_for(current);
  const ownerUserIds = unique_string_values(visibleAgents.map((agent) => string.from(agent.ownerUserId)));
  for (const ownerUserId of ownerUserIds) {
    const ownerAgents = visibleAgents.filter((agent) => string.from(agent.ownerUserId) == ownerUserId);
    const ownerPolicies = list_table_sync_policies_for_scope(ownerUserId);
    const completedJobRows = list_completed_scheduler_job_rows(ownerUserId);
    const tableCaches = ownerAgents.map((agent) => scheduler_agent_table_state_cache(agent, ownerPolicies));
    const activeTableCaches = ownerAgents.map((agent) => ({
      clientName: agent.clientName,
      tables: active_job_tables_for_client(string.from(agent.clientName))
    }));

    for (const agent of ownerAgents) {
      const enabledTables = unique_string_values(
        enabled_sync_tables_for_agent_with_policies(agent, ownerPolicies).concat(
          enabled_sync_policy_tables_for_agent(agent, ownerPolicies)
        )
      );
      if (enabledTables.length == 0) {
        continue;
      }
      const activeCache = scheduler_agent_table_state_cache_for_agent(string.from(agent.clientName), activeTableCaches);
      let activeTables = [];
      if (activeCache != null && activeCache.tables != null) {
        activeTables = activeCache.tables;
      }
      let tablesToQueue = [];
      for (const table of enabledTables) {
        if (string_array_contains(activeTables, table)) {
          skippedBusyTables = skippedBusyTables.concat([string.concat(agent.clientName, '::', table)]);
        } else {
          tablesToQueue = tablesToQueue.concat([table]);
        }
      }
      for (const table of tablesToQueue) {
        const sourceClientName = bulk_source_client_name_for_agent_table(agent, table, ownerAgents, ownerPolicies, completedJobRows);
        if (sourceClientName.length == 0) {
          skippedSourceResolutionTables = skippedSourceResolutionTables.concat([string.concat(agent.clientName, '::', table)]);
          continue;
        }
        const sourceAgent = agent_row_for_client_name(ownerAgents, sourceClientName);
        const clientJobs = create_sync_jobs_for_agent(agent, [table], sourceClientName, activeTableCaches, sourceAgent);
        if (clientJobs.length > 0) {
          createdJobs = createdJobs.concat(clientJobs);
          queuedClientNames = queuedClientNames.concat([string.from(agent.clientName)]);
        }
      }
    }
  }

  return {
    ok: true,
    jobs: createdJobs.map((job) => public_job_payload(job)),
    queuedJobCount: createdJobs.length,
    queuedClientCount: unique_string_values(queuedClientNames).length,
    skippedOfflineClients: unique_string_values(skippedOfflineClients),
    skippedBusyTables: unique_string_values(skippedBusyTables),
    skippedSourceResolutionTables: unique_string_values(skippedSourceResolutionTables)
  };
}

function jobs_create_all_enabled(token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (!is_admin_user(current) && !is_owner_user(current)) {
    return raw_json_error(403, 'permission denied');
  }

  let createdJobs = [];
  let queuedClientNames = [];
  let skippedOfflineClients = [];
  let skippedBusyTables = [];
  let deferredTables = [];
  const visibleAgents = visible_agent_rows_for(current);
  const ownerUserIds = unique_string_values(visibleAgents.map((agent) => string.from(agent.ownerUserId)));
  for (const ownerUserId of ownerUserIds) {
    const ownerAgents = visibleAgents.filter((agent) => string.from(agent.ownerUserId) == ownerUserId);
    let onlineAgents = [];
    for (const agent of ownerAgents) {
      if (effective_agent_online(agent)) {
        onlineAgents = onlineAgents.concat([agent]);
      } else {
        skippedOfflineClients = skippedOfflineClients.concat([string.from(agent.clientName)]);
      }
    }
    if (onlineAgents.length == 0) {
      continue;
    }
    const ownerPolicies = list_table_sync_policies_for_scope(ownerUserId);
    let enabledTables = [];
    for (const agent of onlineAgents) {
      enabledTables = enabledTables.concat(
        enabled_sync_tables_for_agent_with_policies(agent, ownerPolicies).concat(
          enabled_sync_policy_tables_for_agent(agent, ownerPolicies)
        )
      );
    }
    enabledTables = unique_string_values(enabledTables);
    let ownerDeferredTables = [];
    const activeTableCaches = onlineAgents.map((agent) => ({
      clientName: agent.clientName,
      tables: active_job_tables_for_client(string.from(agent.clientName))
    }));
    let ownerHasActiveJobs = false;
    for (const cache of activeTableCaches) {
      if (cache.tables.length > 0) {
        ownerHasActiveJobs = true;
      }
    }
    if (ownerHasActiveJobs) {
      ownerDeferredTables = enabledTables;
      deferredTables = deferredTables.concat(
        enabledTables.map((table) => string.concat(ownerUserId, '::', table))
      );
      set_manual_sync_pending_tables_for_owner(ownerUserId, ownerDeferredTables);
      continue;
    }
    // Keep a manual all-sync bounded while allowing the automatic scheduler
    // to drain the remaining tables without another user click.
    let queuedTablesForOwner = 0;
    for (const table of enabledTables) {
      if (queuedTablesForOwner >= periodic_sync_scheduler_table_limit()) {
        ownerDeferredTables = ownerDeferredTables.concat([table]);
        deferredTables = deferredTables.concat([string.concat(ownerUserId, '::', table)]);
        continue;
      }
      let tableAgents = [];
      for (const agent of onlineAgents) {
        const agentTables = unique_string_values(
          enabled_sync_tables_for_agent_with_policies(agent, ownerPolicies).concat(
            enabled_sync_policy_tables_for_agent(agent, ownerPolicies)
          )
        );
        if (string_array_contains(agentTables, table)) {
          tableAgents = tableAgents.concat([agent]);
        }
      }
      if (tableAgents.length == 0) {
        continue;
      }
      let busy = false;
      for (const agent of tableAgents) {
        if (string_array_contains(
          active_job_tables_from_cache(string.from(agent.clientName), activeTableCaches) ?? [],
          table
        )) {
          busy = true;
          skippedBusyTables = skippedBusyTables.concat([string.concat(agent.clientName, '::', table)]);
        }
      }
      if (busy) {
        continue;
      }
      const jobs = create_multi_writer_batch(ownerUserId, table, tableAgents);
      if (jobs.length > 0) {
        createdJobs = createdJobs.concat(jobs);
        queuedClientNames = queuedClientNames.concat(tableAgents.map((agent) => string.from(agent.clientName)));
        queuedTablesForOwner += 1;
      }
    }
    set_manual_sync_pending_tables_for_owner(ownerUserId, ownerDeferredTables);
  }
  return {
    ok: true,
    mode: 'multi-writer',
    jobs: createdJobs.map((job) => public_job_payload(job)),
    queuedJobCount: createdJobs.length,
    queuedClientCount: unique_string_values(queuedClientNames).length,
    skippedOfflineClients: unique_string_values(skippedOfflineClients),
    skippedBusyTables: unique_string_values(skippedBusyTables),
    skippedSourceResolutionTables: [],
    deferredTables: unique_string_values(deferredTables),
    message: deferredTables.length > 0
      ? 'Sync started for the first eligible table batch; remaining manual tables will drain in bounded scheduler waves.'
      : 'Sync queued for all eligible tables.'
  };
}

