}

function live_state_agent_limit(): int {
  return 100;
}

function live_state_job_limit(): int {
  return 50;
}

function live_state_agent_rows_for(current: map<json>, limit: int): array<json> {
  let where = { clientName: { gte: '' } };
  if (is_client_user(current)) {
    where = { clientUserId: current.id };
  }
  if (is_owner_user(current)) {
    where = { ownerUserId: current.id };
  }
  const rows = db.selectMany(Agent, {
    where,
    orderBy: { field: 'clientName', dir: 'asc' },
    fields: ['clientName', 'machineName', 'server', 'database', 'isOnline', 'historyLimit', 'autoSyncIntervalMinutes', 'serverConnected', 'sqlConnected', 'clientVersion', 'lastHeartbeat', 'selectedTable', 'tables', 'diagnosticRequestId', 'diagnosticRequestedAt', 'diagnosticRequestedByUserId', 'diagnosticLastRequestId', 'diagnosticLastUploadedAt', 'diagnosticStatus', 'diagnosticSummary', 'clientUpdateRequestId', 'clientUpdateRequestedAt', 'clientUpdateRequestedByUserId', 'clientUpdateTargetVersion', 'clientUpdateLastRequestId', 'clientUpdateLastAcknowledgedAt', 'clientUpdateStatus', 'clientUpdateMessage', 'windowActionRequestId', 'windowActionRequestedAt', 'windowActionRequestedByUserId', 'windowActionName', 'windowActionLastRequestId', 'windowActionLastAcknowledgedAt', 'windowActionStatus', 'windowActionMessage', 'clientUserId', 'ownerUserId', 'updatedAt'],
    limit: limit + 1
  });
  if (rows == null) {
    return [];
  }
  return rows;
}

function live_state_job_rows_for(current: map<json>, limit: int): array<json> {
  let where = { createdAt: { lte: now_iso() } };
  if (is_client_user(current)) {
    where = { clientUserId: current.id };
  }
  if (is_owner_user(current)) {
    where = { ownerUserId: current.id };
  }
  const rows = db.selectMany(SyncJob, {
    where,
    orderBy: { field: 'createdAt', dir: 'desc' },
    fields: ['id', 'clientName', 'sourceClientName', 'subscriberClientName', 'table', 'direction', 'publisherServer', 'publisherDatabase', 'publisherUseWindowsAuth', 'status', 'progress', 'rowCount', 'snapshotBytes', 'snapshotCreatedAt', 'snapshotId', 'createdAt', 'updatedAt', 'startedAt', 'completedAt', 'message', 'error', 'clientUserId', 'ownerUserId', 'batchId'],
    limit: limit + 1
  });
  if (rows == null) {
    return [];
  }
  return rows;
}

function bounded_public_agent_payloads(rows: array<json>, limit: int): map<json> {
  let items = [];
  let seen = 0;
  for (const row of rows) {
    seen += 1;
    if (items.length < limit) {
      items = items.concat([public_agent_payload(row)]);
    }
  }
  return {
    items,
    total: seen,
    truncated: seen > items.length
  };
}

function bounded_public_job_payloads(rows: array<json>, limit: int): map<json> {
  let items = [];
  let seen = 0;
  for (const row of rows) {
    seen += 1;
    if (items.length < limit) {
      items = items.concat([public_job_payload(row)]);
    }
  }
  return {
    items,
    total: seen,
    truncated: seen > items.length
  };
}

function ensure_agent(clientName: string, clientUserId: string? = null, ownerUserId: string? = null): map<json> {
  try {
    const existing = db.selectOne(Agent, { clientName });
    if (existing != null) {
      return existing;
    }
  } catch (err) {
    const repaired = db.update(Agent, { clientName }, {
      isOnline: false,
      serverConnected: false,
      sqlConnected: false,
      lastHeartbeat: '',
      selectedTable: null,
      tables: [],
      tableRelationships: [],
      replicationUseWindowsAuth: true,
      replicationUser: '',
      replicationPassword: '',
      diagnosticRequestId: null,
      diagnosticRequestedAt: null,
      diagnosticRequestedByUserId: null,
      diagnosticLastRequestId: null,
      diagnosticLastUploadedAt: null,
      diagnosticStatus: 'idle',
      diagnosticSummary: '',
      diagnosticPayload: '',
      clientUpdateRequestId: null,
      clientUpdateRequestedAt: null,
      clientUpdateRequestedByUserId: null,
      clientUpdateTargetVersion: null,
      clientUpdateLastRequestId: null,
      clientUpdateLastAcknowledgedAt: null,
      clientUpdateStatus: 'idle',
      clientUpdateMessage: '',
      windowActionRequestId: null,
      windowActionRequestedAt: null,
      windowActionRequestedByUserId: null,
      windowActionName: '',
      windowActionLastRequestId: null,
      windowActionLastAcknowledgedAt: null,
      windowActionStatus: 'idle',
      windowActionMessage: '',
      clientVersion: '',
      clientUserId,
      ownerUserId,
      updatedAt: now_iso()
    });
    if (repaired != null) {
      return repaired;
    }
    db.delete(Agent, { clientName });
  }
  return db.insert(Agent, {
    clientName,
    machineName: clientName,
    server: '',
    database: '',
    replicationUseWindowsAuth: true,
    replicationUser: '',
    replicationPassword: '',
    isOnline: false,
    historyLimit: 5,
    autoSyncIntervalMinutes: 15,
    serverConnected: false,
    sqlConnected: false,
    clientVersion: '',
    lastHeartbeat: '',
    selectedTable: null,
    tables: [],
    tableRelationships: [],
    diagnosticRequestId: null,
    diagnosticRequestedAt: null,
    diagnosticRequestedByUserId: null,
    diagnosticLastRequestId: null,
    diagnosticLastUploadedAt: null,
    diagnosticStatus: 'idle',
    diagnosticSummary: '',
    diagnosticPayload: '',
    clientUpdateRequestId: null,
    clientUpdateRequestedAt: null,
    clientUpdateRequestedByUserId: null,
    clientUpdateTargetVersion: null,
    clientUpdateLastRequestId: null,
    clientUpdateLastAcknowledgedAt: null,
    clientUpdateStatus: 'idle',
    clientUpdateMessage: '',
    windowActionRequestId: null,
    windowActionRequestedAt: null,
    windowActionRequestedByUserId: null,
    windowActionName: '',
    windowActionLastRequestId: null,
    windowActionLastAcknowledgedAt: null,
    windowActionStatus: 'idle',
    windowActionMessage: '',
    clientUserId,
    ownerUserId,
    updatedAt: now_iso()
  });
}

function sync_settings_payload(agent: map<json>): map<json> {
  return {
    historyLimit: agent.historyLimit,
    autoSyncIntervalMinutes: agent.autoSyncIntervalMinutes
  };
}

function active_jobs_for_client(clientName: string): array<json> {
  const rows = db.selectMany(SyncJob, {
    where: { clientName },
    orderBy: { field: 'updatedAt', dir: 'desc' },
    fields: ['id', 'clientName', 'sourceClientName', 'subscriberClientName', 'table', 'direction', 'publisherServer', 'publisherDatabase', 'publisherUseWindowsAuth', 'publisherUser', 'publisherPassword', 'status', 'progress', 'rowCount', 'snapshotBytes', 'snapshotCreatedAt', 'snapshotId', 'createdAt', 'updatedAt', 'startedAt', 'completedAt', 'message', 'error', 'clientUserId', 'ownerUserId', 'batchId'],
    limit: 1000
  });
  if (rows == null) {
    return [];
  }
  const readyMultiWriterBatches = db.selectMany(SyncBatch, {
    where: { status: 'ready' },
    orderBy: { field: 'updatedAt', dir: 'desc' },
    fields: ['id'],
    limit: 1000
  }).map((batch) => string.from(batch.id));
  let jobs = [];
  let seenJobKeys = [];
  for (const job of rows) {
    const batchId = string.from(job.batchId ?? '').trim();
    const direction = string.from(job.direction).trim();
    const jobKey = batchId.length == 0
      ? string.from(job.table)
      : string.concat(string.from(job.table), '::', batchId, '::', direction);
    let jobSeen = false;
    for (const seenJobKey of seenJobKeys) {
      if (seenJobKey == jobKey) {
        jobSeen = true;
      }
    }
    if (jobSeen) {
      continue;
    }

    const status = string.from(job.status).trim();
    let multiWriterDownloadReady = true;
    if (batchId.length != 0 && direction == 'download') {
      multiWriterDownloadReady = string_array_contains(readyMultiWriterBatches, batchId);
      if (!multiWriterDownloadReady) {
        continue;
      }
    }
    const isWaitingMultiWriterDownload = status == 'waiting'
      && direction == 'download'
      && batchId.length != 0
      && multiWriterDownloadReady;
    if (is_active_job_status(status) || isWaitingMultiWriterDownload) {
      jobs = jobs.concat([agent_job_payload(job)]);
      seenJobKeys = seenJobKeys.concat([jobKey]);
    }
  }
  return jobs;
}

function unique_string_values(values: array<string>): array<string> {
  let unique = [];
  for (const value of values) {
    let seen = false;
    for (const existing of unique) {
      if (existing == value) {
        seen = true;
      }
    }
    if (!seen) {
      unique = unique.concat([value]);
    }
  }
  return unique;
}

function active_job_tables_for_client(clientName: string): array<string> {
  const jobs = active_jobs_for_client(clientName);
  let tables = [];
  for (const job of jobs) {
    if (string.from(job.batchId ?? '').trim().length != 0) {
      const batch = find_sync_batch(string.from(job.batchId));
      if (batch != null && multi_writer_batch_stale(batch)) {
        continue;
      }
    }
    tables = tables.concat([string.from(job.table)]);
  }
  return unique_string_values(tables);
}

function agent_row_for_client_name(agents: array<json>, clientName: string): map<json>? {
  for (const agent of agents) {
    if (string.from(agent.clientName) == clientName) {
      return agent;
    }
  }
  return null;
}

function active_job_tables_from_cache(clientName: string, activeTableCaches: array<json>? = null): array<string>? {
  if (activeTableCaches == null) {
    return null;
  }
  const cache = scheduler_agent_table_state_cache_for_agent(clientName, activeTableCaches);
  if (cache == null || cache.tables == null) {
    return [];
  }
  return cache.tables;
}

function active_job_for_client_table(clientName: string, table: string): map<json>? {
  const rows = db.selectMany(SyncJob, {
    where: { clientName, table },
    orderBy: { field: 'updatedAt', dir: 'desc' },
    fields: ['id', 'clientName', 'sourceClientName', 'subscriberClientName', 'table', 'direction', 'status', 'progress', 'rowCount', 'updatedAt', 'completedAt', 'message', 'error'],
    limit: 10
  });
  if (rows == null) {
    return null;
  }
  for (const job of rows) {
    const status = string.from(job.status).trim();
    if (is_active_job_status(status)) {
      return job;
    }
    // Keep scanning older rows. A completed upload can be newer than the
    // active download belonging to the same multi-writer table.
  }
  return null;
}

function normalize_agent_table_payload_state(agent: map<json>, tableState: map<json>): map<json> {
  if (tableState.table == null) {
    return tableState;
  }
  const table = string.from(tableState.table).trim();
  if (table.length == 0) {
    return tableState;
  }
  const activeJob = active_job_for_client_table(string.from(agent.clientName), table);
  if (activeJob != null) {
    return {
      table: tableState.table,
      enabled: tableState.enabled,
      status: activeJob.status,
      lastSync: activeJob.updatedAt,
      progress: activeJob.progress,
      rowCount: activeJob.rowCount,
      tableChecksum: tableState.tableChecksum,
      message: activeJob.message,
      history: tableState.history
    };
  }

  const status = string.from(tableState.status ?? '').trim().toLowerCase();
  if (tableState.enabled == true
    && (status == 'queued' || status == 'waiting' || status == 'running' || status == 'uploading' || status == 'downloading')) {
    return {
      table: tableState.table,
      enabled: tableState.enabled,
      status: 'Completed',
      lastSync: tableState.lastSync,
      progress: 100,
      rowCount: tableState.rowCount,
      tableChecksum: tableState.tableChecksum,
      message: 'Up to date.',
      history: tableState.history
    };
  }
  return tableState;
}

function normalize_agent_tables_payload(agent: map<json>, tables: array<json>): array<json> {
  let normalized = [];
  for (const tableState of tables) {
    normalized = normalized.concat([normalize_agent_table_payload_state(agent, tableState)]);
  }
  return normalized;
}

function enabled_sync_tables_for_agent(agent: map<json>): array<string> {
  return enabled_sync_tables_for_agent_with_policies(agent);
}

function enabled_sync_tables_for_agent_with_policies(agent: map<json>, policies: array<json>? = null): array<string> {
  let enabledTables = [];
  let tables = [];
  if (agent.tables != null) {
    tables = apply_table_sync_policies_with_policies(
      agent.ownerUserId,
      agent.tables,
      string.from(agent.database),
      policies
    );
  }
  for (const tableState of tables) {
    if (tableState.enabled == true && tableState.table != null) {
      enabledTables = enabledTables.concat([string.from(tableState.table)]);
    }
  }
  return unique_string_values(enabledTables);
}

function scheduler_agent_table_states(agent: map<json>, policies: array<json>? = null): array<json> {
  if (agent.tables == null) {
    return [];
  }
  return apply_table_sync_policies_with_policies(
    agent.ownerUserId,
    agent.tables,
    string.from(agent.database),
    policies
  );
}

function scheduler_agent_table_state(agentTables: array<json>, table: string): map<json>? {
  for (const tableState of agentTables) {
    if (tableState.table == null) {
      continue;
    }
    if (string.from(tableState.table).trim() == table) {
      return tableState;
    }
  }
  return null;
}

function scheduler_agent_table_state_cache(agent: map<json>, policies: array<json>? = null): map<json> {
  return {
    clientName: agent.clientName,
    tables: scheduler_agent_table_states(agent, policies)
  };
}

function scheduler_agent_table_state_cache_for_agent(clientName: string, caches: array<json>): map<json>? {
  for (const cache of caches) {
    if (cache.clientName == clientName) {
      return cache;
    }
  }
  return null;
}

function enabled_sync_policy_tables_for_agent(agent: map<json>, policies: array<json>? = null): array<string> {
  let enabledTables = [];
  let sourcePolicies = policies;
  if (sourcePolicies == null) {
    sourcePolicies = list_table_sync_policies_for_scope(agent.ownerUserId);
  }
  for (const policy of sourcePolicies ?? []) {
    if (policy.enabled == true) {
      const table = table_sync_policy_sync_key(policy);
      if (table.trim().length != 0) {
        enabledTables = enabledTables.concat([table]);
      }
    }
  }
  return unique_string_values(enabledTables);
}

function sync_table_state_due_for_interval(tableState: map<json>? = null, intervalMinutes: int? = null): bool {
  const interval = clamp_auto_sync_interval(intervalMinutes);
  if (tableState == null || tableState.lastSync == null) {
    return true;
  }
  const lastSync = string.from(tableState.lastSync).trim();
  if (lastSync.length == 0 || lastSync == '--') {
    return true;
  }
  const elapsedMinutes = safe_date_diff_minutes_since(lastSync);
  if (elapsedMinutes == null) {
    return true;
  }
  return elapsedMinutes >= interval;
}

function sync_table_state_due_age_minutes(tableState: map<json>? = null, intervalMinutes: int? = null): int? {
  const interval = clamp_auto_sync_interval(intervalMinutes);
  if (tableState == null || tableState.lastSync == null) {
    return 2147483647;
  }
  const lastSync = string.from(tableState.lastSync).trim();
  if (lastSync.length == 0 || lastSync == '--') {
    return 2147483647;
  }
  const elapsedMinutes = safe_date_diff_minutes_since(lastSync);
  if (elapsedMinutes == null) {
    return 2147483647;
  }
  if (elapsedMinutes < interval) {
    return null;
  }
  return elapsedMinutes;
}

function due_periodic_sync_tables_for_agent(agent: map<json>): array<string> {
  return due_periodic_sync_tables_for_agent_with_policies(agent);
}

function due_periodic_sync_tables_for_agent_with_policies(agent: map<json>, policies: array<json>? = null, tableCache: map<json>? = null, maxCount: int? = null): array<string> {
  const enabledTables = unique_string_values(enabled_sync_tables_for_agent_with_policies(agent, policies).concat(enabled_sync_policy_tables_for_agent(agent, policies)));
  let cachedTables = scheduler_agent_table_states(agent, policies);
  if (tableCache != null && tableCache.tables != null) {
    cachedTables = tableCache.tables;
  }
  let dueTableLimit = 0;
  if (maxCount != null && maxCount > 0) {
    dueTableLimit = maxCount;
  }
  let dueCandidates = [];
  for (const table of enabledTables) {
    const ageMinutes = sync_table_state_due_age_minutes(
      scheduler_agent_table_state(cachedTables, table),
      agent.autoSyncIntervalMinutes
    );
    if (ageMinutes != null) {
      dueCandidates = dueCandidates.concat([{ table, ageMinutes }]);
    }
  }

  // Pick the oldest due tables first so a bounded scheduler wave cannot
  // repeatedly select the first configured tables and starve later ones.
  let dueTables = [];
  for (const ignored of dueCandidates) {
    if (dueTableLimit > 0 && dueTables.length >= dueTableLimit) {
      break;
    }
    let selectedTable = '';
    let selectedAgeMinutes = -1;
    for (const candidate of dueCandidates) {
      const candidateTable = string.from(candidate.table);
      if (string_array_contains(dueTables, candidateTable)) {
        continue;
      }
      if (candidate.ageMinutes > selectedAgeMinutes) {
        selectedTable = candidateTable;
        selectedAgeMinutes = candidate.ageMinutes;
      }
    }
    if (selectedTable.length != 0) {
      dueTables = dueTables.concat([selectedTable]);
    }
  }
  return dueTables;
}

function sync_peer_agents_for_agent(agent: map<json>, allAgents: array<json>? = null): array<json> {
  const sourceAgents = allAgents ?? list_scheduler_agent_rows();
  let peers = [];
  for (const candidate of sourceAgents) {
    if (candidate.ownerUserId == agent.ownerUserId) {
      peers = peers.concat([candidate]);
    }
  }
  return peers;
}

function queue_due_periodic_sync_jobs_for_agent(agent: map<json>, allAgents: array<json>? = null, ownerPolicies: array<json>? = null, allTableCaches: array<json>? = null, completedJobRows: array<json>? = null): array<json> {
  const peerAgents = sync_peer_agents_for_agent(agent, allAgents);
  const tableCache = scheduler_agent_table_state_cache_for_agent(string.from(agent.clientName), allTableCaches ?? []);
  const dueTables = due_periodic_sync_tables_for_agent_with_policies(agent, ownerPolicies, tableCache, periodic_sync_scheduler_table_limit());
  if (dueTables.length == 0) {
    return [];
  }
  let createdJobs = [];
  let queuedTableCount = 0;
  for (const table of dueTables) {
    if (queuedTableCount >= periodic_sync_scheduler_table_limit()) {
      break;
    }
    const sourceClientName = preferred_source_client_name_for_agent_table(agent, table, peerAgents, ownerPolicies, allTableCaches, completedJobRows);
    if (sourceClientName.length == 0) {
      continue;
    }
    const clientJobs = create_sync_jobs_for_agent(agent, [table], sourceClientName);
    if (clientJobs.length > 0) {
      createdJobs = createdJobs.concat(clientJobs);
      queuedTableCount += 1;
    }
  }
  return createdJobs;
}

function queue_due_periodic_sync_jobs_for_owner(ownerUserId: string? = null, allAgents: array<json>? = null): array<json> {
  const sourceAgents = allAgents ?? list_scheduler_agent_rows();
  const ownerPolicies = list_table_sync_policies_for_scope(ownerUserId);
  let ownerAgents = [];
  for (const agent of sourceAgents) {
    if (agent.ownerUserId == ownerUserId &&
        agent_recent_enough_for_periodic_sync(agent) &&
        effective_agent_online(agent)) {
      ownerAgents = ownerAgents.concat([agent]);
    }
  }
  if (ownerAgents.length == 0) {
    return [];
  }

  // Clients execute table jobs sequentially. Do not refill this owner's queue
  // until the current bounded group has fully crossed upload and download.
  const activeTableCaches = ownerAgents.map((agent) => ({
    clientName: agent.clientName,
    tables: active_job_tables_for_client(string.from(agent.clientName))
  }));
  for (const cache of activeTableCaches) {
    if (cache.tables.length > 0) {
      return [];
    }
  }

  // Periodic sync uses the same multi-writer barrier as manual Sync All:
  // every online client uploads first, then every client downloads the merge.
  const tableCaches = ownerAgents.map((agent) => scheduler_agent_table_state_cache(agent, ownerPolicies));
  const manualPendingTables = manual_sync_pending_tables_for_owner(ownerUserId);
  let dueTables = manualPendingTables;
  for (const agent of ownerAgents) {
    const cache = scheduler_agent_table_state_cache_for_agent(string.from(agent.clientName), tableCaches);
    const agentTables = due_periodic_sync_tables_for_agent_with_policies(
      agent,
      ownerPolicies,
      cache,
      periodic_sync_scheduler_table_limit()
    );
    dueTables = unique_string_values(dueTables.concat(agentTables));
  }

  let createdJobs = [];
  let queuedTables = [];
  let queuedTableCount = 0;
  for (const table of dueTables) {
    if (queuedTableCount >= periodic_sync_scheduler_table_limit()) {
      break;
    }
    let tableAgents = [];
    for (const agent of ownerAgents) {
      const enabledTables = unique_string_values(
        enabled_sync_tables_for_agent_with_policies(agent, ownerPolicies).concat(
          enabled_sync_policy_tables_for_agent(agent, ownerPolicies)
        )
      );
      if (string_array_contains(enabledTables, table) &&
          !string_array_contains(
            active_job_tables_from_cache(string.from(agent.clientName), activeTableCaches) ?? [],
            table
          )) {
        tableAgents = tableAgents.concat([agent]);
      }
    }
    if (tableAgents.length == 0) {
      continue;
    }
    const jobs = create_multi_writer_batch(ownerUserId, table, tableAgents);
    if (jobs.length > 0) {
      createdJobs = createdJobs.concat(jobs);
      queuedTables = queuedTables.concat([table]);
      queuedTableCount += 1;
    }
  }
  if (manualPendingTables.length > 0) {
    let remainingManualTables = [];
    for (const table of manualPendingTables) {
      if (string_array_contains(queuedTables, table)) {
        continue;
      }
      let stillEnabled = false;
      for (const agent of ownerAgents) {
        const enabledTables = unique_string_values(
          enabled_sync_tables_for_agent_with_policies(agent, ownerPolicies).concat(
            enabled_sync_policy_tables_for_agent(agent, ownerPolicies)
          )
        );
        if (string_array_contains(enabledTables, table)) {
          stillEnabled = true;
        }
      }
      if (stillEnabled) {
        remainingManualTables = remainingManualTables.concat([table]);
      }
    }
    set_manual_sync_pending_tables_for_owner(ownerUserId, remainingManualTables);
  }
  return createdJobs;
}

function periodic_sync_scheduler_agent_limit(): int {
  return 4;
}

function periodic_sync_scheduler_owner_limit(): int {
  return 2;
}

function periodic_sync_scheduler_table_limit(): int {
  return 4;
}

function periodic_sync_recent_agent_window_minutes(): int {
  return 180;
}

function periodic_sync_scheduler_cooldown_minutes(): int {
  return 1;
}

function agent_recent_enough_for_periodic_sync(agent: map<json>): bool {
  if (agent.lastHeartbeat == null) {
    return false;
  }
  const lastHeartbeat = string.from(agent.lastHeartbeat).trim();
  if (lastHeartbeat.length == 0) {
    return false;
  }
  const ageMinutes = safe_date_diff_minutes_since(lastHeartbeat);
  return ageMinutes != null && ageMinutes <= periodic_sync_recent_agent_window_minutes();
}

function claim_periodic_sync_scheduler_for_owner(ownerUserId: string? = null, bypassCooldown: bool? = false): bool {
  const normalizedOwnerUserId = string.from(ownerUserId).trim();
  const existing = db.selectOne(PeriodicSyncState, { ownerUserId: normalizedOwnerUserId });
  if (existing != null) {
    const elapsedMinutes = safe_date_diff_minutes_since(string.from(existing.lastCheckedAt ?? ''));
    if (!bool.from(bypassCooldown) &&
        elapsedMinutes != null &&
        elapsedMinutes < periodic_sync_scheduler_cooldown_minutes()) {
      return false;
    }
    db.update(PeriodicSyncState, { ownerUserId: normalizedOwnerUserId }, {
      lastCheckedAt: now_iso(),
      updatedAt: now_iso()
    });
    return true;
  }
  db.insert(PeriodicSyncState, {
    ownerUserId: normalizedOwnerUserId,
    lastCheckedAt: now_iso(),
    updatedAt: now_iso()
  });
  return true;
}

function manual_sync_pending_tables_for_owner(ownerUserId: string? = null): array<string> {
  const normalizedOwnerUserId = string.from(ownerUserId).trim();
  const existing = db.selectOne(PeriodicSyncState, { ownerUserId: normalizedOwnerUserId });
  if (existing == null || existing.manualPendingTables == null) {
    return [];
  }
  let tables = [];
  for (const value of existing.manualPendingTables) {
    const table = string.from(value).trim();
    if (table.length != 0) {
      tables = tables.concat([table]);
    }
  }
  return unique_string_values(tables);
}

function set_manual_sync_pending_tables_for_owner(ownerUserId: string? = null, tables: array<string>? = null): void {
  const normalizedOwnerUserId = string.from(ownerUserId).trim();
  const pendingTables = unique_string_values(tables ?? []);
  const existing = db.selectOne(PeriodicSyncState, { ownerUserId: normalizedOwnerUserId });
  if (existing != null) {
    db.update(PeriodicSyncState, { ownerUserId: normalizedOwnerUserId }, {
      manualPendingTables: pendingTables,
      updatedAt: now_iso()
    });
    return;
  }
  db.insert(PeriodicSyncState, {
    ownerUserId: normalizedOwnerUserId,
    lastCheckedAt: now_iso(),
    manualPendingTables: pendingTables,
    updatedAt: now_iso()
  });
}

function list_completed_scheduler_job_rows(ownerUserId: string? = null): array<json> {
  const rows = db.selectMany(SyncJob, {
    where: {
      ownerUserId: table_sync_policy_scope(ownerUserId),
      status: 'completed'
    },
    orderBy: { field: 'updatedAt', dir: 'desc' },
    fields: ['clientName', 'sourceClientName', 'subscriberClientName', 'table', 'direction', 'rowCount'],
    limit: 500
  });
  if (rows == null) {
    return [];
  }
  return rows;
}

function latest_completed_upload_row_count_for_source_from_rows(rows: array<json>, clientName: string, table: string): int {
  for (const row of rows) {
    if (row.clientName != clientName
      || row.sourceClientName != clientName
      || row.table != table
      || row.direction != 'upload') {
      continue;
    }
    if (row.rowCount != null) {
      const rowCount = int.from(row.rowCount);
      if (rowCount >= 0) {
        return rowCount;
      }
    }
  }
  return -1;
}

function latest_completed_upload_row_count_for_source(clientName: string, table: string, completedJobRows: array<json>? = null): int {
  if (completedJobRows != null) {
    return latest_completed_upload_row_count_for_source_from_rows(completedJobRows, clientName, table);
  }
  const rows = db.selectMany(SyncJob, {
    where: {
      clientName,
      sourceClientName: clientName,
      table,
      direction: 'upload',
      status: 'completed'
    },
    orderBy: { field: 'updatedAt', dir: 'desc' },
    fields: ['rowCount'],
    limit: 20
  });
  if (rows == null) {
    return -1;
  }
  for (const row of rows) {
    if (row.rowCount != null) {
      const rowCount = int.from(row.rowCount);
      if (rowCount >= 0) {
        return rowCount;
      }
    }
  }
  return -1;
}

function latest_completed_source_for_target_table_from_rows(rows: array<json>, targetClientName: string, table: string): string {
  for (const row of rows) {
    if (row.subscriberClientName != targetClientName || row.table != table) {
      continue;
    }
    if (row.sourceClientName != null) {
      const sourceClientName = string.from(row.sourceClientName).trim();
      if (sourceClientName.length != 0 && sourceClientName != targetClientName) {
        return sourceClientName;
      }
    }
  }
  return '';
}

function latest_completed_source_for_target_table(targetClientName: string, table: string, completedJobRows: array<json>? = null): string {
  if (completedJobRows != null) {
    return latest_completed_source_for_target_table_from_rows(completedJobRows, targetClientName, table);
  }
  const rows = db.selectMany(SyncJob, {
    where: {
      subscriberClientName: targetClientName,
      table,
      status: 'completed'
    },
    orderBy: { field: 'updatedAt', dir: 'desc' },
    fields: ['sourceClientName'],
    limit: 20
  });
  if (rows == null) {
    return '';
  }
  for (const row of rows) {
    if (row.sourceClientName != null) {
      const sourceClientName = string.from(row.sourceClientName).trim();
      if (sourceClientName.length != 0 && sourceClientName != targetClientName) {
        return sourceClientName;
      }
    }
  }
  return '';
}

function agent_sync_table_state(agent: map<json>, table: string, policies: array<json>? = null, tableCache: map<json>? = null): map<json>? {
  let cachedTables = scheduler_agent_table_states(agent, policies);
  if (tableCache != null && tableCache.tables != null) {
    cachedTables = tableCache.tables;
  }
  return scheduler_agent_table_state(cachedTables, table);
}

function live_row_count_for_agent_table(agent: map<json>, table: string, policies: array<json>? = null, tableCache: map<json>? = null, completedJobRows: array<json>? = null): int {
  const tableState = agent_sync_table_state(agent, table, policies, tableCache);
  if (tableState != null && tableState.rowCount != null) {
    const rowCount = int.from(tableState.rowCount);
    if (rowCount >= 0) {
      return rowCount;
    }
  }
  return latest_completed_upload_row_count_for_source(string.from(agent.clientName), table, completedJobRows);
}

function live_checksum_for_agent_table(agent: map<json>, table: string, policies: array<json>? = null, tableCache: map<json>? = null): string {
  const tableState = agent_sync_table_state(agent, table, policies, tableCache);
  if (tableState != null && tableState.tableChecksum != null) {
    return string.from(tableState.tableChecksum).trim();
  }
  return '';
}

function agent_table_sync_enabled(agent: map<json>, table: string, policies: array<json>? = null, tableCache: map<json>? = null): bool {
  const tableState = agent_sync_table_state(agent, table, policies, tableCache);
  if (tableState == null) {
    return false;
  }
  return tableState.enabled == true;
}

function preferred_source_client_name_for_agent_table(targetAgent: map<json>, table: string, visibleAgents: array<json>, ownerPolicies: array<json>? = null, allTableCaches: array<json>? = null, completedJobRows: array<json>? = null): string {
  const targetClientName = string.from(targetAgent.clientName);
  const targetTableCache = scheduler_agent_table_state_cache_for_agent(targetClientName, allTableCaches ?? []);
  const targetRowCount = live_row_count_for_agent_table(targetAgent, table, ownerPolicies, targetTableCache, completedJobRows);
  const targetChecksum = live_checksum_for_agent_table(targetAgent, table, ownerPolicies, targetTableCache);
  let bestKnownSource = '';
  let bestKnownRowCount = targetRowCount;
  let bestChecksumSource = '';
  let firstAvailableSource = '';
  for (const candidate of visibleAgents) {
    if (candidate.clientName == targetClientName
      || candidate.ownerUserId != targetAgent.ownerUserId
      ) {
      continue;
    }
    const candidateTableCache = scheduler_agent_table_state_cache_for_agent(string.from(candidate.clientName), allTableCaches ?? []);
    if (!agent_table_sync_enabled(candidate, table, ownerPolicies, candidateTableCache)) {
      continue;
    }
    if (firstAvailableSource.length == 0) {
      firstAvailableSource = string.from(candidate.clientName);
    }
    const candidateRowCount = live_row_count_for_agent_table(candidate, table, ownerPolicies, candidateTableCache, completedJobRows);
    if (candidateRowCount < 0) {
      continue;
    }
    if (bestKnownSource.length == 0 || candidateRowCount > bestKnownRowCount) {
      bestKnownSource = string.from(candidate.clientName);
      bestKnownRowCount = candidateRowCount;
    }
    const candidateChecksum = live_checksum_for_agent_table(candidate, table, ownerPolicies, candidateTableCache);
    if (candidateRowCount == targetRowCount
      && targetChecksum.length != 0
      && candidateChecksum.length != 0
      && candidateChecksum != targetChecksum
      && string.from(candidate.clientName) > targetClientName
      && (bestChecksumSource.length == 0 || string.from(candidate.clientName) > bestChecksumSource)) {
      bestChecksumSource = string.from(candidate.clientName);
    }
  }
  if (bestKnownSource.length != 0) {
    if (targetRowCount < 0 || bestKnownRowCount > targetRowCount) {
      return bestKnownSource;
    }
    if (bestChecksumSource.length != 0) {
      return bestChecksumSource;
    }
    return '';
  }
  const rememberedSource = latest_completed_source_for_target_table(string.from(targetAgent.clientName), table, completedJobRows);
  if (rememberedSource.length != 0) {
    for (const candidate of visibleAgents) {
      const candidateTableCache = scheduler_agent_table_state_cache_for_agent(string.from(candidate.clientName), allTableCaches ?? []);
      if (candidate.clientName == rememberedSource
        && candidate.clientName != targetAgent.clientName
        && candidate.ownerUserId == targetAgent.ownerUserId
        && agent_table_sync_enabled(candidate, table, ownerPolicies, candidateTableCache)) {
        return rememberedSource;
      }
    }
  }
  if (targetRowCount < 0) {
    return firstAvailableSource;
  }
  return '';
}

function bulk_source_client_name_for_agent_table(targetAgent: map<json>, table: string, visibleAgents: array<json>, ownerPolicies: array<json>? = null, completedJobRows: array<json>? = null): string {
  const rememberedSource = latest_completed_source_for_target_table(string.from(targetAgent.clientName), table, completedJobRows);
  if (rememberedSource.length != 0) {
    for (const candidate of visibleAgents) {
      if (string.from(candidate.clientName) == rememberedSource
        && string.from(candidate.clientName) != string.from(targetAgent.clientName)
        && candidate.ownerUserId == targetAgent.ownerUserId
        && agent_table_sync_enabled(candidate, table, ownerPolicies)) {
        return rememberedSource;
      }
    }
  }
  for (const candidate of visibleAgents) {
    if (string.from(candidate.clientName) == string.from(targetAgent.clientName)
      || candidate.ownerUserId != targetAgent.ownerUserId
      || !agent_table_sync_enabled(candidate, table, ownerPolicies)) {
      continue;
    }
    return string.from(candidate.clientName);
  }
  return '';
}

function build_snapshot_relay_job_rows(sourceAgent: map<json>, targetClientName: string, targetClientUserId: string? = null, targetOwnerUserId: string? = null, tables: array<string>): array<json> {
  let rows = [];
  for (const table of tables) {
    rows = rows.concat([{
      id: uuid.v4(),
      clientName: sourceAgent.clientName,
      sourceClientName: sourceAgent.clientName,
      subscriberClientName: targetClientName,
      table,
      direction: 'upload',
      publisherServer: sync_job_text(sourceAgent.server),
      publisherDatabase: sync_job_text(relay_publisher_database(sourceAgent, table)),
      publisherUseWindowsAuth: sourceAgent.replicationUseWindowsAuth == true,
      publisherUser: sync_job_text(sourceAgent.replicationUser),
      publisherPassword: sync_job_text(sourceAgent.replicationPassword),
      status: 'queued',
      progress: 0,
      rowCount: 0,
      snapshotBytes: 0,
      snapshotCreatedAt: null,
      snapshotId: null,
      createdAt: now_iso(),
      updatedAt: now_iso(),
      startedAt: null,
      completedAt: null,
      message: string.concat('Queued sync for ', table, '.'),
      error: null,
      clientUserId: sourceAgent.clientUserId,
      ownerUserId: sourceAgent.ownerUserId
    }, {
      id: uuid.v4(),
      clientName: targetClientName,
      sourceClientName: sourceAgent.clientName,
      subscriberClientName: targetClientName,
      table,
      direction: 'download',
      publisherServer: sync_job_text(remote_source_server(sourceAgent)),
      publisherDatabase: sync_job_text(relay_publisher_database(sourceAgent, table)),
      publisherUseWindowsAuth: sourceAgent.replicationUseWindowsAuth == true,
      publisherUser: sync_job_text(sourceAgent.replicationUser),
      publisherPassword: sync_job_text(sourceAgent.replicationPassword),
      status: 'waiting',
      progress: 0,
      rowCount: 0,
      snapshotBytes: 0,
      snapshotCreatedAt: null,
      snapshotId: null,
      createdAt: now_iso(),
      updatedAt: now_iso(),
      startedAt: null,
      completedAt: null,
      message: string.concat('Waiting for source snapshot upload for ', table, '.'),
      error: null,
      clientUserId: targetClientUserId,
      ownerUserId: targetOwnerUserId
    }]);
  }
  return rows;
}

function create_sync_jobs_for_agent(agent: map<json>, tables: array<string>, sourceClientName: string = '', activeTableCaches: array<json>? = null, sourceAgentOverride: map<json>? = null): array<json> {
  if (tables.length == 0) {
    return [];
  }
  let sourceAgent = null;
  const resolvedSourceClientName = sourceClientName.trim();
  if (resolvedSourceClientName.length != 0 && resolvedSourceClientName != agent.clientName) {
    sourceAgent = sourceAgentOverride;
    if (sourceAgent == null || string.from(sourceAgent.clientName) != resolvedSourceClientName) {
      sourceAgent = db.selectOne(Agent, { clientName: resolvedSourceClientName });
    }
    if (sourceAgent == null) {
      return [];
    }
  }
  let activeTables = active_job_tables_from_cache(string.from(agent.clientName), activeTableCaches);
  if (activeTables == null) {
    activeTables = active_job_tables_for_client(agent.clientName);
  }
  let sourceActiveTables = [];
  if (sourceAgent != null) {
    sourceActiveTables = active_job_tables_from_cache(string.from(sourceAgent.clientName), activeTableCaches);
    if (sourceActiveTables == null) {
      sourceActiveTables = active_job_tables_for_client(sourceAgent.clientName);
    }
  }
  const expandedTables = expand_sync_job_tables_for_owner(agent.ownerUserId, tables);
  let tablesToCreate = [];
  for (const table of expandedTables) {
    let busy = false;
    for (const activeTable of activeTables) {
      if (activeTable == table) {
        busy = true;
      }
    }
    for (const sourceActiveTable of sourceActiveTables) {
      if (sourceActiveTable == table) {
        busy = true;
      }
    }
    if (!busy) {
      tablesToCreate = tablesToCreate.concat([table]);
    }
  }
  if (tablesToCreate.length == 0) {
    return [];
  }
  if (sourceAgent == null) {
    return [];
  }
  const rows = build_snapshot_relay_job_rows(
    sourceAgent,
    agent.clientName,
    agent.clientUserId,
    agent.ownerUserId,
    tablesToCreate
  );
  return db.insertMany(SyncJob, rows);
}

function row_key(row: map<json>, keyColumns: array<string>): string {
  if (keyColumns.length == 0) {
    return json.stringify(row);
  }
  let values = [];
  for (const column of keyColumns) {
    values = values.concat([row[column]]);
  }
  return json.stringify(values);
}

function string_array_contains(values: array<string>, target: string): bool {
  for (const value of values) {
    if (value == target) {
      return true;
    }
  }
  return false;
}

function merge_rows_by_key(existingRows: array<json>, incomingRows: array<json>, keyColumns: array<string>): array<json> {
  if (incomingRows.length == 0) {
    return existingRows;
  }
  if (existingRows.length == 0) {
    return incomingRows;
  }

  let incomingKeys = [];
  for (const incoming of incomingRows) {
    incomingKeys = incomingKeys.concat([row_key(incoming, keyColumns)]);
  }

  let retained = [];
  for (const current of existingRows) {
    if (!string_array_contains(incomingKeys, row_key(current, keyColumns))) {
      retained = retained.concat([current]);
    }
  }
  return retained.concat(incomingRows);
}


function normalize_key_columns(keyColumns: array<string>? = null): array<string> {
  if (keyColumns == null) {
    return [];
  }
  return keyColumns;
}

function find_sync_batch(batchId: string? = null): map<json>? {
  if (batchId == null || batchId.trim().length == 0) {
    return null;
  }
  return db.selectOne(SyncBatch, { id: batchId.trim() });
}

function sync_batch_has_value(values: array<json>, target: string): bool {
  for (const value of values) {
    if (string.from(value).trim() == target) {
      return true;
    }
  }
  return false;
}

function sync_batch_chunk_seen(values: array<json>, clientName: string, chunkId: string): bool {
  for (const value of values) {
    if (string.from(value.clientName).trim() == clientName && string.from(value.chunkId).trim() == chunkId) {
      return true;
    }
  }
  return false;
}

function sync_batch_version_values(values: array<json>, clientName: string, trackingVersion: int): array<json> {
  let next = [];
  let replaced = false;
  for (const value of values) {
    if (string.from(value.clientName).trim() == clientName) {
      next = next.concat([{ clientName, changeTrackingVersion: trackingVersion }]);
      replaced = true;
    } else {
      next = next.concat([value]);
    }
  }
  if (!replaced) {
    next = next.concat([{ clientName, changeTrackingVersion: trackingVersion }]);
  }
  return next;
}

function multi_writer_job_rows(batchId: string, table: string, agents: array<json>, ownerUserId: string): array<json> {
  let rows = [];
  const createdAt = now_iso();
  for (const agent of agents) {
    const clientName = string.from(agent.clientName);
    rows = rows.concat([{
      id: uuid.v4(),
      clientName,
      sourceClientName: '',
      subscriberClientName: '',
      table,
      direction: 'upload',
      publisherServer: sync_job_text(agent.server),
      publisherDatabase: sync_job_text(agent.database),
      publisherUseWindowsAuth: agent.replicationUseWindowsAuth == true,
      publisherUser: sync_job_text(agent.replicationUser),
      publisherPassword: sync_job_text(agent.replicationPassword),
      status: 'queued',
      progress: 0,
      rowCount: 0,
      snapshotBytes: 0,
      snapshotCreatedAt: null,
      snapshotId: null,
      createdAt,
      updatedAt: createdAt,
      startedAt: null,
      completedAt: null,
      message: string.concat('Queued multi-writer upload for ', table, '.'),
      error: null,
      clientUserId: agent.clientUserId,
      ownerUserId,
      batchId
    }, {
      id: uuid.v4(),
      clientName,
      sourceClientName: 'server-merge',
      subscriberClientName: clientName,
      table,
      direction: 'download',
      publisherServer: '',
      publisherDatabase: sync_job_text(agent.database),
      publisherUseWindowsAuth: agent.replicationUseWindowsAuth == true,
      publisherUser: '',
      publisherPassword: '',
      status: 'waiting',
      progress: 0,
      rowCount: 0,
      snapshotBytes: 0,
      snapshotCreatedAt: null,
      snapshotId: null,
      createdAt,
      updatedAt: createdAt,
      startedAt: null,
      completedAt: null,
      message: string.concat('Waiting for all client uploads for ', table, '.'),
      error: null,
      clientUserId: agent.clientUserId,
      ownerUserId,
      batchId
    }]);
  }
  return rows;
}

function create_multi_writer_batch(ownerUserId: string, table: string, agents: array<json>): array<json> {
  if (agents.length == 0) {
    return [];
  }
  const batchId = uuid.v4();
  const clientNames = agents.map((agent) => string.from(agent.clientName));
  const createdAt = now_iso();
  db.insert(SyncBatch, {
    id: batchId,
    table,
    revision: 0,
    ownerUserId,
    expectedClients: clientNames,
    uploadedClients: [],
    receivedChunks: [],
    receivedBytes: 0,
    clientChangeTrackingVersions: [],
    keyColumns: [],
    columns: [],
    rows: [],
    status: 'uploading',
    createdAt,
    updatedAt: createdAt
  });
  return db.insertMany(SyncJob, multi_writer_job_rows(batchId, table, agents, ownerUserId));
}

function multi_writer_batch_stale(batch: map<json>): bool {
  const ageMinutes = safe_date_diff_minutes_since(string.from(batch.createdAt));
  return ageMinutes != null && ageMinutes >= 30;
}

function auth_login(name: string, password: string, app: string = 'web'): map<json> {
  const normalizedName = normalize_user_name(name);
  let user = null;
  if (normalizedName == default_admin_username()) {
    user = seed_admin_user();
  } else {
    user = find_user_by_identity(name);
  }
  if (user == null) {
    return raw_json_error(401, 'user not found');
  }
  if (user.password != password) {
    return raw_json_error(401, 'invalid password');
  }
  return create_session_for_user(user, app);
}

function auth_me(token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'not authenticated');
  }
  return { user: public_user_payload(current) };
}

function auth_logout(token: string? = null): map<json> {
  if (token == null || token.trim().length == 0) {
    return raw_json_error(401, 'not authenticated');
  }
  const session = db.update(Session, { token }, { revokedAt: now_iso() });
  if (session == null) {
    return raw_json_error(401, 'not authenticated');
  }
  return { ok: true };
}

function users_list(token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (!is_admin_user(current) && !is_owner_user(current)) {
    return raw_json_error(403, 'permission denied');
  }
  const users = visible_user_rows_for(current).map((user) => public_user_payload(user));
  return { users };
}

function users_create(name: string, email: string = '', password: string, role: string, ownerUserId: string? = null, token: string? = null): map<json> {
  const normalized = normalize_user_name(name);
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }

  let resolvedRole = role;
  let resolvedOwnerUserId = ownerUserId;
  if (is_owner_user(current)) {
    if (role != 'client') {
      return raw_json_error(403, 'owners can create client accounts only');
    }
    resolvedRole = 'client';
    resolvedOwnerUserId = current.id;
  } else if (is_admin_user(current)) {
    if (role != 'owner' && role != 'client') {
      return raw_json_error(403, 'admins can create owner or client accounts only');
    }
    if (role == 'client') {
      const owner = find_user_by_id(ownerUserId);
      if (owner == null || !is_owner_user(owner)) {
        return raw_json_error(400, 'client accounts must belong to a valid owner');
      }
      resolvedOwnerUserId = owner.id;
    } else {
      resolvedOwnerUserId = null;
    }
  } else {
    return raw_json_error(403, 'permission denied');
  }

  const existing = find_user_by_identity(normalized);
  if (existing != null) {
    if (!can_manage_user(current, existing)) {
      return raw_json_error(409, 'an account with that name already exists');
    }
    return raw_json_success({ user: public_user_payload(existing), existed: true }, 200);
  }

  const user = db.insert(User, {
    id: uuid.v4(),
    username: normalized,
    email,
    name: normalized,
    role: resolvedRole,
    ownerUserId: resolvedOwnerUserId,
    createdByUserId: current.id,
    password,
    createdAt: now_iso()
  });
  return raw_json_success({ user: public_user_payload(user) }, 201);
}

function user_reset_password(userId: string, password: string, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  const target = find_user_by_id(userId);
  if (!can_manage_user(current, target)) {
    return raw_json_error(403, 'permission denied');
  }
  const user = db.update(User, { id: userId }, { password });
  if (user == null) {
    return raw_json_error(404, 'user not found');
  }
  return { ok: true };
}

function user_delete(userId: string, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  const target = find_user_by_id(userId);
  if (target == null) {
    return raw_json_error(404, 'user not found');
  }
  if (!can_manage_user(current, target)) {
    return raw_json_error(403, 'permission denied');
  }
  if (!is_client_user(target)) {
    return raw_json_error(403, 'only client accounts can be deleted');
  }

  db.updateMany(Session, { userId }, { revokedAt: now_iso() });
  db.delete(Agent, { clientName: target.username });
  const deleted = db.delete(User, { id: userId });
  if (deleted == 0) {
    return raw_json_error(404, 'user not found');
  }
  return { ok: true, user: public_user_payload(target) };
}

function live_state(token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  const agentLimit = live_state_agent_limit();
  const jobLimit = live_state_job_limit();
  const agentPage = bounded_public_agent_payloads(
    live_state_agent_rows_for(current, agentLimit),
    agentLimit
  );
  const jobPage = bounded_public_job_payloads(
    live_state_job_rows_for(current, jobLimit),
    jobLimit
  );
  return {
    generatedAt: now_iso(),
    agents: agentPage.items,
    jobs: jobPage.items,
    limits: {
      agents: agentLimit,
      jobs: jobLimit
    },
    totals: {
      agents: agentPage.total,
      jobs: jobPage.total
    },
    truncated: {
      agents: agentPage.truncated,
      jobs: jobPage.truncated
    }
  };
}

function agents_heartbeat(clientName: string? = null, machineName: string = '', historyLimit: int? = null, autoSyncIntervalMinutes: int? = null, server: string = '', database: string = '', replicationUseWindowsAuth: bool = true, replicationUser: string = '', replicationPassword: string = '', serverConnected: bool = false, sqlConnected: bool = false, selectedTable: string? = null, tables: array<json>? = null, tableRelationships: array<json>? = null, clientVersion: string = '', token: string? = null): map<json> {
  let resolvedClientName = '';
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (clientName == null || clientName.trim().length == 0) {
    if (current.username == null) {
      resolvedClientName = normalize_user_name(current.name);
    } else {
      resolvedClientName = current.username;
    }
  } else {
    resolvedClientName = normalize_user_name(clientName);
  }
  const clientUser = find_user_by_identity(resolvedClientName);
  if (clientUser != null && !can_manage_user(current, clientUser)) {
    return raw_json_error(403, 'permission denied');
  }
  let userId = null;
  let ownerUserId = owner_namespace_for_user(current);
  userId = current.id;
  const agent = ensure_agent(
    resolvedClientName,
    userId,
    ownerUserId
  );
  let nextTables = agent.tables;
  if (tables != null) {
    nextTables = tables;
  }
  const nextTableRelationships = bounded_table_relationships(database, tableRelationships, resolvedClientName);
  nextTables = bounded_heartbeat_tables(nextTables, selectedTable);
  const tablesChanged = json_payload_changed(agent.tables, nextTables);
  const relationshipsChanged = json_payload_changed(agent.tableRelationships, nextTableRelationships);
  const nextMachineName = machineName.trim().length == 0 ? resolvedClientName : machineName;
  const nextHistoryLimit = clamp_history_limit(historyLimit);
  const nextClientVersion = truncate_text(clientVersion.trim(), 32);
  const lightweightHeartbeatChanged = lightweight_agent_heartbeat_state_changed(
    agent,
    nextMachineName,
    nextHistoryLimit,
    server,
    database,
    replicationUseWindowsAuth,
    replicationUser,
    replicationPassword,
    serverConnected,
    sqlConnected,
    selectedTable,
    nextClientVersion
  );
  let updated = null;
  if (tablesChanged || relationshipsChanged) {
    updated = db.update(Agent, { clientName: resolvedClientName }, {
      machineName: nextMachineName,
      server,
      database,
      replicationUseWindowsAuth,
      replicationUser,
      replicationPassword,
      isOnline: true,
      historyLimit: nextHistoryLimit,
      autoSyncIntervalMinutes: clamp_auto_sync_interval(agent.autoSyncIntervalMinutes),
      serverConnected,
      sqlConnected,
      clientVersion: nextClientVersion,
      lastHeartbeat: now_iso(),
      selectedTable,
      tables: nextTables,
      tableRelationships: nextTableRelationships,
      updatedAt: now_iso()
    });
  } else if (lightweightHeartbeatChanged || heartbeat_write_due(agent)) {
    updated = db.update(Agent, { clientName: resolvedClientName }, {
      machineName: nextMachineName,
      server,
      database,
      replicationUseWindowsAuth,
      replicationUser,
      replicationPassword,
      isOnline: true,
      historyLimit: nextHistoryLimit,
      autoSyncIntervalMinutes: clamp_auto_sync_interval(agent.autoSyncIntervalMinutes),
      serverConnected,
      sqlConnected,
      clientVersion: nextClientVersion,
      lastHeartbeat: now_iso(),
      selectedTable,
      updatedAt: now_iso()
    });
  }
  let nextAgent = agent;
  if (updated != null) {
    nextAgent = updated;
  }
  if (nextAgent == null) {
    return raw_json_error(500, 'agent heartbeat state unavailable');
  }
  return {
    ok: true,
    syncSettings: sync_settings_payload(nextAgent),
    tablePolicies: table_sync_policy_payloads_for_database(ownerUserId, database),
    tableDependencies: table_dependency_payloads_for_database(ownerUserId, database),
    jobs: active_jobs_for_client(resolvedClientName),
    diagnostics: agent_diagnostics_payload(nextAgent),
    clientUpdate: agent_client_update_payload(nextAgent),
    windowAction: agent_window_action_payload(nextAgent)
  };
}

function auto_sync_tick(token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (is_client_user(current)) {
    return raw_json_error(403, 'permission denied');
  }

  const allAgents = list_scheduler_agent_rows();
  let ownerIds = [];
  if (is_owner_user(current)) {
    ownerIds = ownerIds.concat([current.id]);
  } else {
    const ownerLimit = periodic_sync_scheduler_owner_limit();
    for (const agent of allAgents) {
      if (!agent_recent_enough_for_periodic_sync(agent)) {
        continue;
      }
      const ownerUserId = string.from(agent.ownerUserId ?? '').trim();
      if (ownerUserId.length != 0 && !string_array_contains(ownerIds, ownerUserId)) {
        ownerIds = ownerIds.concat([ownerUserId]);
        if (ownerIds.length >= ownerLimit) {
          break;
        }
      }
    }
  }

  let createdJobs = [];
  let checkedOwners = [];
  for (const ownerUserId of ownerIds) {
    const hasManualPendingTables = manual_sync_pending_tables_for_owner(ownerUserId).length > 0;
    if (!claim_periodic_sync_scheduler_for_owner(ownerUserId, hasManualPendingTables)) {
      continue;
    }
    checkedOwners = checkedOwners.concat([ownerUserId]);
    const ownerJobs = queue_due_periodic_sync_jobs_for_owner(ownerUserId, allAgents);
    if (ownerJobs.length > 0) {
      createdJobs = createdJobs.concat(ownerJobs);
    }
  }
  return {
    ok: true,
    checkedOwnerCount: checkedOwners.length,
    createdJobCount: createdJobs.length,
    jobs: createdJobs.map((job) => agent_job_payload(job))
  };
}

function agent_sync_settings_get(clientName: string, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  const user = find_user_by_identity(clientName);
  if (user != null && !can_manage_user(current, user)) {
    return raw_json_error(403, 'permission denied');
  }
  let userId = null;
  let ownerUserId = null;
  if (user != null) {
    userId = user.id;
    ownerUserId = user.ownerUserId;
  }
  const agent = ensure_agent(clientName, userId, ownerUserId);
  return { syncSettings: sync_settings_payload(agent) };
}

function agent_sync_settings_post(clientName: string, historyLimit: int? = null, autoSyncIntervalMinutes: int? = null, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  const user = find_user_by_identity(clientName);
  if (user != null && !can_manage_user(current, user)) {
    return raw_json_error(403, 'permission denied');
  }
  let userId = null;
  let ownerUserId = null;
  if (user != null) {
    userId = user.id;
    ownerUserId = user.ownerUserId;
  }
  ensure_agent(clientName, userId, ownerUserId);
  const updated = db.update(Agent, { clientName }, {
    historyLimit: clamp_history_limit(historyLimit),
    autoSyncIntervalMinutes: clamp_auto_sync_interval(autoSyncIntervalMinutes),
    updatedAt: now_iso()
  });
  if (updated == null) {
    return raw_json_error(404, 'agent not found');
  }
  return { ok: true, syncSettings: sync_settings_payload(updated) };
}

function agent_sync_settings_post_all(historyLimit: int? = null, autoSyncIntervalMinutes: int? = null, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (is_client_user(current)) {
    return raw_json_error(403, 'permission denied');
  }

  const nextHistoryLimit = clamp_history_limit(historyLimit);
  const nextAutoSyncIntervalMinutes = clamp_auto_sync_interval(autoSyncIntervalMinutes);
  let targetClientNames = [];
  for (const agent of visible_agent_rows_for(current)) {
    if (agent.clientName == null) {
      continue;
    }
    const clientName = string.from(agent.clientName).trim();
    if (clientName.length == 0) {
      continue;
    }
    targetClientNames = targetClientNames.concat([clientName]);
  }

  if (targetClientNames.length != 0) {
    db.updateMany(Agent, { clientName: { in: targetClientNames } }, {
      historyLimit: nextHistoryLimit,
      autoSyncIntervalMinutes: nextAutoSyncIntervalMinutes,
      updatedAt: now_iso()
    });
  }

  return {
    ok: true,
    updatedCount: targetClientNames.length,
    updatedClients: targetClientNames,
    syncSettings: {
      historyLimit: nextHistoryLimit,
      autoSyncIntervalMinutes: nextAutoSyncIntervalMinutes
    }
  };
}

function agent_jobs(clientName: string): map<json> {
  return { jobs: active_jobs_for_client(clientName) };
}

function agent_diagnostics_request(clientName: string, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (!is_admin_user(current) && !is_owner_user(current)) {
    return raw_json_error(403, 'permission denied');
  }
  const normalizedClientName = normalize_user_name(clientName);
  const targetUser = find_user_by_identity(normalizedClientName);
  if (targetUser != null && !can_manage_user(current, targetUser)) {
    return raw_json_error(403, 'permission denied');
  }
  let targetOwnerUserId = null;
  if (targetUser != null) {
    targetOwnerUserId = targetUser.ownerUserId;
  }
  let targetClientUserId = null;
  if (targetUser != null) {
    targetClientUserId = targetUser.id;
  }
  const agent = ensure_agent(normalizedClientName, targetClientUserId, targetOwnerUserId);
  const updated = db.update(Agent, { clientName: normalizedClientName }, {
    diagnosticRequestId: uuid.v4(),
    diagnosticRequestedAt: now_iso(),
    diagnosticRequestedByUserId: current.id,
    diagnosticStatus: 'requested',
    updatedAt: now_iso()
  });
  if (updated == null) {
    return raw_json_error(404, 'client not found');
  }
  return {
    ok: true,
    clientName: normalizedClientName,
    diagnostics: agent_diagnostics_payload(updated)
  };
}

function online_visible_agent_client_names(current: map<json>, limit: int = 0): array<string> {
  const visibleAgents = visible_agent_rows_for(current);
  let requestedClientNames = [];
  for (const agent of visibleAgents) {
    if (!effective_agent_online(agent)) {
      continue;
    }
    const clientName = normalize_user_name(agent.clientName);
    if (clientName.length == 0 || string_array_contains(requestedClientNames, clientName)) {
      continue;
    }
    requestedClientNames = requestedClientNames.concat([clientName]);
    if (limit > 0 && requestedClientNames.length >= limit) {
      break;
    }
  }
  return requestedClientNames;
}

function agent_diagnostics_request_batch(clientNames: array<string>? = null, requestId: string? = null, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (!is_admin_user(current) && !is_owner_user(current)) {
    return raw_json_error(403, 'permission denied');
  }
  let normalizedRequestId = '';
  if (requestId != null) {
    normalizedRequestId = truncate_text(string.from(requestId).trim(), 64);
  }
  if (normalizedRequestId.length == 0) {
    normalizedRequestId = uuid.v4();
  }
  const requestedAt = now_iso();
  const visibleClientNames = online_visible_agent_client_names(current);
  let requestedClientNames = [];
  for (const item of clientNames ?? []) {
    const clientName = normalize_user_name(item);
    if (clientName.length == 0) {
      continue;
    }
    if (!string_array_contains(visibleClientNames, clientName)) {
      continue;
    }
    if (!string_array_contains(requestedClientNames, clientName)) {
      requestedClientNames = requestedClientNames.concat([clientName]);
    }
  }
  if (requestedClientNames.length == 0) {
    return {
      ok: true,
      requestId: normalizedRequestId,
      requestedAt,
      requestedByUserId: current.id,
      requestedClientCount: 0,
      requestedClientNames: []
    };
  }
  db.updateMany(Agent, { clientName: { in: requestedClientNames } }, {
    diagnosticRequestId: normalizedRequestId,
    diagnosticRequestedAt: requestedAt,
    diagnosticRequestedByUserId: current.id,
    diagnosticStatus: 'requested',
    updatedAt: requestedAt
  });

  return {
    ok: true,
    requestId: normalizedRequestId,
    requestedAt,
    requestedByUserId: current.id,
    requestedClientCount: requestedClientNames.length,
    requestedClientNames
  };
}

function agent_diagnostics_request_all(batchSize: int = 0, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (!is_admin_user(current) && !is_owner_user(current)) {
    return raw_json_error(403, 'permission denied');
  }

  let normalizedBatchSize = batchSize;
  if (normalizedBatchSize < 0) {
    normalizedBatchSize = 0;
  }
  if (normalizedBatchSize > 50) {
    normalizedBatchSize = 50;
  }
  const requestedClientNames = online_visible_agent_client_names(current, normalizedBatchSize);
  return agent_diagnostics_request_batch(requestedClientNames, null, token);
}

function agent_client_update_request(clientName: string, targetVersion: string? = null, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (!is_admin_user(current) && !is_owner_user(current)) {
    return raw_json_error(403, 'permission denied');
  }
  const normalizedClientName = normalize_user_name(clientName);
  const targetUser = find_user_by_identity(normalizedClientName);
  if (targetUser != null && !can_manage_user(current, targetUser)) {
    return raw_json_error(403, 'permission denied');
  }
  let targetOwnerUserId = null;
  if (targetUser != null) {
    targetOwnerUserId = targetUser.ownerUserId;
  }
  let targetClientUserId = null;
  if (targetUser != null) {
    targetClientUserId = targetUser.id;
  }
  ensure_agent(normalizedClientName, targetClientUserId, targetOwnerUserId);
  const requestedAt = now_iso();
  let normalizedTargetVersion = '';
  if (targetVersion != null) {
    normalizedTargetVersion = truncate_text(string.from(targetVersion).trim(), 32);
  }
  let targetVersionOrNull = null;
  if (normalizedTargetVersion.length != 0) {
    targetVersionOrNull = normalizedTargetVersion;
  }
  const updated = db.update(Agent, { clientName: normalizedClientName }, {
    clientUpdateRequestId: uuid.v4(),
    clientUpdateRequestedAt: requestedAt,
    clientUpdateRequestedByUserId: current.id,
    clientUpdateTargetVersion: targetVersionOrNull,
    clientUpdateStatus: 'requested',
    clientUpdateMessage: '',
    updatedAt: requestedAt
  });
  if (updated == null) {
    return raw_json_error(404, 'client not found');
  }
  return {
    ok: true,
    clientName: normalizedClientName,
    clientUpdate: agent_client_update_payload(updated)
  };
}

function agent_client_update_request_all(targetVersion: string? = null, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (!is_admin_user(current) && !is_owner_user(current)) {
    return raw_json_error(403, 'permission denied');
  }
  const requestId = uuid.v4();
  const requestedAt = now_iso();
  let normalizedTargetVersion = '';
  if (targetVersion != null) {
    normalizedTargetVersion = truncate_text(string.from(targetVersion).trim(), 32);
  }
  let targetVersionOrNull = null;
  if (normalizedTargetVersion.length != 0) {
    targetVersionOrNull = normalizedTargetVersion;
  }
  const visibleAgents = visible_agent_rows_for(current);
  let requestedClientNames = [];
  for (const agent of visibleAgents) {
    const clientName = normalize_user_name(agent.clientName);
    if (clientName.length != 0) {
      requestedClientNames = requestedClientNames.concat([clientName]);
    }
  }
  if (requestedClientNames.length == 0) {
    return {
      ok: true,
      requestId,
      requestedAt,
      requestedByUserId: current.id,
      requestedClientCount: 0,
      requestedClientNames: []
    };
  }
  db.updateMany(Agent, { clientName: { in: requestedClientNames } }, {
    clientUpdateRequestId: requestId,
    clientUpdateRequestedAt: requestedAt,
    clientUpdateRequestedByUserId: current.id,
    clientUpdateTargetVersion: targetVersionOrNull,
    clientUpdateStatus: 'requested',
    clientUpdateMessage: '',
    updatedAt: requestedAt
  });
  return {
    ok: true,
    requestId,
    requestedAt,
    requestedByUserId: current.id,
    requestedClientCount: requestedClientNames.length,
    requestedClientNames
  };
}

function agent_client_update_ack(clientName: string? = null, requestId: string? = null, status: string = 'current', installedVersion: string = '', message: string = '', token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  let resolvedClientName = '';
  if (clientName == null || clientName.trim().length == 0) {
    if (current.username == null) {
      resolvedClientName = normalize_user_name(current.name);
    } else {
      resolvedClientName = normalize_user_name(current.username);
    }
  } else {
    resolvedClientName = normalize_user_name(clientName);
  }
  const targetUser = find_user_by_identity(resolvedClientName);
  if (targetUser != null && !can_manage_user(current, targetUser)) {
    return raw_json_error(403, 'permission denied');
  }
  let targetOwnerUserId = owner_namespace_for_user(current);
  let targetClientUserId = current.id;
  if (targetUser != null) {
    targetOwnerUserId = targetUser.ownerUserId;
    targetClientUserId = targetUser.id;
  }
  const agent = ensure_agent(resolvedClientName, targetClientUserId, targetOwnerUserId);
  let resolvedRequestId = '';
  if (requestId != null) {
    resolvedRequestId = string.from(requestId).trim();
  }
  if (resolvedRequestId.length == 0 && agent.clientUpdateRequestId != null) {
    resolvedRequestId = string.from(agent.clientUpdateRequestId).trim();
  }
  let resolvedRequestIdOrNull = null;
  if (resolvedRequestId.length != 0) {
    resolvedRequestIdOrNull = resolvedRequestId;
  }
  let nextClientVersion = '';
  if (installedVersion.trim().length == 0) {
    if (agent.clientVersion != null) {
      nextClientVersion = truncate_text(string.from(agent.clientVersion).trim(), 32);
    }
  } else {
    nextClientVersion = truncate_text(installedVersion.trim(), 32);
  }
  const updated = db.update(Agent, { clientName: resolvedClientName }, {
    clientUpdateLastRequestId: resolvedRequestIdOrNull,
    clientUpdateLastAcknowledgedAt: now_iso(),
    clientUpdateStatus: truncate_text(status.trim(), 32),
    clientUpdateMessage: truncate_text(message, 4000),
    clientVersion: nextClientVersion,
    updatedAt: now_iso()
  });
  if (updated == null) {
    return raw_json_error(404, 'client not found');
  }
  return {
    ok: true,
    clientName: resolvedClientName,
    clientUpdate: agent_client_update_payload(updated)
  };
}

function agent_window_action_request_all(action: string = 'minimize', token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (!is_admin_user(current) && !is_owner_user(current)) {
    return raw_json_error(403, 'permission denied');
  }
  const normalizedAction = truncate_text(action.trim().toLowerCase(), 32);
  if (normalizedAction.length == 0) {
    return raw_json_error(400, 'action is required');
  }
  if (normalizedAction != 'minimize') {
    return raw_json_error(400, 'unsupported window action');
  }
  const requestId = uuid.v4();
  const requestedAt = now_iso();
  const visibleAgents = visible_agent_rows_for(current);
  let requestedClientNames = [];
  for (const agent of visibleAgents) {
    if (!effective_agent_online(agent)) {
      continue;
    }
    const clientName = normalize_user_name(agent.clientName);
    if (clientName.length != 0) {
      requestedClientNames = requestedClientNames.concat([clientName]);
    }
  }
  if (requestedClientNames.length == 0) {
    return {
      ok: true,
      action: normalizedAction,
      requestId,
      requestedAt,
      requestedByUserId: current.id,
      requestedClientCount: 0,
      requestedClientNames: []
    };
  }
  db.updateMany(Agent, { clientName: { in: requestedClientNames } }, {
    windowActionRequestId: requestId,
    windowActionRequestedAt: requestedAt,
    windowActionRequestedByUserId: current.id,
    windowActionName: normalizedAction,
    windowActionStatus: 'requested',
    windowActionMessage: '',
    updatedAt: requestedAt
  });
  return {
    ok: true,
    action: normalizedAction,
    requestId,
    requestedAt,
    requestedByUserId: current.id,
    requestedClientCount: requestedClientNames.length,
    requestedClientNames
  };
}

