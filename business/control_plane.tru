    orderBy: { field: 'clientName', dir: 'asc' },
    fields: ['clientName', 'machineName', 'server', 'database', 'isOnline', 'historyLimit', 'autoSyncIntervalMinutes', 'serverConnected', 'sqlConnected', 'lastHeartbeat', 'selectedTable', 'diagnosticRequestId', 'diagnosticRequestedAt', 'diagnosticRequestedByUserId', 'diagnosticLastRequestId', 'diagnosticLastUploadedAt', 'diagnosticStatus', 'diagnosticSummary', 'clientUserId', 'ownerUserId', 'updatedAt'],
    limit: limit + 1
  });
  if (rows == null) {
    return [];
  }
  return rows;
}

function live_state_job_rows_for(current: map<json>, limit: int): array<json> {
  let where = { createdAt: { lte: now_iso() } };
  if (is_client_user(current)) {
    where = { clientUserId: current.id };
  }
  if (is_owner_user(current)) {
    where = { ownerUserId: current.id };
  }
  const rows = db.selectMany(SyncJob, {
    where,
    orderBy: { field: 'createdAt', dir: 'desc' },
    fields: ['id', 'clientName', 'sourceClientName', 'table', 'direction', 'status', 'progress', 'rowCount', 'createdAt', 'updatedAt', 'startedAt', 'completedAt', 'message', 'error', 'clientUserId', 'ownerUserId'],
    limit: limit + 1
  });
  if (rows == null) {
    return [];
  }
  return rows;
}

function bounded_public_agent_payloads(rows: array<json>, limit: int): map<json> {
  let items = [];
  let seen = 0;
  for (const row of rows) {
    seen += 1;
    if (items.length < limit) {
      items = items.concat([public_agent_payload(row)]);
    }
  }
  return {
    items,
    total: seen,
    truncated: seen > items.length
  };
}

function bounded_public_job_payloads(rows: array<json>, limit: int): map<json> {
  let items = [];
  let seen = 0;
  for (const row of rows) {
    seen += 1;
    if (items.length < limit) {
      items = items.concat([public_job_payload(row)]);
    }
  }
  return {
    items,
    total: seen,
    truncated: seen > items.length
  };
}

function ensure_agent(clientName: string, clientUserId: string? = null, ownerUserId: string? = null): map<json> {
  try {
    const existing = db.selectOne(Agent, { clientName });
    if (existing != null) {
      return existing;
    }
  } catch (err) {
    const repaired = db.update(Agent, { clientName }, {
      tableRelationships: [],
      replicationUseWindowsAuth: true,
      replicationUser: '',
      replicationPassword: '',
      diagnosticRequestId: null,
      diagnosticRequestedAt: null,
      diagnosticRequestedByUserId: null,
      diagnosticLastRequestId: null,
      diagnosticLastUploadedAt: null,
      diagnosticStatus: 'idle',
      diagnosticSummary: '',
      diagnosticPayload: '',
      symmetricDsStatus: 'unknown',
      symmetricDsConfigPath: '',
      symmetricDsMessage: '',
      symmetricDsConfiguredAt: null,
      clientVersion: '',
      clientUserId,
      ownerUserId,
      updatedAt: now_iso()
    });
    if (repaired != null) {
      return repaired;
    }
    db.delete(Agent, { clientName });
  }
  return db.insert(Agent, {
    clientName,
    machineName: clientName,
    server: '',
    database: '',
    replicationUseWindowsAuth: true,
    replicationUser: '',
    replicationPassword: '',
    isOnline: false,
    historyLimit: 5,
    autoSyncIntervalMinutes: 15,
    serverConnected: false,
    sqlConnected: false,
    clientVersion: '',
    lastHeartbeat: '',
    selectedTable: null,
    tables: [],
    tableRelationships: [],
    diagnosticRequestId: null,
    diagnosticRequestedAt: null,
    diagnosticRequestedByUserId: null,
    diagnosticLastRequestId: null,
    diagnosticLastUploadedAt: null,
    diagnosticStatus: 'idle',
    diagnosticSummary: '',
    diagnosticPayload: '',
    symmetricDsStatus: 'unknown',
    symmetricDsConfigPath: '',
    symmetricDsMessage: '',
    symmetricDsConfiguredAt: null,
    clientUserId,
    ownerUserId,
    updatedAt: now_iso()
  });
}

function sync_settings_payload(agent: map<json>): map<json> {
  return {
    historyLimit: agent.historyLimit,
    autoSyncIntervalMinutes: agent.autoSyncIntervalMinutes
  };
}

function active_jobs_for_client(clientName: string): array<json> {
  const rows = db.selectMany(SyncJob, {
    where: { clientName },
    orderBy: { field: 'updatedAt', dir: 'desc' },
    fields: ['id', 'clientName', 'sourceClientName', 'subscriberClientName', 'table', 'direction', 'mergeRole', 'publisherServer', 'publisherDatabase', 'publicationName', 'publisherUseWindowsAuth', 'publisherUser', 'publisherPassword', 'status', 'progress', 'rowCount', 'createdAt', 'updatedAt', 'startedAt', 'completedAt', 'message', 'error', 'clientUserId', 'ownerUserId'],
    limit: 1000
  });
  if (rows == null) {
    return [];
  }
  let jobs = [];
  let seenTables = [];
  for (const job of rows) {
    let tableSeen = false;
    for (const seenTable of seenTables) {
      if (seenTable == job.table) {
        tableSeen = true;
      }
    }
    if (tableSeen) {
      continue;
    }

    const status = string.from(job.status).trim();
    if (status == 'queued' || status == 'running' || status == 'applying') {
      jobs = jobs.concat([agent_job_payload(job)]);
      seenTables = seenTables.concat([job.table]);
    } else if (status == 'completed' || status == 'failed' || status == 'cancelled') {
      seenTables = seenTables.concat([job.table]);
    }
  }
  return jobs;
}

function unique_string_values(values: array<string>): array<string> {
  let unique = [];
  for (const value of values) {
    let seen = false;
    for (const existing of unique) {
      if (existing == value) {
        seen = true;
      }
    }
    if (!seen) {
      unique = unique.concat([value]);
    }
  }
  return unique;
}

function active_job_tables_for_client(clientName: string): array<string> {
  const jobs = active_jobs_for_client(clientName);
  let tables = [];
  for (const job of jobs) {
    tables = tables.concat([string.from(job.table)]);
  }
  return unique_string_values(tables);
}

function enabled_sync_tables_for_agent(agent: map<json>): array<string> {
  let enabledTables = [];
  let tables = [];
  if (agent.tables != null) {
    tables = apply_table_sync_policies(agent.ownerUserId, agent.tables, string.from(agent.database));
  }
  for (const tableState of tables) {
    if (tableState.enabled == true && tableState.table != null) {
      enabledTables = enabledTables.concat([string.from(tableState.table)]);
    }
  }
  return unique_string_values(enabledTables);
}

function enabled_sync_policy_tables_for_agent(agent: map<json>): array<string> {
  let enabledTables = [];
  const policies = list_table_sync_policies_for_scope(agent.ownerUserId).map((row) => normalize_stored_table_sync_policy(row));
  for (const policy of policies) {
    if (policy.enabled == true) {
      const table = table_sync_policy_sync_key(policy);
      if (table.trim().length != 0) {
        enabledTables = enabledTables.concat([table]);
      }
    }
  }
  return unique_string_values(enabledTables);
}

function latest_completed_job_tables_for_client(clientName: string): array<string> {
  const rows = db.selectMany(SyncJob, {
    where: { clientName },
    orderBy: { field: 'updatedAt', dir: 'desc' },
    fields: ['table', 'status'],
    limit: 1000
  });
  if (rows == null) {
    return [];
  }
  let tables = [];
  for (const row of rows) {
    if (row.status == 'completed' && row.table != null) {
      tables = tables.concat([string.from(row.table)]);
    }
  }
  return unique_string_values(tables);
}

function create_sync_jobs_for_agent(agent: map<json>, tables: array<string>, sourceClientName: string = ''): array<json> {
  if (tables.length == 0) {
    return [];
  }
  let sourceAgent = null;
  const resolvedSourceClientName = sourceClientName.trim();
  if (resolvedSourceClientName.length != 0 && resolvedSourceClientName != agent.clientName) {
    sourceAgent = db.selectOne(Agent, { clientName: resolvedSourceClientName });
    if (sourceAgent == null) {
      return [];
    }
  }
  const activeTables = active_job_tables_for_client(agent.clientName);
  const expandedTables = expand_sync_job_tables_for_owner(agent.ownerUserId, tables);
  let tablesToCreate = [];
  for (const table of expandedTables) {
    let busy = false;
    for (const activeTable of activeTables) {
      if (activeTable == table) {
        busy = true;
      }
    }
    if (!busy) {
      tablesToCreate = tablesToCreate.concat([table]);
    }
  }
  if (tablesToCreate.length == 0) {
    return [];
  }
  if (sourceAgent != null) {
    let rows = [];
    for (const table of tablesToCreate) {
      rows = rows.concat([{
        id: uuid.v4(),
        clientName: agent.clientName,
        sourceClientName: sourceAgent.clientName,
        subscriberClientName: agent.clientName,
        table,
        direction: 'sync',
        mergeRole: 'symmetricds',
        publisherServer: sourceAgent.server,
        publisherDatabase: sourceAgent.database,
        publicationName: '',
        publisherUseWindowsAuth: sourceAgent.replicationUseWindowsAuth == true,
        publisherUser: sourceAgent.replicationUser,
        publisherPassword: sourceAgent.replicationPassword,
        status: 'queued',
        progress: 0,
        rowCount: 0,
        snapshotBytes: 0,
        snapshotCreatedAt: null,
        snapshotId: null,
        createdAt: now_iso(),
        updatedAt: now_iso(),
        startedAt: null,
        completedAt: null,
        message: string.concat('Queued SymmetricDS sync for ', table, '.'),
        error: null,
        clientUserId: agent.clientUserId,
        ownerUserId: agent.ownerUserId
      }]);
    }
    if (rows.length == 0) {
      return [];
    }
    return db.insertMany(SyncJob, rows);
  }
  const rows = tablesToCreate.map((table) => {
    const tableReference = sync_table_reference(table);
    let publisherDatabase = agent.database;
    if (tableReference.database != null && string.from(tableReference.database).trim().length != 0) {
      publisherDatabase = string.from(tableReference.database).trim();
    }
    return {
      id: uuid.v4(),
      clientName: agent.clientName,
      sourceClientName,
      subscriberClientName: agent.clientName,
      table,
      direction: 'sync',
      mergeRole: 'symmetricds',
      publisherServer: agent.server,
      publisherDatabase,
      publicationName: '',
      publisherUseWindowsAuth: agent.replicationUseWindowsAuth == true,
      publisherUser: agent.replicationUser,
      publisherPassword: agent.replicationPassword,
      status: 'queued',
      progress: 0,
      rowCount: 0,
      snapshotBytes: 0,
      snapshotCreatedAt: null,
      snapshotId: null,
      createdAt: now_iso(),
      updatedAt: now_iso(),
      startedAt: null,
      completedAt: null,
      message: string.concat('Queued SymmetricDS sync for ', table, '.'),
      error: null,
      clientUserId: agent.clientUserId,
      ownerUserId: agent.ownerUserId
    };
  });
  return db.insertMany(SyncJob, rows);
}

function row_key(row: map<json>, keyColumns: array<string>): string {
  if (keyColumns.length == 0) {
    return json.stringify(row);
  }
  let values = [];
  for (const column of keyColumns) {
    values = values.concat([row[column]]);
  }
  return json.stringify(values);
}

function string_array_contains(values: array<string>, target: string): bool {
  for (const value of values) {
    if (value == target) {
      return true;
    }
  }
  return false;
}

function merge_rows_by_key(existingRows: array<json>, incomingRows: array<json>, keyColumns: array<string>): array<json> {
  if (incomingRows.length == 0) {
    return existingRows;
  }
  if (existingRows.length == 0) {
    return incomingRows;
  }

  let incomingKeys = [];
  for (const incoming of incomingRows) {
    incomingKeys = incomingKeys.concat([row_key(incoming, keyColumns)]);
  }

  let retained = [];
  for (const current of existingRows) {
    if (!string_array_contains(incomingKeys, row_key(current, keyColumns))) {
      retained = retained.concat([current]);
    }
  }
  return retained.concat(incomingRows);
}


function normalize_key_columns(keyColumns: array<string>? = null): array<string> {
  if (keyColumns == null) {
    return [];
  }
  return keyColumns;
}

function auth_login(name: string, password: string, app: string = 'web'): map<json> {
  const normalizedName = normalize_user_name(name);
  let user = null;
  if (normalizedName == default_admin_username()) {
    user = seed_admin_user();
  } else {
    user = find_user_by_identity(name);
  }
  if (user == null) {
    return raw_json_error(401, 'user not found');
  }
  if (user.password != password) {
    return raw_json_error(401, 'invalid password');
  }
  return create_session_for_user(user, app);
}

function auth_me(token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'not authenticated');
  }
  return { user: public_user_payload(current) };
}

function auth_logout(token: string? = null): map<json> {
  if (token == null || token.trim().length == 0) {
    return raw_json_error(401, 'not authenticated');
  }
  const session = db.update(Session, { token }, { revokedAt: now_iso() });
  if (session == null) {
    return raw_json_error(401, 'not authenticated');
  }
  return { ok: true };
}

function users_list(token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (!is_admin_user(current) && !is_owner_user(current)) {
    return raw_json_error(403, 'permission denied');
  }
  const users = visible_user_rows_for(current).map((user) => public_user_payload(user));
  return { users };
}

function users_create(name: string, email: string = '', password: string, role: string, ownerUserId: string? = null, token: string? = null): map<json> {
  const normalized = normalize_user_name(name);
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }

  let resolvedRole = role;
  let resolvedOwnerUserId = ownerUserId;
  if (is_owner_user(current)) {
    if (role != 'client') {
      return raw_json_error(403, 'owners can create client accounts only');
    }
    resolvedRole = 'client';
    resolvedOwnerUserId = current.id;
  } else if (is_admin_user(current)) {
    if (role != 'owner' && role != 'client') {
      return raw_json_error(403, 'admins can create owner or client accounts only');
    }
    if (role == 'client') {
      const owner = find_user_by_id(ownerUserId);
      if (owner == null || !is_owner_user(owner)) {
        return raw_json_error(400, 'client accounts must belong to a valid owner');
      }
      resolvedOwnerUserId = owner.id;
    } else {
      resolvedOwnerUserId = null;
    }
  } else {
    return raw_json_error(403, 'permission denied');
  }

  const existing = find_user_by_identity(normalized);
  if (existing != null) {
    if (!can_manage_user(current, existing)) {
      return raw_json_error(409, 'an account with that name already exists');
    }
    return raw_json_success({ user: public_user_payload(existing), existed: true }, 200);
  }

  const user = db.insert(User, {
    id: uuid.v4(),
    username: normalized,
    email,
    name: normalized,
    role: resolvedRole,
    ownerUserId: resolvedOwnerUserId,
    createdByUserId: current.id,
    password,
    createdAt: now_iso()
  });
  return raw_json_success({ user: public_user_payload(user) }, 201);
}

function user_reset_password(userId: string, password: string, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  const target = find_user_by_id(userId);
  if (!can_manage_user(current, target)) {
    return raw_json_error(403, 'permission denied');
  }
  const user = db.update(User, { id: userId }, { password });
  if (user == null) {
    return raw_json_error(404, 'user not found');
  }
  return { ok: true };
}

function user_delete(userId: string, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  const target = find_user_by_id(userId);
  if (target == null) {
    return raw_json_error(404, 'user not found');
  }
  if (!can_manage_user(current, target)) {
    return raw_json_error(403, 'permission denied');
  }
  if (!is_client_user(target)) {
    return raw_json_error(403, 'only client accounts can be deleted');
  }

  db.updateMany(Session, { userId }, { revokedAt: now_iso() });
  db.delete(Agent, { clientName: target.username });
  const deleted = db.delete(User, { id: userId });
  if (deleted == 0) {
    return raw_json_error(404, 'user not found');
  }
  return { ok: true, user: public_user_payload(target) };
}

function live_state(token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  const agentLimit = live_state_agent_limit();
  const jobLimit = live_state_job_limit();
  const agentPage = bounded_public_agent_payloads(
    live_state_agent_rows_for(current, agentLimit),
    agentLimit
  );
  const jobPage = bounded_public_job_payloads(
    live_state_job_rows_for(current, jobLimit),
    jobLimit
  );
  return {
    generatedAt: now_iso(),
    syncEngine: sync_engine_metadata(),
    agents: agentPage.items,
    jobs: jobPage.items,
    limits: {
      agents: agentLimit,
      jobs: jobLimit
    },
    totals: {
      agents: agentPage.total,
      jobs: jobPage.total
    },
    truncated: {
      agents: agentPage.truncated,
      jobs: jobPage.truncated
    }
  };
}

function agents_heartbeat(clientName: string? = null, machineName: string = '', historyLimit: int? = null, autoSyncIntervalMinutes: int? = null, server: string = '', database: string = '', replicationUseWindowsAuth: bool = true, replicationUser: string = '', replicationPassword: string = '', serverConnected: bool = false, sqlConnected: bool = false, selectedTable: string? = null, tables: array<json>? = null, tableRelationships: array<json>? = null, clientVersion: string = '', symmetricDsStatus: string = 'unknown', symmetricDsConfigPath: string = '', symmetricDsMessage: string = '', symmetricDsConfigured: bool = false, token: string? = null): map<json> {
  let resolvedClientName = '';
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (clientName == null || clientName.trim().length == 0) {
    if (current.username == null) {
      resolvedClientName = normalize_user_name(current.name);
    } else {
      resolvedClientName = current.username;
    }
  } else {
    resolvedClientName = normalize_user_name(clientName);
  }
  const clientUser = find_user_by_identity(resolvedClientName);
  if (clientUser != null && !can_manage_user(current, clientUser)) {
    return raw_json_error(403, 'permission denied');
  }
  let userId = null;
  let ownerUserId = owner_namespace_for_user(current);
  userId = current.id;
  const agent = ensure_agent(
    resolvedClientName,
    userId,
    ownerUserId
  );
  let nextTables = agent.tables;
  if (tables != null) {
    nextTables = tables;
  }
  const nextTableRelationships = bounded_table_relationships(database, tableRelationships, resolvedClientName);
  nextTables = bounded_agent_tables(nextTables, selectedTable);
  nextTables = apply_table_sync_policies(ownerUserId, nextTables, database);
  let nextSymmetricDsConfiguredAt = agent.symmetricDsConfiguredAt;
  if (symmetricDsConfigured) {
    nextSymmetricDsConfiguredAt = now_iso();
  }
  const updated = db.update(Agent, { clientName: resolvedClientName }, {
    machineName: machineName.trim().length == 0 ? resolvedClientName : machineName,
    server,
    database,
    replicationUseWindowsAuth,
    replicationUser,
    replicationPassword,
    isOnline: true,
    historyLimit: clamp_history_limit(historyLimit),
    autoSyncIntervalMinutes: clamp_auto_sync_interval(autoSyncIntervalMinutes),
    serverConnected,
    sqlConnected,
    clientVersion: truncate_text(clientVersion.trim(), 32),
    symmetricDsStatus: truncate_text(symmetricDsStatus.trim(), 64),
    symmetricDsConfigPath: truncate_text(symmetricDsConfigPath.trim(), 512),
    symmetricDsMessage: truncate_text(symmetricDsMessage.trim(), 4000),
    symmetricDsConfiguredAt: nextSymmetricDsConfiguredAt,
    lastHeartbeat: now_iso(),
    selectedTable,
    tables: nextTables,
    tableRelationships: nextTableRelationships,
    updatedAt: now_iso()
  });
  let nextAgent = agent;
  if (updated != null) {
    nextAgent = updated;
  }
  if (nextAgent == null) {
    return raw_json_error(500, 'agent heartbeat state unavailable');
  }
  return {
    ok: true,
    syncEngine: sync_engine_metadata(),
    syncSettings: sync_settings_payload(nextAgent),
    tablePolicies: table_sync_policy_payloads_for_database(ownerUserId, database),
    tableDependencies: table_dependency_payloads_for_database(ownerUserId, database),
    jobs: active_jobs_for_client(resolvedClientName),
    diagnostics: agent_diagnostics_payload(nextAgent)
  };
}

function agent_symmetricds_status_post(clientName: string? = null, status: string = 'unknown', configPath: string = '', message: string = '', configured: bool = false, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  let resolvedClientName = '';
  if (clientName == null || clientName.trim().length == 0) {
    if (current.username == null) {
      resolvedClientName = normalize_user_name(current.name);
    } else {
      resolvedClientName = current.username;
    }
  } else {
    resolvedClientName = normalize_user_name(clientName);
  }
  const clientUser = find_user_by_identity(resolvedClientName);
  if (clientUser != null && !can_manage_user(current, clientUser)) {
    return raw_json_error(403, 'permission denied');
  }
  let userId = current.id;
  let ownerUserId = owner_namespace_for_user(current);
  const agent = ensure_agent(resolvedClientName, userId, ownerUserId);
  let nextSymmetricDsConfiguredAt = agent.symmetricDsConfiguredAt;
  if (configured) {
    nextSymmetricDsConfiguredAt = now_iso();
  }
  const updated = db.update(Agent, { clientName: resolvedClientName }, {
    symmetricDsStatus: truncate_text(status.trim(), 64),
    symmetricDsConfigPath: truncate_text(configPath.trim(), 512),
    symmetricDsMessage: truncate_text(message.trim(), 4000),
    symmetricDsConfiguredAt: nextSymmetricDsConfiguredAt,
    updatedAt: now_iso()
  });
  if (updated == null) {
    return raw_json_error(500, 'agent symmetricds status unavailable');
  }
  return {
    ok: true,
    agent: public_agent_payload(updated)
  };
}

