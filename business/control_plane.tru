  const updated = db.update(SyncJob, { id: jobId }, {
    clientName: job.clientName,
    sourceClientName: job.sourceClientName,
    subscriberClientName: job.subscriberClientName,
    table: job.table,
    direction: job.direction,
    mergeRole: job.mergeRole,
    publisherServer: job.publisherServer,
    publisherDatabase: job.publisherDatabase,
    publicationName: job.publicationName,
    publisherUseWindowsAuth: job.publisherUseWindowsAuth,
    publisherUser: job.publisherUser,
    publisherPassword: job.publisherPassword,
    status,
    progress,
    rowCount,
    snapshotBytes: job.snapshotBytes,
    snapshotCreatedAt: job.snapshotCreatedAt,
    snapshotId: job.snapshotId,
    createdAt: job.createdAt,
    startedAt: job.startedAt,
    completedAt,
    message,
    error: null,
    clientUserId: job.clientUserId,
    ownerUserId: job.ownerUserId,
    updatedAt: completedAt
  });
  let nextJob = job;
  if (updated != null) {
    nextJob = updated;
  }
  return { job: public_job_payload(nextJob) };
}

function jobs_fail(jobId: string, message: string, progress: int? = null, token: string? = null): map<json> {
  const job = find_job_by_id(jobId);
  if (job == null) {
    return raw_json_error(404, 'job not found');
  }
  if (!can_access_job(current_user_record(token), job)) {
    return raw_json_error(403, 'permission denied');
  }
  let nextProgress = job.progress;
  if (progress != null) {
    nextProgress = progress;
  }
  const updated = db.update(SyncJob, { id: jobId }, {
    clientName: job.clientName,
    sourceClientName: job.sourceClientName,
    subscriberClientName: job.subscriberClientName,
    table: job.table,
    direction: job.direction,
    mergeRole: job.mergeRole,
    publisherServer: job.publisherServer,
    publisherDatabase: job.publisherDatabase,
    publicationName: job.publicationName,
    publisherUseWindowsAuth: job.publisherUseWindowsAuth,
    publisherUser: job.publisherUser,
    publisherPassword: job.publisherPassword,
    status: 'failed',
    progress: nextProgress,
    rowCount: job.rowCount,
    snapshotBytes: job.snapshotBytes,
    snapshotCreatedAt: job.snapshotCreatedAt,
    snapshotId: job.snapshotId,
    createdAt: job.createdAt,
    startedAt: job.startedAt,
    completedAt: now_iso(),
    error: message,
    message,
    clientUserId: job.clientUserId,
    ownerUserId: job.ownerUserId,
    updatedAt: now_iso()
  });
  let nextJob = job;
  if (updated != null) {
    nextJob = updated;
  }
  return { job: public_job_payload(nextJob) };
}

function jobs_cancel_active(clientNames: array<string>? = null, message: string = 'Cancelled active sync jobs.', token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (!is_admin_user(current) && !is_owner_user(current)) {
    return raw_json_error(403, 'permission denied');
  }

  let targetNames = [];
  if (clientNames != null) {
    for (const clientName of clientNames) {
      const normalized = normalize_user_name(clientName);
      if (normalized.length != 0) {
        targetNames = targetNames.concat([normalized]);
      }
    }
  }
  targetNames = unique_string_values(targetNames);

  let cancelledJobs = [];
  let cancelledJobIds = [];
  const completedAt = now_iso();
  for (const job of visible_job_rows_for(current)) {
    const status = string.from(job.status).trim();
    if (status != 'queued' && status != 'running' && status != 'applying') {
      continue;
    }
    const jobClientName = normalize_user_name(job.clientName);
    if (targetNames.length != 0 && !string_array_contains(targetNames, jobClientName)) {
      continue;
    }
    cancelledJobIds = cancelledJobIds.concat([job.id]);
    cancelledJobs = cancelledJobs.concat([public_job_payload({
      id: job.id,
      clientName: job.clientName,
      sourceClientName: job.sourceClientName,
      subscriberClientName: job.subscriberClientName,
      table: job.table,
      direction: job.direction,
      mergeRole: job.mergeRole,
      publisherServer: job.publisherServer,
      publisherDatabase: job.publisherDatabase,
      publicationName: job.publicationName,
      publisherUseWindowsAuth: job.publisherUseWindowsAuth,
      status: 'cancelled',
      progress: 100,
      rowCount: job.rowCount,
      createdAt: job.createdAt,
      updatedAt: completedAt,
      startedAt: job.startedAt,
      completedAt,
      message,
      error: message,
      clientUserId: job.clientUserId,
      ownerUserId: job.ownerUserId
    })]);
  }

  if (cancelledJobIds.length != 0) {
    db.updateMany(SyncJob, { id: { in: cancelledJobIds } }, {
      status: 'cancelled',
      progress: 100,
      completedAt,
      message,
      error: message,
      updatedAt: completedAt
    });
  }

  return {
    ok: true,
    cancelledJobCount: cancelledJobs.length,
    jobs: cancelledJobs
  };
}
