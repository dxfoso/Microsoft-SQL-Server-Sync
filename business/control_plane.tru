  if (is_owner_user(current)) {
    where = { ownerUserId: current.id };
  }
  const rows = db.selectMany(Agent, {
    where,
    orderBy: { field: 'clientName', dir: 'asc' },
    fields: ['clientName', 'machineName', 'server', 'database', 'isOnline', 'historyLimit', 'autoSyncIntervalMinutes', 'serverConnected', 'sqlConnected', 'lastHeartbeat', 'selectedTable', 'diagnosticRequestId', 'diagnosticRequestedAt', 'diagnosticRequestedByUserId', 'diagnosticLastRequestId', 'diagnosticLastUploadedAt', 'diagnosticStatus', 'diagnosticSummary', 'clientUserId', 'ownerUserId', 'updatedAt'],
    limit: limit + 1
  });
  if (rows == null) {
    return [];
  }
  return rows;
}

function live_state_job_rows_for(current: map<json>, limit: int): array<json> {
  let where = { createdAt: { lte: now_iso() } };
  if (is_client_user(current)) {
    where = { clientUserId: current.id };
  }
  if (is_owner_user(current)) {
    where = { ownerUserId: current.id };
  }
  const rows = db.selectMany(SyncJob, {
    where,
    orderBy: { field: 'createdAt', dir: 'desc' },
    fields: ['id', 'clientName', 'sourceClientName', 'table', 'direction', 'status', 'progress', 'rowCount', 'createdAt', 'updatedAt', 'startedAt', 'completedAt', 'snapshotId', 'snapshotCreatedAt', 'snapshotBytes', 'message', 'error', 'clientUserId', 'ownerUserId'],
    limit: limit + 1
  });
  if (rows == null) {
    return [];
  }
  return rows;
}

function live_state_snapshot_rows_for(current: map<json>, limit: int): array<json> {
  let where = { createdAt: { lte: now_iso() } };
  if (is_client_user(current)) {
    where = { clientUserId: current.id };
  }
  if (is_owner_user(current)) {
    where = { ownerUserId: current.id };
  }
  const rows = db.selectMany(SnapshotRecord, {
    where,
    orderBy: { field: 'createdAt', dir: 'desc' },
    fields: ['id', 'clientName', 'table', 'rowCount', 'checksum', 'createdAt', 'snapshotBytes', 'columns', 'sourceJobId', 'clientUserId', 'ownerUserId'],
    limit: limit + 1
  });
  if (rows == null) {
    return [];
  }
  return rows;
}

function bounded_public_agent_payloads(rows: array<json>, limit: int): map<json> {
  let items = [];
  let seen = 0;
  for (const row of rows) {
    seen += 1;
    if (items.length < limit) {
      items = items.concat([public_agent_payload(row)]);
    }
  }
  return {
    items,
    total: seen,
    truncated: seen > items.length
  };
}

function bounded_public_job_payloads(rows: array<json>, limit: int): map<json> {
  let items = [];
  let seen = 0;
  for (const row of rows) {
    seen += 1;
    if (items.length < limit) {
      items = items.concat([public_job_payload(row)]);
    }
  }
  return {
    items,
    total: seen,
    truncated: seen > items.length
  };
}

function bounded_public_snapshot_payloads(rows: array<json>, limit: int): map<json> {
  let items = [];
  let seen = 0;
  for (const row of rows) {
    seen += 1;
    if (items.length < limit) {
      items = items.concat([public_snapshot_payload(row)]);
    }
  }
  return {
    items,
    total: seen,
    truncated: seen > items.length
  };
}

function ensure_agent(clientName: string, clientUserId: string? = null, ownerUserId: string? = null): map<json> {
  try {
    const existing = db.selectOne(Agent, { clientName });
    if (existing != null) {
      return existing;
    }
  } catch (err) {
    const repaired = db.update(Agent, { clientName }, {
      tableRelationships: [],
      diagnosticRequestId: null,
      diagnosticRequestedAt: null,
      diagnosticRequestedByUserId: null,
      diagnosticLastRequestId: null,
      diagnosticLastUploadedAt: null,
      diagnosticStatus: 'idle',
      diagnosticSummary: '',
      diagnosticPayload: '',
      clientUserId,
      ownerUserId,
      updatedAt: now_iso()
    });
    if (repaired != null) {
      return repaired;
    }
    db.delete(Agent, { clientName });
  }
  return db.insert(Agent, {
    clientName,
    machineName: clientName,
    server: '',
    database: '',
    isOnline: false,
    historyLimit: 5,
    autoSyncIntervalMinutes: 15,
    serverConnected: false,
    sqlConnected: false,
    lastHeartbeat: '',
    selectedTable: null,
    tables: [],
    tableRelationships: [],
    diagnosticRequestId: null,
    diagnosticRequestedAt: null,
    diagnosticRequestedByUserId: null,
    diagnosticLastRequestId: null,
    diagnosticLastUploadedAt: null,
    diagnosticStatus: 'idle',
    diagnosticSummary: '',
    diagnosticPayload: '',
    clientUserId,
    ownerUserId,
    updatedAt: now_iso()
  });
}

function sync_settings_payload(agent: map<json>): map<json> {
  return {
    historyLimit: agent.historyLimit,
    autoSyncIntervalMinutes: agent.autoSyncIntervalMinutes
  };
}

function active_jobs_for_client(clientName: string): array<json> {
  const rows = db.selectMany(SyncJob, {
    where: { clientName },
    orderBy: { field: 'updatedAt', dir: 'desc' },
    fields: ['id', 'clientName', 'sourceClientName', 'table', 'direction', 'status', 'progress', 'rowCount', 'createdAt', 'updatedAt', 'startedAt', 'completedAt', 'snapshotId', 'snapshotCreatedAt', 'snapshotBytes', 'message', 'error', 'clientUserId', 'ownerUserId'],
    limit: 1000
  });
  if (rows == null) {
    return [];
  }
  let jobs = [];
  let seenTables = [];
  for (const job of rows) {
    let tableSeen = false;
    for (const seenTable of seenTables) {
      if (seenTable == job.table) {
        tableSeen = true;
      }
    }
    if (tableSeen) {
      continue;
    }

    const status = string.from(job.status).trim();
    if (status == 'queued' || status == 'snapshotting' || status == 'uploading' || status == 'downloading' || status == 'applying') {
      jobs = jobs.concat([public_job_payload(job)]);
      seenTables = seenTables.concat([job.table]);
    } else if (status == 'completed' || status == 'failed' || status == 'cancelled') {
      seenTables = seenTables.concat([job.table]);
    }
  }
  return jobs;
}

function unique_string_values(values: array<string>): array<string> {
  let unique = [];
  for (const value of values) {
    let seen = false;
    for (const existing of unique) {
      if (existing == value) {
        seen = true;
      }
    }
    if (!seen) {
      unique = unique.concat([value]);
    }
  }
  return unique;
}

function active_job_tables_for_client(clientName: string): array<string> {
  const jobs = active_jobs_for_client(clientName);
  let tables = [];
  for (const job of jobs) {
    tables = tables.concat([string.from(job.table)]);
  }
  return unique_string_values(tables);
}

function enabled_sync_tables_for_agent(agent: map<json>): array<string> {
  let enabledTables = [];
  let tables = [];
  if (agent.tables != null) {
    tables = apply_table_sync_policies(agent.ownerUserId, agent.tables, string.from(agent.database));
  }
  for (const tableState of tables) {
    if (tableState.enabled == true && tableState.table != null) {
      enabledTables = enabledTables.concat([string.from(tableState.table)]);
    }
  }
  return unique_string_values(enabledTables);
}

function create_sync_jobs_for_agent(agent: map<json>, tables: array<string>, sourceClientName: string = ''): array<json> {
  if (tables.length == 0) {
    return [];
  }
  const activeTables = active_job_tables_for_client(agent.clientName);
  const expandedTables = expand_sync_job_tables_for_owner(agent.ownerUserId, tables);
  let tablesToCreate = [];
  for (const table of expandedTables) {
    let busy = false;
    for (const activeTable of activeTables) {
      if (activeTable == table) {
        busy = true;
      }
    }
    if (!busy) {
      tablesToCreate = tablesToCreate.concat([table]);
    }
  }
  if (tablesToCreate.length == 0) {
    return [];
  }
  const rows = tablesToCreate.map((table) => {
    return {
      id: uuid.v4(),
      clientName: agent.clientName,
      sourceClientName,
      table,
      direction: 'sync',
      status: 'queued',
      progress: 0,
      rowCount: 0,
      createdAt: now_iso(),
      updatedAt: now_iso(),
      startedAt: null,
      completedAt: null,
      snapshotId: null,
      snapshotCreatedAt: null,
      snapshotBytes: 0,
      message: string.concat('Queued immediate sync for ', table, '.'),
      error: null,
      clientUserId: agent.clientUserId,
      ownerUserId: agent.ownerUserId
    };
  });
  return db.insertMany(SyncJob, rows);
}

function latest_snapshot_for(clientName: string, table: string): map<json>? {
  const rows = db.selectMany(SnapshotRecord, {
    where: { clientName, table },
    orderBy: { field: 'createdAt', dir: 'desc' },
    fields: ['id', 'clientName', 'table', 'rowCount', 'checksum', 'createdAt', 'snapshotBytes', 'columns', 'rows', 'previewRows', 'sourceJobId', 'clientUserId', 'ownerUserId'],
    limit: 100
  });
  if (rows == null || rows.length == 0) {
    return null;
  }
  return rows[0];
}

function row_key(row: map<json>, keyColumns: array<string>): string {
  if (keyColumns.length == 0) {
    return json.stringify(row);
  }
  let values = [];
  for (const column of keyColumns) {
    values = values.concat([row[column]]);
  }
  return json.stringify(values);
}

function string_array_contains(values: array<string>, target: string): bool {
  for (const value of values) {
    if (value == target) {
      return true;
    }
  }
  return false;
}

function merge_rows_by_key(existingRows: array<json>, incomingRows: array<json>, keyColumns: array<string>): array<json> {
  if (incomingRows.length == 0) {
    return existingRows;
  }
  if (existingRows.length == 0) {
    return incomingRows;
  }

  let incomingKeys = [];
  for (const incoming of incomingRows) {
    incomingKeys = incomingKeys.concat([row_key(incoming, keyColumns)]);
  }

  let retained = [];
  for (const current of existingRows) {
    if (!string_array_contains(incomingKeys, row_key(current, keyColumns))) {
      retained = retained.concat([current]);
    }
  }
  return retained.concat(incomingRows);
}

function latest_owner_snapshot_for(ownerUserId: string, table: string): map<json>? {
  const rows = db.selectMany(SnapshotRecord, {
    where: { clientName: ownerUserId, ownerUserId, table },
    orderBy: { field: 'createdAt', dir: 'desc' },
    fields: ['id', 'clientName', 'table', 'rowCount', 'checksum', 'createdAt', 'snapshotBytes', 'columns', 'rows', 'previewRows', 'sourceJobId', 'clientUserId', 'ownerUserId'],
    limit: 1
  });
  if (rows == null || rows.length == 0) {
    return null;
  }
  return rows[0];
}

function latest_download_snapshot_for_job(job: map<json>): map<json>? {
  if (job.ownerUserId != null && job.ownerUserId.trim().length != 0) {
    const ownerSnapshot = latest_owner_snapshot_for(job.ownerUserId, job.table);
    if (ownerSnapshot != null) {
      return ownerSnapshot;
    }
  }
  let source = job.clientName;
  if (job.sourceClientName != null && job.sourceClientName.trim().length != 0) {
    source = job.sourceClientName;
  }
  return latest_snapshot_for(source, job.table);
}

function normalize_key_columns(keyColumns: array<string>? = null): array<string> {
  if (keyColumns == null) {
    return [];
  }
  return keyColumns;
}

function snapshot_checksum(snapshot: map<json>): string {
  return crypto.hash(json.stringify(snapshot), 'sha256');
}

function snapshot_preview_rows(rows: array<json>): array<json> {
  let preview = [];
  let count = 0;
  for (const row of rows) {
    if (count < 5) {
      preview = preview.concat([row]);
    }
    count += 1;
  }
  return preview;
}

function auth_login(name: string, password: string, app: string = 'web'): map<json> {
  const normalizedName = normalize_user_name(name);
  let user = null;
  if (normalizedName == default_admin_username()) {
    user = seed_admin_user();
  } else {
    user = find_user_by_identity(name);
  }
  if (user == null) {
    return raw_json_error(401, 'user not found');
  }
  if (user.password != password) {
    return raw_json_error(401, 'invalid password');
  }
  return create_session_for_user(user, app);
}

function auth_me(token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'not authenticated');
  }
  return { user: public_user_payload(current) };
}

function auth_logout(token: string? = null): map<json> {
  if (token == null || token.trim().length == 0) {
    return raw_json_error(401, 'not authenticated');
  }
  const session = db.update(Session, { token }, { revokedAt: now_iso() });
  if (session == null) {
    return raw_json_error(401, 'not authenticated');
  }
  return { ok: true };
}

function users_list(token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (!is_admin_user(current) && !is_owner_user(current)) {
    return raw_json_error(403, 'permission denied');
  }
  const users = visible_user_rows_for(current).map((user) => public_user_payload(user));
  return { users };
}

function users_create(name: string, email: string = '', password: string, role: string, ownerUserId: string? = null, token: string? = null): map<json> {
  const normalized = normalize_user_name(name);
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }

  let resolvedRole = role;
  let resolvedOwnerUserId = ownerUserId;
  if (is_owner_user(current)) {
    if (role != 'client') {
      return raw_json_error(403, 'owners can create client accounts only');
    }
    resolvedRole = 'client';
    resolvedOwnerUserId = current.id;
  } else if (is_admin_user(current)) {
    if (role != 'owner' && role != 'client') {
      return raw_json_error(403, 'admins can create owner or client accounts only');
    }
    if (role == 'client') {
      const owner = find_user_by_id(ownerUserId);
      if (owner == null || !is_owner_user(owner)) {
        return raw_json_error(400, 'client accounts must belong to a valid owner');
      }
      resolvedOwnerUserId = owner.id;
    } else {
      resolvedOwnerUserId = null;
    }
  } else {
    return raw_json_error(403, 'permission denied');
  }

  const existing = find_user_by_identity(normalized);
  if (existing != null) {
    if (!can_manage_user(current, existing)) {
      return raw_json_error(409, 'an account with that name already exists');
    }
    return raw_json_success({ user: public_user_payload(existing), existed: true }, 200);
  }

  const user = db.insert(User, {
    id: uuid.v4(),
    username: normalized,
    email,
    name: normalized,
    role: resolvedRole,
    ownerUserId: resolvedOwnerUserId,
    createdByUserId: current.id,
    password,
    createdAt: now_iso()
  });
  return raw_json_success({ user: public_user_payload(user) }, 201);
}

function user_reset_password(userId: string, password: string, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  const target = find_user_by_id(userId);
  if (!can_manage_user(current, target)) {
    return raw_json_error(403, 'permission denied');
  }
  const user = db.update(User, { id: userId }, { password });
  if (user == null) {
    return raw_json_error(404, 'user not found');
  }
  return { ok: true };
}

function user_delete(userId: string, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  const target = find_user_by_id(userId);
  if (target == null) {
    return raw_json_error(404, 'user not found');
  }
  if (!can_manage_user(current, target)) {
    return raw_json_error(403, 'permission denied');
  }
  if (!is_client_user(target)) {
    return raw_json_error(403, 'only client accounts can be deleted');
  }

  db.updateMany(Session, { userId }, { revokedAt: now_iso() });
  db.delete(Agent, { clientName: target.username });
  const deleted = db.delete(User, { id: userId });
  if (deleted == 0) {
    return raw_json_error(404, 'user not found');
  }
  return { ok: true, user: public_user_payload(target) };
}

function live_state(token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  const agentLimit = live_state_agent_limit();
  const jobLimit = live_state_job_limit();
  const snapshotLimit = live_state_snapshot_limit();
  const agentPage = bounded_public_agent_payloads(
    live_state_agent_rows_for(current, agentLimit),
    agentLimit
  );
  const jobPage = bounded_public_job_payloads(
    live_state_job_rows_for(current, jobLimit),
    jobLimit
  );
  const snapshotPage = bounded_public_snapshot_payloads(
    live_state_snapshot_rows_for(current, snapshotLimit),
    snapshotLimit
  );
  return {
    generatedAt: now_iso(),
    syncEngine: sync_engine_metadata(),
    agents: agentPage.items,
    jobs: jobPage.items,
    snapshots: snapshotPage.items,
    limits: {
      agents: agentLimit,
      jobs: jobLimit,
      snapshots: snapshotLimit
    },
    totals: {
      agents: agentPage.total,
      jobs: jobPage.total,
      snapshots: snapshotPage.total
    },
    truncated: {
      agents: agentPage.truncated,
      jobs: jobPage.truncated,
      snapshots: snapshotPage.truncated
    }
  };
}

function agents_heartbeat(clientName: string? = null, machineName: string = '', historyLimit: int? = null, autoSyncIntervalMinutes: int? = null, server: string = '', database: string = '', serverConnected: bool = false, sqlConnected: bool = false, selectedTable: string? = null, tables: array<json>? = null, tableRelationships: array<json>? = null, token: string? = null): map<json> {
  let resolvedClientName = '';
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (clientName == null || clientName.trim().length == 0) {
    if (current.username == null) {
      resolvedClientName = normalize_user_name(current.name);
    } else {
      resolvedClientName = current.username;
    }
  } else {
    resolvedClientName = normalize_user_name(clientName);
  }
  const clientUser = find_user_by_identity(resolvedClientName);
  if (clientUser != null && !can_manage_user(current, clientUser)) {
    return raw_json_error(403, 'permission denied');
  }
  let userId = null;
  let ownerUserId = owner_namespace_for_user(current);
  userId = current.id;
  const agent = ensure_agent(
    resolvedClientName,
    userId,
    ownerUserId
  );
  let nextTables = agent.tables;
  if (tables != null) {
    nextTables = tables;
  }
  const nextTableRelationships = bounded_table_relationships(database, tableRelationships, resolvedClientName);
  nextTables = bounded_agent_tables(nextTables, selectedTable);
  nextTables = apply_table_sync_policies(ownerUserId, nextTables, database);
  const updated = db.update(Agent, { clientName: resolvedClientName }, {
    machineName: machineName.trim().length == 0 ? resolvedClientName : machineName,
    server,
    database,
    isOnline: true,
    historyLimit: clamp_history_limit(historyLimit),
    autoSyncIntervalMinutes: clamp_auto_sync_interval(autoSyncIntervalMinutes),
    serverConnected,
    sqlConnected,
    lastHeartbeat: now_iso(),
    selectedTable,
    tables: nextTables,
    tableRelationships: nextTableRelationships,
    updatedAt: now_iso()
  });
  let nextAgent = agent;
  if (updated != null) {
    nextAgent = updated;
  }
  if (nextAgent == null) {
    return raw_json_error(500, 'agent heartbeat state unavailable');
  }
  return {
    ok: true,
    syncEngine: sync_engine_metadata(),
    syncSettings: sync_settings_payload(nextAgent),
    tablePolicies: table_sync_policy_payloads_for_database(ownerUserId, database),
    tableDependencies: table_dependency_payloads_for_database(ownerUserId, database),
    jobs: active_jobs_for_client(resolvedClientName),
    diagnostics: agent_diagnostics_payload(nextAgent)
  };
}

function agent_sync_settings_get(clientName: string, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  const user = find_user_by_identity(clientName);
  if (user != null && !can_manage_user(current, user)) {
    return raw_json_error(403, 'permission denied');
  }
  let userId = null;
  let ownerUserId = null;
  if (user != null) {
    userId = user.id;
    ownerUserId = user.ownerUserId;
  }
  const agent = ensure_agent(clientName, userId, ownerUserId);
  return { syncSettings: sync_settings_payload(agent) };
}

function agent_sync_settings_post(clientName: string, historyLimit: int? = null, autoSyncIntervalMinutes: int? = null, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  const user = find_user_by_identity(clientName);
  if (user != null && !can_manage_user(current, user)) {
    return raw_json_error(403, 'permission denied');
  }
  let userId = null;
  let ownerUserId = null;
  if (user != null) {
    userId = user.id;
    ownerUserId = user.ownerUserId;
  }
  ensure_agent(clientName, userId, ownerUserId);
  const updated = db.update(Agent, { clientName }, {
    historyLimit: clamp_history_limit(historyLimit),
    autoSyncIntervalMinutes: clamp_auto_sync_interval(autoSyncIntervalMinutes),
    updatedAt: now_iso()
  });
  if (updated == null) {
    return raw_json_error(404, 'agent not found');
  }
  return { ok: true, syncSettings: sync_settings_payload(updated) };
}

function agent_jobs(clientName: string): map<json> {
  return { jobs: active_jobs_for_client(clientName) };
}

function agent_diagnostics_request(clientName: string, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (!is_admin_user(current) && !is_owner_user(current)) {
    return raw_json_error(403, 'permission denied');
  }
  const normalizedClientName = normalize_user_name(clientName);
  const targetUser = find_user_by_identity(normalizedClientName);
  if (targetUser != null && !can_manage_user(current, targetUser)) {
    return raw_json_error(403, 'permission denied');
  }
  let targetOwnerUserId = null;
  if (targetUser != null) {
    targetOwnerUserId = targetUser.ownerUserId;
  }
  let targetClientUserId = null;
  if (targetUser != null) {
    targetClientUserId = targetUser.id;
  }
  const agent = ensure_agent(normalizedClientName, targetClientUserId, targetOwnerUserId);
  const updated = db.update(Agent, { clientName: normalizedClientName }, {
    diagnosticRequestId: uuid.v4(),
    diagnosticRequestedAt: now_iso(),
    diagnosticRequestedByUserId: current.id,
    diagnosticStatus: 'requested',
    updatedAt: now_iso()
  });
  if (updated == null) {
    return raw_json_error(404, 'client not found');
  }
  return {
    ok: true,
    clientName: normalizedClientName,
    diagnostics: agent_diagnostics_payload(updated)
  };
}

function agent_diagnostics_request_all(token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (!is_admin_user(current) && !is_owner_user(current)) {
    return raw_json_error(403, 'permission denied');
  }

  const requestId = uuid.v4();
  const requestedAt = now_iso();
  const visibleAgents = visible_agent_rows_for(current);
  let requestedClientNames = [];
  for (const agent of visibleAgents) {
    const clientName = normalize_user_name(agent.clientName);
    if (clientName.length != 0) {
      requestedClientNames = requestedClientNames.concat([clientName]);
    }
  }
  if (requestedClientNames.length == 0) {
    return {
      ok: true,
      requestId,
      requestedAt,
      requestedByUserId: current.id,
      requestedClientCount: 0,
      requestedClientNames: []
    };
  }

  if (is_owner_user(current)) {
    db.updateMany(Agent, { ownerUserId: current.id }, {
      diagnosticRequestId: requestId,
      diagnosticRequestedAt: requestedAt,
      diagnosticRequestedByUserId: current.id,
      diagnosticStatus: 'requested',
      updatedAt: requestedAt
    });
  } else {
    db.updateMany(Agent, { clientName: { gte: '' } }, {
      diagnosticRequestId: requestId,
      diagnosticRequestedAt: requestedAt,
      diagnosticRequestedByUserId: current.id,
      diagnosticStatus: 'requested',
      updatedAt: requestedAt
    });
  }

  return {
    ok: true,
    requestId,
    requestedAt,
    requestedByUserId: current.id,
    requestedClientCount: requestedClientNames.length,
    requestedClientNames
  };
}

function agent_diagnostics_upload(clientName: string? = null, requestId: string? = null, summary: string = '', payload: string = '', token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  let resolvedClientName = '';
  if (clientName == null || clientName.trim().length == 0) {
    if (current.username == null) {
      resolvedClientName = normalize_user_name(current.name);
    } else {
      resolvedClientName = normalize_user_name(current.username);
    }
  } else {
    resolvedClientName = normalize_user_name(clientName);
  }
  const targetUser = find_user_by_identity(resolvedClientName);
  if (targetUser != null && !can_manage_user(current, targetUser)) {
    return raw_json_error(403, 'permission denied');
  }
  let targetOwnerUserId = owner_namespace_for_user(current);
  let targetClientUserId = current.id;
  if (targetUser != null) {
    targetOwnerUserId = targetUser.ownerUserId;
    targetClientUserId = targetUser.id;
  }
  const agent = ensure_agent(resolvedClientName, targetClientUserId, targetOwnerUserId);
  let resolvedRequestId = '';
  if (requestId != null) {
    resolvedRequestId = string.from(requestId).trim();
  }
  if (resolvedRequestId.length == 0 && agent.diagnosticRequestId != null) {
    resolvedRequestId = string.from(agent.diagnosticRequestId).trim();
  }
  let resolvedRequestIdOrNull = null;
  if (resolvedRequestId.length != 0) {
    resolvedRequestIdOrNull = resolvedRequestId;
  }
  const updated = db.update(Agent, { clientName: resolvedClientName }, {
    diagnosticLastRequestId: resolvedRequestIdOrNull,
    diagnosticLastUploadedAt: now_iso(),
    diagnosticStatus: 'uploaded',
    diagnosticSummary: truncate_text(summary, 4000),
    diagnosticPayload: truncate_text(payload, 64000),
    updatedAt: now_iso()
  });
  if (updated == null) {
    return raw_json_error(404, 'client not found');
  }
  return {
    ok: true,
    clientName: resolvedClientName,
    diagnostics: agent_diagnostics_payload(updated)
  };
}

function agent_diagnostics_get(clientName: string, token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  const normalizedClientName = normalize_user_name(clientName);
  const agent = db.selectOne(Agent, { clientName: normalizedClientName });
  if (agent == null) {
    return raw_json_error(404, 'client not found');
  }
  if (!can_read_agent(current, agent.ownerUserId, agent.clientUserId)) {
    return raw_json_error(403, 'permission denied');
  }
  return {
    clientName: normalizedClientName,
    diagnostics: agent_diagnostics_payload(agent, true)
  };
}

function jobs_create_all_enabled(token: string? = null): map<json> {
  const current = current_user_record(token);
  if (current == null) {
    return raw_json_error(401, 'permission denied');
  }
  if (!is_admin_user(current) && !is_owner_user(current)) {
    return raw_json_error(403, 'permission denied');
  }

  let createdJobs = [];
  let queuedClientNames = [];
  let skippedOfflineClients = [];
  let skippedBusyTables = [];

  for (const agent of visible_agent_rows_for(current)) {
    const enabledTables = enabled_sync_tables_for_agent(agent);
    if (enabledTables.length == 0) {
      continue;
    }
    if (agent.isOnline != true || agent.serverConnected != true || agent.sqlConnected != true) {
      skippedOfflineClients = skippedOfflineClients.concat([string.from(agent.clientName)]);
      continue;
    }
    const activeTables = active_job_tables_for_client(agent.clientName);
    let tablesToQueue = [];
    for (const table of enabledTables) {
      let busy = false;
      for (const activeTable of activeTables) {
        if (activeTable == table) {
          busy = true;
        }
      }
      if (busy) {
        skippedBusyTables = skippedBusyTables.concat([string.concat(agent.clientName, '::', table)]);
      } else {
        tablesToQueue = tablesToQueue.concat([table]);
      }
    }
    if (tablesToQueue.length == 0) {
      continue;
    }
    const clientJobs = create_sync_jobs_for_agent(agent, tablesToQueue);
    if (clientJobs.length > 0) {
      createdJobs = createdJobs.concat(clientJobs);
      queuedClientNames = queuedClientNames.concat([string.from(agent.clientName)]);
    }
  }

  return {
    ok: true,
    jobs: createdJobs.map((job) => public_job_payload(job)),
    queuedJobCount: createdJobs.length,
    queuedClientCount: unique_string_values(queuedClientNames).length,
    skippedOfflineClients: unique_string_values(skippedOfflineClients),
    skippedBusyTables: unique_string_values(skippedBusyTables)
  };
}

function sync_job_reset_batch(limit: int = 200): map<json> {
  const rows = db.selectMany(SyncJob, {
    where: { id: { gte: '' } },
    orderBy: { field: 'id', dir: 'asc' },
    fields: ['id'],
    limit
  });
  if (rows == null || rows.length == 0) {
    return { deletedCount: 0, hasMore: false };
  }
  let ids = [];
  for (const row of rows) {
    ids = ids.concat([string.from(row.id)]);
  }
  return {
    deletedCount: db.deleteMany(SyncJob, { id: { in: ids } }),
    hasMore: rows.length >= limit
  };
}

