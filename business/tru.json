{
  "name": "Microsoft SQL Server Sync",
  "mode": "release",
  "port": 9001,
  "storageDir": "storage",
  "truDir": ".",
  "version": "0.3",
  "settings": {
    "host": "0.0.0.0",
    "admin": {
      "requireKey": false,
      "primaryColor": "#0f766e",
      "key": "replace-with-production-admin-key"
    },
    "specPollMs": 1000,
    "specCachePath": ".tru_spec_cache.sqlite",
    "requestTimeoutMs": 10000,
    "callConcurrency": 64
  }
}
